@model StudentCareHomeroomTeacherPageViewModel
@{
    ViewData["Title"] = "ครูโฮมรูม";
}

<div class="teacher-shell">
    <section class="teacher-hero teacher-hero-teal mb-3">
        <div class="teacher-hero-body">
            <div class="teacher-hero-copy">
                <div class="teacher-kicker">Student Care Admin</div>
                <h1 class="teacher-hero-title">ครูโฮมรูม</h1>
                <p class="teacher-hero-text">เพิ่ม แก้ไข และกำหนดห้องประจำชั้นให้ครูโฮมรูมของระบบดูแลช่วยเหลือนักเรียน</p>
            </div>
            <div class="teacher-hero-stack">
                <div class="teacher-hero-chip">
                    <span class="teacher-chip-label">บัญชีครูโฮมรูม</span>
                    <strong>@Model.Teachers.Count รายการ</strong>
                </div>
                <a class="btn btn-light" asp-action="Index">
                    <i class="bi bi-sliders me-1"></i> ประเภทคะแนน
                </a>
            </div>
        </div>
    </section>

    <div class="row g-3">
        <div class="col-xl-4">
            <section class="teacher-section-card h-100">
                <div class="teacher-section-head">
                    <div>
                        <div class="teacher-section-kicker">Homeroom Account</div>
                        <h2 class="teacher-section-title" data-form-title>เพิ่มครูโฮมรูม</h2>
                    </div>
                </div>

                <form asp-action="SaveHomeroomTeacher" method="post" class="row g-3" data-homeroom-form>
                    @Html.AntiForgeryToken()
                    <input asp-for="Input.UserId" type="hidden" name="UserId" data-input-user-id />

                    <div class="col-12">
                        <label asp-for="Input.FullName" class="form-label">ชื่อ-นามสกุล</label>
                        <input asp-for="Input.FullName" name="FullName" class="form-control" placeholder="เช่น ครูสมชาย ใจดี" data-input-full-name />
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.Username" class="form-label">ชื่อผู้ใช้</label>
                        <input asp-for="Input.Username" name="Username" class="form-control" placeholder="เช่น homeroom-m101" data-input-username />
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.Email" class="form-label">อีเมล</label>
                        <input asp-for="Input.Email" name="Email" type="email" class="form-control" placeholder="homeroom@school.local" data-input-email />
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.Password" class="form-label">รหัสผ่าน</label>
                        <input asp-for="Input.Password" name="Password" type="password" class="form-control" placeholder="กรอกเมื่อเพิ่มใหม่หรือเมื่อต้องการเปลี่ยนรหัส" data-input-password />
                    </div>
                    <div class="col-12">
                        <label asp-for="Input.AssignedClassroomId" class="form-label">ห้องประจำชั้น</label>
                        <select asp-for="Input.AssignedClassroomId" name="AssignedClassroomId" class="form-select" data-input-classroom>
                            <option value="">-- เลือกห้องประจำชั้น --</option>
                            @foreach (var classroom in Model.ClassroomOptions)
                            {
                                <option value="@classroom.Value">@classroom.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input asp-for="Input.IsActive" name="IsActive" class="form-check-input" type="checkbox" data-input-active />
                            <label asp-for="Input.IsActive" class="form-check-label">เปิดใช้งานบัญชี</label>
                        </div>
                    </div>
                    <div class="col-12 d-flex gap-2 justify-content-end">
                        <button type="button" class="btn btn-outline-secondary" data-reset-homeroom>
                            ล้างฟอร์ม
                        </button>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle me-1"></i> บันทึกครูโฮมรูม
                        </button>
                    </div>
                </form>
            </section>
        </div>

        <div class="col-xl-8">
            <section class="teacher-section-card h-100">
                <div class="teacher-section-head">
                    <div>
                        <div class="teacher-section-kicker">Assigned Rooms</div>
                        <h2 class="teacher-section-title">รายชื่อครูโฮมรูม</h2>
                    </div>
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>ครูโฮมรูม</th>
                                <th>บัญชี</th>
                                <th>ห้องประจำชั้น</th>
                                <th>สถานะ</th>
                                <th class="text-end">จัดการ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Teachers.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">ยังไม่มีครูโฮมรูมในระบบดูแล</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var teacher in Model.Teachers)
                                {
                                    <tr>
                                        <td>
                                            <div class="fw-semibold">@teacher.FullName</div>
                                            <div class="small text-muted">@teacher.Email</div>
                                        </td>
                                        <td>@teacher.Username</td>
                                        <td>@teacher.AssignedClassroomName</td>
                                        <td>
                                            <span class="badge @(teacher.IsActive ? "bg-success" : "bg-secondary") text-white">
                                                @(teacher.IsActive ? "ใช้งาน" : "ปิดใช้งาน")
                                            </span>
                                        </td>
                                        <td class="text-end">
                                            <button type="button"
                                                    class="btn btn-sm btn-outline-primary"
                                                    data-edit-homeroom
                                                    data-user-id="@teacher.UserId"
                                                    data-full-name="@teacher.FullName"
                                                    data-username="@teacher.Username"
                                                    data-email="@teacher.Email"
                                                    data-classroom-id="@teacher.AssignedClassroomId"
                                                    data-active="@teacher.IsActive.ToString().ToLowerInvariant()">
                                                แก้ไข
                                            </button>
                                            <form asp-action="ToggleHomeroomTeacher" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@teacher.UserId" />
                                                <button type="submit" class="btn btn-sm @(teacher.IsActive ? "btn-outline-warning" : "btn-outline-success")">
                                                    @(teacher.IsActive ? "ปิดใช้งาน" : "เปิดใช้งาน")
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (() => {
            const form = document.querySelector('[data-homeroom-form]');
            if (!form) return;

            const setValue = (selector, value) => {
                const input = form.querySelector(selector);
                if (input) input.value = value || '';
            };

            const resetForm = () => {
                form.reset();
                setValue('[data-input-user-id]', '');
                setValue('[data-input-password]', '');
                const active = form.querySelector('[data-input-active]');
                if (active) active.checked = true;
                const title = document.querySelector('[data-form-title]');
                if (title) title.textContent = 'เพิ่มครูโฮมรูม';
            };

            document.querySelectorAll('[data-edit-homeroom]').forEach((button) => {
                button.addEventListener('click', () => {
                    setValue('[data-input-user-id]', button.dataset.userId);
                    setValue('[data-input-full-name]', button.dataset.fullName);
                    setValue('[data-input-username]', button.dataset.username);
                    setValue('[data-input-email]', button.dataset.email);
                    setValue('[data-input-classroom]', button.dataset.classroomId);
                    setValue('[data-input-password]', '');

                    const active = form.querySelector('[data-input-active]');
                    if (active) active.checked = button.dataset.active === 'true';

                    const title = document.querySelector('[data-form-title]');
                    if (title) title.textContent = 'แก้ไขครูโฮมรูม';
                    form.scrollIntoView({ behavior: 'smooth', block: 'center' });
                });
            });

            form.querySelector('[data-reset-homeroom]')?.addEventListener('click', resetForm);
        })();
    </script>
}
