@model StudentCareProfileDetailViewModel
@{
    Layout = null;
}
<!doctype html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>แฟ้มดูแลนักเรียน - @Model.StudentName</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: #fff; padding: 20px; }
        .card { break-inside: avoid; }
        @@media print {
            body { padding: 0; }
            a[href]:after { content: ""; }
        }
    </style>
</head>
<body onload="window.print()">
    <partial name="_StudentCareProfileDetail" model="Model" />
</body>
</html>
