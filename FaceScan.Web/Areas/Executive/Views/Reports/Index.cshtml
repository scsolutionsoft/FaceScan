        border: 1px solid rgba(26, 77, 91, 0.14);
        background: linear-gradient(180deg, #ffffff 0%, #f6fbfd 100%);
        box-shadow: 0 10px 24px rgba(20, 56, 71, 0.08);
    }
    .executive-risk-spotlight-card:hover { text-decoration: none; color: inherit; border-color: rgba(28, 100, 120, 0.36); }
    .executive-risk-rank {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 1.8rem;
        height: 1.8rem;
        border-radius: 999px;
        font-size: .78rem;
        font-weight: 700;
        margin-right: .45rem;
        background: #0f4e5f;
        color: #f5fbfd;
    }
    .executive-risk-line { font-size: .9rem; color: #486473; margin-top: .3rem; }
    .executive-risk-student-grid { display: grid; gap: .8rem; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); }
    .executive-risk-student-card {
        display: block;
        text-decoration: none;
        color: inherit;
        border-radius: 16px;
        padding: .9rem 1rem;
        background: linear-gradient(180deg, #ffffff 0%, #f8fcfe 100%);
        border: 1px solid rgba(24, 78, 93, 0.15);
        box-shadow: 0 8px 20px rgba(19, 57, 73, 0.09);
    }
    .executive-risk-student-card:hover { text-decoration: none; color: inherit; border-color: rgba(28, 100, 120, 0.36); }
    .executive-student-risk-line { font-size: .86rem; color: #4b6877; margin-top: .35rem; }
    .executive-risk-trend-row {
        display: grid;
        grid-template-columns: 120px 1fr auto;
        gap: .75rem;
        align-items: center;
        padding: .6rem .2rem;
        border-bottom: 1px dashed rgba(33, 77, 92, 0.15);
    }
    .executive-risk-trend-bar {
        height: 9px;
        border-radius: 999px;
        background: #e8f0f4;
        overflow: hidden;
    }
    .executive-risk-trend-bar > span {
        display: block;
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, #ef6b6b 0%, #f3b54a 45%, #33a56d 100%);
    }
    .executive-sparkline-wrap {
        border: 1px solid rgba(31, 88, 106, 0.15);
        border-radius: 14px;
        background: linear-gradient(180deg, #fbfeff 0%, #f2f8fb 100%);
        padding: .65rem .75rem;
        margin-bottom: .8rem;
    }
    .executive-sparkline-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: .4rem;
        color: #3d6171;
        font-size: .84rem;
    }

    .executive-kpi-card, .executive-insight-card, .executive-summary-card {
        display: block; color: inherit; text-decoration: none;
        padding: 1.1rem 1.15rem; border-radius: 22px; background: #fff;
        border: 1px solid rgba(30, 85, 102, 0.08); box-shadow: 0 12px 30px rgba(18, 36, 45, 0.06);
        transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease;
    }
    .executive-summary-card:hover {
        transform: translateY(-2px); border-color: rgba(29, 111, 140, 0.36);
        box-shadow: 0 16px 34px rgba(17, 63, 78, 0.12); text-decoration: none; color: inherit;
    }
    .executive-kpi-card.is-primary { background: linear-gradient(135deg, #153f4a 0%, #1f5967 100%); color: #f7fbfc; }
    .executive-kpi-card.is-success { background: linear-gradient(135deg, #1f6f58 0%, #2f8f6f 100%); color: #f7fbfc; }
    .executive-kpi-label, .executive-insight-title { display: block; font-size: .82rem; color: #6d7f8d; margin-bottom: .45rem; }
    .executive-kpi-card.is-primary .executive-kpi-label, .executive-kpi-card.is-success .executive-kpi-label { color: rgba(247, 251, 252, 0.74); }
    .executive-kpi-value, .executive-insight-value { font-size: clamp(1.6rem, 2vw, 2.2rem); font-weight: 700; line-height: 1; margin-bottom: .4rem; }
    .executive-kpi-meta, .executive-insight-caption, .executive-summary-meta, .executive-summary-times { color: #607483; font-size: .88rem; }
    .executive-kpi-card.is-primary .executive-kpi-meta, .executive-kpi-card.is-success .executive-kpi-meta { color: rgba(247, 251, 252, 0.78); }
    .executive-insight-card { border-width: 0; }
    .executive-insight-neutral { background: linear-gradient(180deg, #f8fbfc 0%, #eef6f8 100%); }
    .executive-insight-good { background: linear-gradient(180deg, #eefaf3 0%, #dbf4e4 100%); }
    .executive-insight-warn { background: linear-gradient(180deg, #fff7e9 0%, #ffe9bf 100%); }
    .executive-insight-alert { background: linear-gradient(180deg, #fff0ef 0%, #ffd7d3 100%); }

    .executive-summary-card-head { display: flex; justify-content: space-between; gap: .75rem; align-items: start; margin-bottom: .95rem; }
    .executive-summary-title { margin: 0; font-size: 1.08rem; color: #14323d; font-weight: 700; }
    .executive-summary-subtitle { display: block; font-size: .85rem; color: #6f8592; margin-top: .15rem; }
    .executive-risk-badge {
        display: inline-flex;
        align-items: center;
        gap: .35rem;
        margin-top: .45rem;
        padding: .24rem .58rem;
        border-radius: 999px;
        font-size: .74rem;
        letter-spacing: .02em;
        font-weight: 700;
    }
    .risk-high { background: #ffe1df; color: #a52424; }
    .risk-watch { background: #ffefcc; color: #9a6400; }
    .risk-normal { background: #dcf4e6; color: #1c6e45; }
    .executive-rate-badge { min-width: 84px; text-align: center; padding: .55rem .7rem; border-radius: 18px; background: #edf5f7; color: #164654; font-weight: 700; }
    .executive-summary-metrics { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .7rem; margin-bottom: .9rem; }
    .executive-summary-metric { padding: .7rem .75rem; border-radius: 16px; background: #f7fafb; }
    .executive-summary-metric strong { display: block; font-size: 1.05rem; color: #173844; }
    .executive-summary-metric span { display: block; font-size: .78rem; color: #718592; }
    .executive-summary-foot { display: flex; flex-wrap: wrap; gap: .5rem; margin-top: .35rem; }
    .executive-pill { display: inline-flex; align-items: center; gap: .35rem; padding: .4rem .65rem; border-radius: 999px; background: #f0f6f8; color: #2c4c59; font-size: .8rem; }

    .executive-table-panel .card-header, .executive-chart-panel .card-header, .executive-summary-panel .card-header {
        background: transparent; border-bottom: 1px solid rgba(25, 62, 73, 0.08); padding: 1.15rem 1.2rem 0;
    }
    .executive-table-panel .table thead th {
        white-space: nowrap; border-bottom-width: 1px; color: #4d6471; font-size: .83rem; text-transform: uppercase; letter-spacing: .04em;
    }
    .executive-table-panel .table tbody tr:hover { background: #f8fbfc; }
    .executive-student-meta { display: flex; align-items: center; gap: .75rem; }
    .executive-avatar {
        width: 42px; height: 42px; border-radius: 50%; object-fit: cover;
        background: #eef5f8; border: 1px solid rgba(30, 85, 102, 0.12);
    }
    .executive-empty { padding: 1rem 1.2rem 1.25rem; color: #6a7e8b; }

    @@media (max-width: 991.98px) {
        .executive-hero-body { grid-template-columns: 1fr; padding: 1.5rem; }
        .executive-live-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="executive-shell">
    <section class="card executive-hero">
        <div class="executive-hero-body">
            <div>
                <div class="executive-kicker"><i class="bi bi-bar-chart-line"></i> Executive Attendance</div>
                <h1 class="executive-title">รายงานการมาเรียนรายระดับชั้นและรายห้องเรียน</h1>
                <p class="executive-subtitle">สรุปภาพรวมการมาเรียนในช่วงวันที่เลือก พร้อมมุมมองรายระดับชั้น รายห้อง และรายบุคคล สำหรับติดตามจุดเสี่ยงและความพร้อมของข้อมูลใบหน้าในหน้าเดียว</p>
            </div>
            <div class="executive-range-chip-grid">
                <div class="executive-range-chip">
                    <span class="executive-range-chip-label">ช่วงวันที่</span>
                    <strong>@Model.Filter.DateFrom.ToThaiDate("dd MMM yyyy") - @Model.Filter.DateTo.ToThaiDate("dd MMM yyyy")</strong>
                </div>
                <div class="executive-range-chip">
                    <span class="executive-range-chip-label">ตัวกรองหลัก</span>
                    <strong>@(Model.GradeLevels.FirstOrDefault(x => x.Value == Model.Filter.GradeLevelId)?.Text ?? "ทุกระดับชั้น") / @(Model.Classrooms.FirstOrDefault(x => x.Value == Model.Filter.ClassroomId)?.Text ?? "ทุกห้อง")</strong>
                </div>
                <div class="executive-range-chip">
                    <span class="executive-range-chip-label">คำค้น</span>
                    <strong>@(string.IsNullOrWhiteSpace(Model.Filter.StudentKeyword) ? "ไม่ได้ระบุ" : Model.Filter.StudentKeyword)</strong>
                </div>
            </div>
        </div>
    </section>

    <form method="get" class="card executive-panel executive-filter-card">
        <div class="executive-filter-head">
            <div>
                <div class="executive-section-kicker">Filter</div>
                <h2 class="executive-section-title">เลือกช่วงเวลาและกลุ่มเป้าหมายของรายงาน</h2>
            </div>
            <div class="executive-section-note">เพิ่ม drill-down จากการ์ดสรุปและ export CSV เพื่อใช้งานต่อในงานธุรการได้ทันที</div>
        </div>

        <div class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label">จากวันที่</label>
                <input type="date" name="DateFrom" class="form-control" value="@Model.Filter.DateFrom.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label">ถึงวันที่</label>
                <input type="date" name="DateTo" class="form-control" value="@Model.Filter.DateTo.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <label class="form-label">ระดับชั้น</label>
                <select name="GradeLevelId" class="form-select">
                    <option value="">ทั้งหมด</option>
                    @foreach (var item in Model.GradeLevels)
                    {
                        <option value="@item.Value" selected="@(Model.Filter.GradeLevelId == item.Value ? "selected" : null)">@item.Text</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">ห้องเรียน</label>
                <select name="ClassroomId" class="form-select">
                    <option value="">ทั้งหมด</option>
                    @foreach (var item in Model.Classrooms)
                    {
