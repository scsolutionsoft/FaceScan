    .executive-live-counter strong { display: block; font-size: 1.35rem; line-height: 1; color: #163947; }
    .executive-live-counter span { font-size: .78rem; color: #617b88; }
    .executive-live-feed { display: grid; gap: .55rem; max-height: 290px; overflow: auto; }
    .executive-live-item {
