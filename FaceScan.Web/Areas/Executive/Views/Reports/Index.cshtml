    .executive-live-trend-bars span.is-failed { background: #d05a4b; }
    .executive-live-config-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: .5rem;
        margin-top: .55rem;
    }
    .executive-live-config-item {
        border-radius: 11px;
        border: 1px solid rgba(23, 80, 95, 0.15);
        background: #f8fcfe;
        padding: .45rem .55rem;
    }
    .executive-live-config-item label {
        display: block;
        font-size: .72rem;
        color: #5f7a88;
        margin-bottom: .25rem;
    }
    .executive-live-config-item .form-select { font-size: .8rem; border-radius: 10px; }
    .executive-live-config-toggle {
        margin-top: .45rem;
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        font-size: .8rem;
        color: #355a69;
    }
    .executive-live-toast-wrap {
        position: fixed;
        right: 1rem;
        bottom: 1rem;
        display: grid;
        gap: .55rem;
        z-index: 1090;
        max-width: min(92vw, 390px);
        pointer-events: none;
    }
    .executive-live-toast {
        pointer-events: auto;
        border-radius: 14px;
        border: 1px solid rgba(198, 63, 56, 0.28);
        background: linear-gradient(180deg, #fff4f2 0%, #ffe8e4 100%);
        box-shadow: 0 12px 30px rgba(129, 44, 36, 0.18);
        padding: .72rem .8rem;
        animation: executive-toast-in .2s ease-out;
    }
    .executive-live-toast strong {
        display: block;
        color: #8e2f27;
        font-size: .86rem;
        margin-bottom: .2rem;
    }
    .executive-live-toast span {
        display: block;
        color: #8a4a41;
        font-size: .8rem;
    }
    @@keyframes executive-toast-in {
        from { opacity: 0; transform: translateY(8px); }
        to { opacity: 1; transform: translateY(0); }
    }
    .executive-risk-spotlight-grid { display: grid; gap: .8rem; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
    .executive-risk-spotlight-card {
        display: block;
