    <section class="card executive-panel executive-summary-panel">
        <div class="card-header">
            <div class="executive-section-kicker">Risk Spotlight</div>
            <h2 class="executive-section-title">Top 5 นักเรียนเสี่ยงที่ควรติดตาม</h2>
            <div class="executive-section-note">คำนวณจากการขาด, หนีเรียน, มาสาย และอัตรามาเรียน เพื่อช่วยโฟกัสรายบุคคลที่ต้องติดตามกับครูประจำชั้น</div>
        </div>
        <div class="card-body">
            @if (Model.TopRiskStudents.Count == 0)
            {
                <div class="executive-empty">ไม่พบข้อมูลนักเรียนเสี่ยงในช่วงวันที่เลือก</div>
            }
            else
            {
                <div class="executive-risk-student-grid">
                    @for (var i = 0; i < Model.TopRiskStudents.Count; i++)
                    {
                        var student = Model.TopRiskStudents[i];
                        var riskClass = student.PresentRate < 70m ? "risk-high" : student.PresentRate < 85m ? "risk-watch" : "risk-normal";

                        <a class="executive-risk-student-card"
                           asp-action="Index"
                           asp-route-DateFrom="@Model.Filter.DateFrom.ToString("yyyy-MM-dd")"
                           asp-route-DateTo="@Model.Filter.DateTo.ToString("yyyy-MM-dd")"
                           asp-route-GradeLevelId=""
                           asp-route-ClassroomId=""
                           asp-route-StudentKeyword="@student.StudentCode">
                            <div class="d-flex align-items-start justify-content-between gap-2">
                                <div>
                                    <span class="executive-risk-rank">#@(i + 1)</span>
                                    <strong>@student.StudentName</strong>
                                    <span class="executive-summary-subtitle">@student.StudentCode | @student.GradeLevel/@student.Classroom</span>
                                </div>
                                <span class="executive-risk-badge @riskClass">@student.RiskLevel</span>
                            </div>
                            <div class="executive-student-risk-line">@student.RiskReason</div>
                            <div class="executive-summary-foot mt-2">
                                <span class="executive-pill"><i class="bi bi-speedometer2"></i> Risk Score @student.RiskScore.ToString("0.00")</span>
                                <span class="executive-pill"><i class="bi bi-check2-circle"></i> มาเรียน @student.PresentRate.ToString("0.0")%</span>
                                <span class="executive-pill"><i class="bi bi-x-circle"></i> ขาด @student.AbsentPeriods</span>
                                <span class="executive-pill"><i class="bi bi-person-x"></i> หนีเรียน @student.TruancyPeriods</span>
                                <span class="executive-pill"><i class="bi bi-alarm"></i> มาสาย @student.LatePeriods</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
