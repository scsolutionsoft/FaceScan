@model ExecutiveDashboardViewModel
@{
    ViewData["Title"] = "แดชบอร์ดผู้บริหาร";
}

@functions {
    string ToneClass(string tone) => tone switch
    {
        "good" => "executive-insight-good",
        "warn" => "executive-insight-warn",
        "alert" => "executive-insight-alert",
        _ => "executive-insight-neutral"
    };

    string DescribeActiveFilters()
    {
        var grade = Model.GradeLevels.FirstOrDefault(x => x.Value == Model.Filter.GradeLevelId)?.Text;
        var classroom = Model.Classrooms.FirstOrDefault(x => x.Value == Model.Filter.ClassroomId)?.Text;
        var keyword = string.IsNullOrWhiteSpace(Model.Filter.StudentKeyword) ? null : Model.Filter.StudentKeyword.Trim();

        var pieces = new List<string>();
        if (!string.IsNullOrWhiteSpace(grade))
        {
            pieces.Add($"ระดับชั้น: {grade}");
        }

        if (!string.IsNullOrWhiteSpace(classroom))
        {
            pieces.Add($"ห้องเรียน: {classroom}");
        }

        if (!string.IsNullOrWhiteSpace(keyword))
        {
            pieces.Add($"คำค้น: {keyword}");
        }

        return pieces.Count == 0 ? "ไม่มีตัวกรองเพิ่มเติม" : string.Join(" | ", pieces);
    }

    string BuildSparklinePoints(IReadOnlyList<ExecutiveRiskTrendPointViewModel> points, int width = 320, int height = 80)
    {
        if (points.Count == 0)
        {
            return "";
        }

        var max = points.Max(x => x.AttendanceRate);
        var min = points.Min(x => x.AttendanceRate);
        var span = Math.Max(max - min, 1m);
        var step = points.Count == 1 ? 0m : (decimal)width / (points.Count - 1);

        var coords = new List<string>(points.Count);
        for (var i = 0; i < points.Count; i++)
        {
            var x = Math.Round(step * i, 1);
            var normalized = (points[i].AttendanceRate - min) / span;
            var y = Math.Round((decimal)height - (normalized * height), 1);
            coords.Add($"{x.ToString(System.Globalization.CultureInfo.InvariantCulture)},{y.ToString(System.Globalization.CultureInfo.InvariantCulture)}");
        }

        return string.Join(" ", coords);
    }
}

<style>
    .executive-shell { display: grid; gap: 1.5rem; }
    .executive-hero {
        position: relative; overflow: hidden; border: 0; border-radius: 28px;
        background: radial-gradient(circle at top right, rgba(255, 218, 185, 0.65), transparent 28%), linear-gradient(135deg, #0b3c49 0%, #145374 44%, #1d6f8c 100%);
        color: #f7fbfc; box-shadow: 0 28px 60px rgba(11, 60, 73, 0.18);
    }
    .executive-hero::after {
        content: ""; position: absolute; inset: auto -5rem -6rem auto; width: 18rem; height: 18rem;
        border-radius: 50%; background: rgba(255, 255, 255, 0.08); filter: blur(2px);
    }
    .executive-hero-body { position: relative; z-index: 1; display: grid; grid-template-columns: minmax(0, 1.8fr) minmax(280px, 1fr); gap: 1.25rem; padding: 2rem; }
    .executive-kicker {
        display: inline-flex; align-items: center; gap: .45rem; padding: .35rem .75rem; border-radius: 999px;
        background: rgba(255, 255, 255, 0.12); font-size: .78rem; letter-spacing: .08em; text-transform: uppercase;
    }
    .executive-title { margin-top: 1rem; margin-bottom: .75rem; font-size: clamp(1.8rem, 3vw, 2.8rem); font-weight: 700; line-height: 1.05; }
    .executive-subtitle { max-width: 46rem; margin: 0; color: rgba(247, 251, 252, 0.86); font-size: 1rem; }
    .executive-range-chip-grid { display: grid; gap: .85rem; align-content: start; }
    .executive-range-chip { padding: 1rem 1.1rem; border-radius: 20px; background: rgba(7, 27, 32, 0.22); border: 1px solid rgba(255, 255, 255, 0.12); }
    .executive-range-chip-label { display: block; color: rgba(247, 251, 252, 0.7); font-size: .8rem; text-transform: uppercase; letter-spacing: .06em; margin-bottom: .35rem; }
    .executive-range-chip strong { display: block; font-size: 1.15rem; }
    .executive-panel { border: 0; border-radius: 24px; box-shadow: 0 18px 45px rgba(23, 35, 52, 0.08); }
    .executive-filter-card { padding: 1.4rem; background: linear-gradient(180deg, #ffffff 0%, #f8fbfd 100%); }
    .executive-filter-head { display: flex; justify-content: space-between; gap: 1rem; margin-bottom: 1rem; align-items: start; }
    .executive-section-kicker { color: #2a6f7b; text-transform: uppercase; letter-spacing: .08em; font-size: .75rem; font-weight: 700; margin-bottom: .35rem; }
    .executive-section-title { margin: 0; font-size: 1.25rem; font-weight: 700; color: #14323d; }
    .executive-section-note { color: #5f7382; max-width: 42rem; font-size: .95rem; }

    .executive-active-filters {
        display: flex; flex-wrap: wrap; gap: .5rem; margin-top: 1rem;
        padding: .75rem; border-radius: 16px; background: #eef5f8; border: 1px solid rgba(25, 83, 101, 0.12);
    }
    .executive-filter-chip {
        display: inline-flex; align-items: center; gap: .4rem; padding: .38rem .65rem;
        border-radius: 999px; background: #fff; color: #1f4d5d; font-size: .82rem;
        border: 1px solid rgba(25, 83, 101, 0.15);
    }

    .executive-kpi-grid, .executive-insight-grid, .executive-summary-grid { display: grid; gap: 1rem; }
    .executive-kpi-grid { grid-template-columns: repeat(auto-fit, minmax(155px, 1fr)); }
    .executive-insight-grid { grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); }
    .executive-summary-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
    .executive-live-grid { display: grid; gap: 1rem; grid-template-columns: minmax(230px, 300px) minmax(0, 1fr); }
    .executive-live-pill {
        display: inline-flex;
        align-items: center;
        gap: .4rem;
        padding: .25rem .6rem;
        border-radius: 999px;
        font-size: .78rem;
        background: #edf3f7;
        color: #2f4f5d;
    }
    .executive-live-pill-dot { width: .52rem; height: .52rem; border-radius: 50%; background: #c14d4d; }
    .executive-live-pill.is-online { background: #dff3e8; color: #16563a; }
    .executive-live-pill.is-online .executive-live-pill-dot { background: #1f9d63; }
    .executive-live-counter-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: .65rem; margin-top: .7rem; }
    .executive-live-filter-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
