    }
    .executive-live-alert.is-show { display: block; }
    .executive-live-trend {
        margin-top: .7rem;
        border-radius: 12px;
        border: 1px solid rgba(22, 77, 94, 0.15);
        background: #f7fbfd;
        padding: .55rem .65rem;
    }
    .executive-live-trend-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: .5rem;
        font-size: .79rem;
        color: #476674;
        margin-bottom: .45rem;
    }
    .executive-live-trend-bars {
        display: grid;
        grid-template-columns: repeat(20, minmax(0, 1fr));
