    <section class="card executive-panel executive-summary-panel">
        <div class="card-header">
            <div class="executive-section-kicker">Risk Trend</div>
            <h2 class="executive-section-title">แนวโน้มความเสี่ยงรายวัน</h2>
            <div class="executive-section-note">ดูการเปลี่ยนแปลงอัตรามาเรียนรายวันในช่วงที่เลือกเพื่อประเมินว่าความเสี่ยงดีขึ้นหรือแย่ลง</div>
        </div>
        <div class="card-body">
            @if (Model.RiskTrendPoints.Count == 0)
            {
                <div class="executive-empty">ยังไม่มีข้อมูลแนวโน้มความเสี่ยง</div>
            }
            else
            {
                var recent = Model.RiskTrendPoints.TakeLast(7).ToList();
                var sparklinePoints = BuildSparklinePoints(recent);
                var latestRate = recent.LastOrDefault()?.AttendanceRate ?? 0m;
                var earliestRate = recent.FirstOrDefault()?.AttendanceRate ?? latestRate;
                var delta = Math.Round(latestRate - earliestRate, 1);

                <div class="executive-sparkline-wrap">
                    <div class="executive-sparkline-head">
                        <span>สรุป 7 วันล่าสุด</span>
                        <span>@(delta >= 0 ? "+" : "")@delta.ToString("0.0")%</span>
                    </div>
                    <svg width="100%" height="86" viewBox="0 0 320 86" preserveAspectRatio="none" role="img" aria-label="กราฟแนวโน้มความเสี่ยง 7 วัน">
                        <polyline fill="none" stroke="#1f7894" stroke-width="2.4" points="@sparklinePoints"></polyline>
                    </svg>
                </div>

                @foreach (var point in Model.RiskTrendPoints)
                {
                    var riskClass = point.AttendanceRate < 70m ? "risk-high" : point.AttendanceRate < 85m ? "risk-watch" : "risk-normal";

                    <div class="executive-risk-trend-row">
                        <div>@point.Date.ToThaiDate("dd/MM/yyyy")</div>
                        <div class="executive-risk-trend-bar"><span style="width:@point.AttendanceRate.ToString("0.0", System.Globalization.CultureInfo.InvariantCulture)%"></span></div>
                        <div class="d-flex align-items-center gap-2">
                            <span>@point.AttendanceRate.ToString("0.0")%</span>
                            <span class="executive-risk-badge @riskClass">@point.RiskLevel</span>
                        </div>
                    </div>
                }
            }
        </div>
    </section>

    <section class="card executive-panel executive-summary-panel">
        <div class="card-header">
            <div class="executive-section-kicker">By Grade</div>
            <h2 class="executive-section-title">สรุปรายระดับชั้น</h2>
            <div class="executive-section-note">คลิกการ์ดเพื่อเจาะดูรายบุคคลของระดับชั้นนั้นทันที</div>
        </div>
        <div class="card-body">
            @if (Model.GradeSummaries.Count == 0)
            {
                <div class="executive-empty">ไม่พบข้อมูลระดับชั้นตามเงื่อนไขที่เลือก</div>
            }
            else
            {
                <div class="executive-summary-grid">
                    @foreach (var summary in Model.GradeSummaries)
                    {
                        <a class="executive-summary-card"
                           asp-action="Index"
                           asp-route-DateFrom="@Model.Filter.DateFrom.ToString("yyyy-MM-dd")"
                           asp-route-DateTo="@Model.Filter.DateTo.ToString("yyyy-MM-dd")"
                           asp-route-GradeLevelId="@summary.GradeLevelId"
                           asp-route-ClassroomId=""
                           asp-route-StudentKeyword="@Model.Filter.StudentKeyword">
                            <div class="executive-summary-card-head">
                                <div>
                                    <h3 class="executive-summary-title">@summary.Name</h3>
                                    <span class="executive-summary-subtitle">@summary.SecondaryLabel</span>
                                    @{
                                        var gradeRiskClass = summary.AttendanceRate < 70m ? "risk-high" : summary.AttendanceRate < 85m ? "risk-watch" : "risk-normal";
                                        var gradeRiskText = summary.AttendanceRate < 70m ? "เสี่ยงสูง" : summary.AttendanceRate < 85m ? "เฝ้าระวัง" : "ปกติ";
                                    }
                                    <span class="executive-risk-badge @gradeRiskClass"><i class="bi bi-shield-exclamation"></i> @gradeRiskText</span>
                                </div>
                                <div class="executive-rate-badge">@summary.AttendanceRate.ToString("0.0")%</div>
                            </div>
                            <div class="executive-summary-metrics">
                                <div class="executive-summary-metric"><strong>@summary.StudentCount</strong><span>นักเรียน</span></div>
                                <div class="executive-summary-metric"><strong>@summary.ActiveAttendanceCount</strong><span>มาเรียน</span></div>
                                <div class="executive-summary-metric"><strong>@summary.InactiveAttendanceCount</strong><span>ไม่พบสแกน</span></div>
                            </div>
                            <div class="executive-summary-meta">ลงทะเบียนใบหน้าแล้ว @summary.RegisteredFaceCount คน (@summary.FaceRegistrationRate.ToString("0.0")%)</div>
                            <div class="executive-summary-foot">
                                <span class="executive-pill"><i class="bi bi-alarm"></i> มาสาย @summary.LateCount</span>
                                <span class="executive-pill"><i class="bi bi-door-open"></i> ลา @summary.LeaveCount</span>
                                <span class="executive-pill"><i class="bi bi-exclamation-octagon"></i> หนีเรียน @summary.TruancyCount</span>
                                <span class="executive-pill"><i class="bi bi-three-dots"></i> อื่นๆ @summary.OtherCount</span>
                            </div>
                            <div class="executive-summary-times mt-3">เริ่มเข้าเรียนครั้งแรก: @(summary.FirstActivityTime?.ToThaiDate("dd/MM/yyyy HH:mm") ?? "-") | สแกนกลับล่าสุด: @(summary.LastActivityTime?.ToThaiDate("dd/MM/yyyy HH:mm") ?? "-")</div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>

    <section class="card executive-panel executive-summary-panel">
        <div class="card-header">
            <div class="executive-section-kicker">By Classroom</div>
            <h2 class="executive-section-title">สรุปรายห้องเรียน</h2>
            <div class="executive-section-note">คลิกการ์ดเพื่อกรองห้องนั้นในตารางรายบุคคล</div>
        </div>
        <div class="card-body">
            @if (Model.ClassroomSummaries.Count == 0)
            {
                <div class="executive-empty">ไม่พบข้อมูลห้องเรียนตามเงื่อนไขที่เลือก</div>
            }
            else
            {
                <div class="executive-summary-grid">
                    @foreach (var summary in Model.ClassroomSummaries)
                    {
                        <a class="executive-summary-card"
                           asp-action="Index"
                           asp-route-DateFrom="@Model.Filter.DateFrom.ToString("yyyy-MM-dd")"
                           asp-route-DateTo="@Model.Filter.DateTo.ToString("yyyy-MM-dd")"
                           asp-route-GradeLevelId="@summary.GradeLevelId"
                           asp-route-ClassroomId="@summary.ClassroomId"
                           asp-route-StudentKeyword="@Model.Filter.StudentKeyword">
                            <div class="executive-summary-card-head">
                                <div>
                                    <h3 class="executive-summary-title">@summary.Name</h3>
                                    <span class="executive-summary-subtitle">@summary.SecondaryLabel</span>
                                    @{
                                        var classRiskClass = summary.AttendanceRate < 70m ? "risk-high" : summary.AttendanceRate < 85m ? "risk-watch" : "risk-normal";
                                        var classRiskText = summary.AttendanceRate < 70m ? "เสี่ยงสูง" : summary.AttendanceRate < 85m ? "เฝ้าระวัง" : "ปกติ";
                                    }
                                    <span class="executive-risk-badge @classRiskClass"><i class="bi bi-shield-exclamation"></i> @classRiskText</span>
                                </div>
                                <div class="executive-rate-badge">@summary.AttendanceRate.ToString("0.0")%</div>
                            </div>
                            <div class="executive-summary-metrics">
                                <div class="executive-summary-metric"><strong>@summary.StudentCount</strong><span>นักเรียน</span></div>
                                <div class="executive-summary-metric"><strong>@summary.ActiveAttendanceCount</strong><span>มาเรียน</span></div>
                                <div class="executive-summary-metric"><strong>@summary.InactiveAttendanceCount</strong><span>ไม่พบสแกน</span></div>
                            </div>
                            <div class="executive-summary-meta">ลงทะเบียนใบหน้าแล้ว @summary.RegisteredFaceCount คน (@summary.FaceRegistrationRate.ToString("0.0")%)</div>
                            <div class="executive-summary-foot">
                                <span class="executive-pill"><i class="bi bi-alarm"></i> มาสาย @summary.LateCount</span>
                                <span class="executive-pill"><i class="bi bi-door-open"></i> ลา @summary.LeaveCount</span>
                                <span class="executive-pill"><i class="bi bi-exclamation-octagon"></i> หนีเรียน @summary.TruancyCount</span>
                                <span class="executive-pill"><i class="bi bi-three-dots"></i> อื่นๆ @summary.OtherCount</span>
                            </div>
                        </a>
                    }
                </div>
            }
        </div>
    </section>

    <section class="card executive-panel executive-chart-panel">
        <div class="card-header">
            <div class="executive-section-kicker">Trend</div>
            <h2 class="executive-section-title">แนวโน้มรายวัน</h2>
        </div>
        <div class="card-body">
            <canvas id="executiveTrendChart" height="90"></canvas>
        </div>
    </section>

    <section class="card executive-panel executive-table-panel">
        <div class="card-header">
            <div class="executive-section-kicker">Student Detail</div>
            <h2 class="executive-section-title">รายงานรายละเอียดรายบุคคล</h2>
        </div>
        <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
                <thead>
                    <tr>
                        <th>นักเรียน</th>
                        <th>รหัส</th>
                        <th>ชั้น/ห้อง</th>
                        <th>เข้าเรียนครั้งแรก</th>
                        <th>สแกนกลับล่าสุด</th>
                        <th class="text-end">มาเรียน</th>
                        <th class="text-end">ลา</th>
                        <th class="text-end">ขาด</th>
                        <th class="text-end">หนีเรียน</th>
                        <th class="text-end">มาสาย</th>
                        <th class="text-end">อื่นๆ</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Rows.Count == 0)
                    {
                        <tr><td colspan="11" class="text-center text-muted py-4">ไม่พบข้อมูลตามเงื่อนไขที่เลือก</td></tr>
                    }
                    else
                    {
                        @foreach (var row in Model.Rows)
                        {
                            <tr>
                                <td>
                                    <div class="executive-student-meta">
                                        @if (!string.IsNullOrWhiteSpace(row.PhotoPath))
                                        {
                                            <img src="~/@row.PhotoPath" alt="@row.StudentName" class="executive-avatar" />
                                        }
                                        else
                                        {
                                            <div class="executive-avatar d-flex align-items-center justify-content-center"><i class="bi bi-person"></i></div>
                                        }
                                        <span>@row.StudentName</span>
                                    </div>
                                </td>
                                <td>@row.StudentCode</td>
                                <td>@row.GradeLevel / @row.Classroom</td>
                                <td>@row.FirstCheckInTime.ToThaiDate("yyyy-MM-dd HH:mm")</td>
                                <td>@row.LastCheckOutTime.ToThaiDate("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end">@row.PresentPeriods</td>
                                <td class="text-end">@row.LeavePeriods</td>
                                <td class="text-end">@row.AbsentPeriods</td>
                                <td class="text-end">@row.TruancyPeriods</td>
                                <td class="text-end">@row.LatePeriods</td>
                                <td class="text-end">@row.OtherPeriods</td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<div id="executiveLiveToastWrap" class="executive-live-toast-wrap" aria-live="assertive" aria-atomic="false"></div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js" integrity="sha512-M6gdlKs2grQiiK2vNhbbX6YsJhBKt3vnDnN/SUXOcDSBx/OVCkXbkqVKgf/mBlC9ZwTe74MkRUYw35vj0IadBQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script>
(() => {
    const source = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.DailySummaries.Select(x => new {
        date = x.Date.ToThaiDate("yyyy-MM-dd"),
        present = x.PresentCount,
        leave = x.LeaveCount,
        absent = x.AbsentCount,
        truancy = x.TruancyCount,
        late = x.LateCount,
        other = x.OtherCount
    })));

    const labels = source.map(x => x.date);
    const chart = document.getElementById('executiveTrendChart');
    if (!chart) return;

    new Chart(chart, {
        type: 'bar',
        data: {
            labels,
            datasets: [
                { label: 'มาเรียน', data: source.map(x => x.present), backgroundColor: '#2b9348' },
                { label: 'ลา', data: source.map(x => x.leave), backgroundColor: '#f4c430' },
                { label: 'ขาด', data: source.map(x => x.absent), backgroundColor: '#f8961e' },
                { label: 'หนีเรียน', data: source.map(x => x.truancy), backgroundColor: '#d62828' },
                { label: 'มาสาย', data: source.map(x => x.late), backgroundColor: '#7b2cbf' },
                { label: 'อื่นๆ', data: source.map(x => x.other), backgroundColor: '#4ea8de' }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                x: { stacked: true },
                y: { stacked: true, beginAtZero: true }
            }
        }
    });
})();

(() => {
    const statusWrap = document.getElementById('executiveLiveStatus');
    const feed = document.getElementById('executiveLiveFeed');
    const countAll = document.getElementById('executiveLiveCountAll');
    const countSuccess = document.getElementById('executiveLiveCountSuccess');
    const countFailed = document.getElementById('executiveLiveCountFailed');
    const scopeFilter = document.getElementById('executiveLiveScopeFilter');
    const stationFilter = document.getElementById('executiveLiveStationFilter');
    const liveAlert = document.getElementById('executiveLiveAlert');
    const liveTrendSummary = document.getElementById('executiveLiveTrendSummary');
    const liveTrendBars = document.getElementById('executiveLiveTrendBars');
    const alertThresholdSelect = document.getElementById('executiveLiveAlertThreshold');
    const alertSampleSizeSelect = document.getElementById('executiveLiveAlertSampleSize');
    const alertSoundToggle = document.getElementById('executiveLiveAlertSound');
    const toastWrap = document.getElementById('executiveLiveToastWrap');
    const kpiTotalStudents = document.getElementById('executiveKpiTotalStudents');
    const kpiRegistered = document.getElementById('executiveKpiRegistered');
    const kpiPresent = document.getElementById('executiveKpiPresent');
    const kpiAbsent = document.getElementById('executiveKpiAbsent');
    const kpiLate = document.getElementById('executiveKpiLate');
    const kpiTruancyOther = document.getElementById('executiveKpiTruancyOther');
    if (!statusWrap || !feed || !countAll || !countSuccess || !countFailed || !scopeFilter || !stationFilter || !liveAlert || !liveTrendSummary || !liveTrendBars || !alertThresholdSelect || !alertSampleSizeSelect || !alertSoundToggle || !toastWrap || !window.signalR) return;

    const state = {
        events: [],
        stations: new Set(),
        refreshTimerId: null,
        alertActive: false,
        lastToastAt: 0,
        config: {
            threshold: 40,
            sampleSize: 5,
            soundOn: false
        }
    };
    const liveSummaryUrl = '@Url.Action("LiveSummary", "Reports", new { area = "Executive" })';
    const liveFilter = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(new {
        dateFrom = Model.Filter.DateFrom.ToString("yyyy-MM-dd"),
        dateTo = Model.Filter.DateTo.ToString("yyyy-MM-dd"),
        gradeLevelId = Model.Filter.GradeLevelId,
        classroomId = Model.Filter.ClassroomId,
        studentKeyword = Model.Filter.StudentKeyword
    }));

    const updateStatus = (isOnline, text) => {
        statusWrap.classList.toggle('is-online', isOnline);
        statusWrap.innerHTML = `<span class="executive-live-pill-dot"></span><span>${text}</span>`;
    };

    const loadConfig = () => {
        try
        {
            const saved = localStorage.getItem('executive-live-alert-config');
            if (!saved)
            {
                return;
            }

            const data = JSON.parse(saved);
            state.config.threshold = Number(data.threshold) || 40;
            state.config.sampleSize = Number(data.sampleSize) || 5;
            state.config.soundOn = Boolean(data.soundOn);
        }
        catch (error)
        {
            console.error(error);
        }
    };

    const saveConfig = () => {
        localStorage.setItem('executive-live-alert-config', JSON.stringify(state.config));
    };

    const syncConfigInputs = () => {
        alertThresholdSelect.value = String(state.config.threshold);
        alertSampleSizeSelect.value = String(state.config.sampleSize);
        alertSoundToggle.checked = state.config.soundOn;
    };

    const playAlertBeep = () => {
        if (!state.config.soundOn)
        {
            return;
        }

        try
        {
            const AudioContextCtor = window.AudioContext || window.webkitAudioContext;
            if (!AudioContextCtor)
            {
                return;
            }

            const audioContext = new AudioContextCtor();
            const oscillator = audioContext.createOscillator();
            const gainNode = audioContext.createGain();

            oscillator.type = 'triangle';
            oscillator.frequency.setValueAtTime(760, audioContext.currentTime);
            gainNode.gain.setValueAtTime(0.001, audioContext.currentTime);
            gainNode.gain.exponentialRampToValueAtTime(0.18, audioContext.currentTime + 0.02);
            gainNode.gain.exponentialRampToValueAtTime(0.001, audioContext.currentTime + 0.28);

            oscillator.connect(gainNode);
            gainNode.connect(audioContext.destination);
            oscillator.start();
            oscillator.stop(audioContext.currentTime + 0.3);

            oscillator.onended = () => {
                audioContext.close();
            };
        }
        catch (error)
        {
            console.error(error);
        }
    };

    const showToast = (title, message) => {
        const now = Date.now();
        if (now - state.lastToastAt < 15000)
        {
            return;
        }
        state.lastToastAt = now;

        const toast = document.createElement('article');
        toast.className = 'executive-live-toast';
        toast.innerHTML = `<strong>${title}</strong><span>${message}</span>`;
        toastWrap.prepend(toast);

        while (toastWrap.children.length > 3)
        {
            toastWrap.removeChild(toastWrap.lastElementChild);
        }

        window.setTimeout(() => {
            toast.remove();
        }, 6000);
    };

    const formatTime = (scanTime) => {
        if (!scanTime) return '-';
        const dt = new Date(scanTime);
        if (Number.isNaN(dt.getTime())) return scanTime;
        return dt.toLocaleString('th-TH', {
            year: 'numeric',
            month: '2-digit',
            day: '2-digit',
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit'
        });
    };

    const renderCounters = (filteredEvents) => {
        const success = filteredEvents.filter((x) => x.eventType === 'success').length;
        const failed = filteredEvents.length - success;
        countAll.textContent = String(filteredEvents.length);
        countSuccess.textContent = String(success);
        countFailed.textContent = String(failed);
    };

    const renderLiveHealth = (filteredEvents) => {
        const trendItems = filteredEvents.slice(0, 20).reverse();
        const total = trendItems.length;
        const failed = trendItems.filter((x) => x.eventType !== 'success').length;
        const success = total - failed;
        const successRate = total === 0 ? 0 : Math.round((success / total) * 100);

        if (total === 0)
        {
            liveTrendSummary.textContent = 'ยังไม่มีข้อมูล';
            liveTrendBars.innerHTML = '';
            liveAlert.classList.remove('is-show');
            liveAlert.textContent = '';
            state.alertActive = false;
            return;
        }

        liveTrendSummary.textContent = `สำเร็จ ${successRate}% (${success}/${total})`;
        liveTrendBars.innerHTML = trendItems
            .map((item) => `<span class="${item.eventType === 'success' ? 'is-success' : 'is-failed'}" title="${item.eventType === 'success' ? 'สำเร็จ' : 'ไม่สำเร็จ'}"></span>`)
            .join('');

        const recentForAlert = filteredEvents.slice(0, state.config.sampleSize);
        const recentCount = recentForAlert.length;
        const recentFailed = recentForAlert.filter((x) => x.eventType !== 'success').length;
        const recentFailedRate = recentCount === 0 ? 0 : Math.round((recentFailed / recentCount) * 100);
        const shouldAlert = recentCount >= state.config.sampleSize && recentFailedRate >= state.config.threshold;

        if (shouldAlert)
        {
            liveAlert.textContent = `แจ้งเตือน: ${state.config.sampleSize} เหตุการณ์ล่าสุดมีสแกนไม่สำเร็จ/ซ้ำ ${recentFailedRate}% (เกณฑ์ ${state.config.threshold}%)`;
            liveAlert.classList.add('is-show');

            if (!state.alertActive)
            {
                showToast('Live Risk Alert', `สแกนไม่สำเร็จ/ซ้ำ ${recentFailedRate}% จาก ${state.config.sampleSize} เหตุการณ์ล่าสุด`);
                playAlertBeep();
            }
            state.alertActive = true;
        }
        else
        {
            liveAlert.classList.remove('is-show');
            liveAlert.textContent = '';
            state.alertActive = false;
        }
    };

    const buildLiveItemHtml = (eventData) => {
        const isSuccess = eventData.eventType === 'success';
        const riskClass = isSuccess ? 'risk-normal' : 'risk-high';
        const typeText = eventData.eventType === 'duplicate' ? 'ข้อมูลซ้ำ' : isSuccess ? 'สำเร็จ' : 'ไม่สำเร็จ';
        const name = eventData.name || '-';
        const code = eventData.code || '-';
        const station = eventData.stationCode || '-';
        const scope = eventData.scope === 'teacher' ? 'ครู' : 'นักเรียน';

        return `
            <article class="executive-live-item">
                <div class="executive-live-item-head">
                    <span class="executive-live-item-name">${name} (${code})</span>
                    <span class="executive-risk-badge ${riskClass}">${typeText}</span>
                </div>
                <div class="executive-live-item-meta">${scope} | ${eventData.scanType || '-'} | จุดสแกน ${station}</div>
                <div class="executive-live-item-meta">${eventData.message || '-'} | ${formatTime(eventData.scanTime)}</div>
            </article>`;
    };

    const renderLiveFeed = () => {
        const scope = scopeFilter.value;
        const station = stationFilter.value;
        const filteredEvents = state.events.filter((item) => {
            const scopeMatch = scope === 'all' || item.scope === scope;
            const stationMatch = station === 'all' || (item.stationCode || '-') === station;
            return scopeMatch && stationMatch;
        });

        renderCounters(filteredEvents);
        renderLiveHealth(filteredEvents);

        if (filteredEvents.length === 0)
        {
            feed.innerHTML = '<div class="executive-live-empty">ไม่พบเหตุการณ์ตามตัวกรองที่เลือก</div>';
            return;
        }

        feed.innerHTML = filteredEvents
            .slice(0, 20)
            .map((eventData) => buildLiveItemHtml(eventData))
            .join('');
    };

    const refreshStationFilter = () => {
        const selected = stationFilter.value;
        const values = ['all', ...Array.from(state.stations).sort((a, b) => a.localeCompare(b, 'th'))];
        stationFilter.innerHTML = values
            .map((value) => `<option value="${value}">${value === 'all' ? 'ทุกจุดสแกน' : value}</option>`)
            .join('');

        if (values.includes(selected)) {
            stationFilter.value = selected;
        }
    };

    const pushLiveEvent = (eventData) => {
        const normalized = {
            ...eventData,
            scope: eventData.scope || 'student',
            stationCode: eventData.stationCode || '-'
        };

        state.events.unshift(normalized);
        if (state.events.length > 100)
        {
            state.events.length = 100;
        }

        state.stations.add(normalized.stationCode);
        refreshStationFilter();
        renderLiveFeed();

        scheduleKpiRefresh();
    };

    const refreshKpis = async () => {
        const query = new URLSearchParams({
            DateFrom: liveFilter.dateFrom || '',
            DateTo: liveFilter.dateTo || '',
            GradeLevelId: liveFilter.gradeLevelId?.toString() || '',
            ClassroomId: liveFilter.classroomId?.toString() || '',
            StudentKeyword: liveFilter.studentKeyword || ''
        });

        try
        {
            const response = await fetch(`${liveSummaryUrl}?${query.toString()}`, { method: 'GET' });
            if (!response.ok)
            {
                return;
            }

            const data = await response.json();
            if (kpiTotalStudents) kpiTotalStudents.textContent = String(data.totalStudents ?? 0);
            if (kpiRegistered) kpiRegistered.textContent = String(data.registeredFaceCount ?? 0);
            if (kpiPresent) kpiPresent.textContent = String(data.presentCount ?? 0);
            if (kpiAbsent) kpiAbsent.textContent = String(data.absentCount ?? 0);
            if (kpiLate) kpiLate.textContent = String(data.lateCount ?? 0);
            if (kpiTruancyOther) kpiTruancyOther.textContent = String(data.truancyAndOtherCount ?? 0);
        }
        catch (error)
        {
            console.error(error);
        }
    };

    const scheduleKpiRefresh = () => {
        if (state.refreshTimerId) {
            window.clearTimeout(state.refreshTimerId);
        }

        state.refreshTimerId = window.setTimeout(() => {
            state.refreshTimerId = null;
            refreshKpis();
        }, 1200);
    };

    scopeFilter.addEventListener('change', renderLiveFeed);
    stationFilter.addEventListener('change', renderLiveFeed);
    alertThresholdSelect.addEventListener('change', () => {
        state.config.threshold = Number(alertThresholdSelect.value) || 40;
        saveConfig();
        renderLiveFeed();
    });
    alertSampleSizeSelect.addEventListener('change', () => {
        state.config.sampleSize = Number(alertSampleSizeSelect.value) || 5;
        saveConfig();
        renderLiveFeed();
    });
    alertSoundToggle.addEventListener('change', () => {
        state.config.soundOn = alertSoundToggle.checked;
        saveConfig();
    });

    const connection = new signalR.HubConnectionBuilder()
        .withUrl('/hubs/scan-live')
        .withAutomaticReconnect()
        .build();

    connection.on('scanEvent', (eventData) => {
        if (!eventData) return;
        pushLiveEvent(eventData);
    });

    connection.onreconnecting(() => updateStatus(false, 'กำลังเชื่อมต่อใหม่...'));
    connection.onreconnected(async () => {
        updateStatus(true, 'เชื่อมต่อแล้ว (กำลังรับข้อมูลสด)');
        try {
            await connection.invoke('JoinExecutiveDashboardAsync');
        }
        catch (error)
        {
            updateStatus(false, 'เชื่อมต่อแต่ยังเข้ากลุ่มไม่ได้');
            console.error(error);
        }
    });
    connection.onclose(() => updateStatus(false, 'ตัดการเชื่อมต่อ Live Feed'));

    connection.start()
        .then(() => connection.invoke('JoinExecutiveDashboardAsync'))
        .then(() => updateStatus(true, 'เชื่อมต่อแล้ว (กำลังรับข้อมูลสด)'))
        .catch((error) => {
            updateStatus(false, 'เชื่อมต่อ Live Feed ไม่สำเร็จ');
            console.error(error);
        });

    loadConfig();
    syncConfigInputs();
    renderLiveFeed();
})();
</script>
}
