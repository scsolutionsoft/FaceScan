    .executive-live-item-head { display: flex; justify-content: space-between; gap: .75rem; font-size: .82rem; color: #3c5f6f; }
    .executive-live-item-name { font-weight: 700; color: #173f4d; }
    .executive-live-item-meta { margin-top: .25rem; font-size: .8rem; color: #627d8b; }
    .executive-live-empty { padding: 1rem; border-radius: 14px; background: #f4f9fc; color: #607b89; font-size: .88rem; }
    .executive-live-alert {
        margin-top: .7rem;
        border-radius: 12px;
        padding: .55rem .7rem;
