    async function refreshRecentScans() {
        try {
            const query = new URLSearchParams({ stationCode: stationCode || '', stationToken: stationToken || '', isPublicMode: isPublicMode ? 'true' : 'false', take: '20' });
            const response = await fetch(`/Scan/Recent?${query.toString()}`, { method: 'GET' });
            const data = await parseResponseJson(response);
            if (response.ok && data?.success) renderRecentScans(data.items);
        } catch (error) {
            console.error(error);
        }
    }

    function updateLocationStatusText() {
        if (!latestLocation) {
            locationStatus.textContent = 'ยังไม่ได้รับตำแหน่งจีพีเอส (ต้องอนุญาต GPS ก่อนเปิดกล้อง)';
            return;
        }
        const ageSec = Math.max(0, Math.floor((Date.now() - locationUpdatedAt) / 1000));
        locationStatus.textContent = `Lat: ${latestLocation.latitude.toFixed(6)}, Lng: ${latestLocation.longitude.toFixed(6)}, Accuracy: ${Math.round(latestLocation.accuracy)} m, อัปเดต ${ageSec}s ที่แล้ว`;
    }

    function updateLocation(coords) { latestLocation = coords; locationUpdatedAt = Date.now(); updateLocationStatusText(); }

    function focusCameraPreview() {
        if (!cameraPreviewShell) return;
        cameraPreviewShell.scrollIntoView({ behavior: 'smooth', block: 'center' });
        window.setTimeout(() => {
            try {
                cameraPreviewShell.focus({ preventScroll: true });
            } catch {
                cameraPreviewShell.focus();
            }
        }, 120);
    }

    function startLocationWatch() {
        if (!navigator.geolocation || locationWatchId !== null) return;
        locationWatchId = navigator.geolocation.watchPosition(
            (position) => updateLocation(position.coords),
            () => updateLocationStatusText(),
            { enableHighAccuracy: true, timeout: 10000, maximumAge: 15000 });
    }

    function stopLocationWatch() {
        if (!navigator.geolocation || locationWatchId === null) return;
        navigator.geolocation.clearWatch(locationWatchId);
        locationWatchId = null;
    }

    function readCurrentLocation(options = {}) {
        return new Promise((resolve) => {
            if (!navigator.geolocation) {
                resolve(null);
                return;
            }
            navigator.geolocation.getCurrentPosition(
                (position) => { updateLocation(position.coords); resolve(latestLocation); },
                () => resolve(null),
                {
                    enableHighAccuracy: true,
                    timeout: options.timeout ?? 9000,
                    maximumAge: options.maximumAge ?? 0
                });
        });
    }

    async function getCurrentLocation() {
        if (latestLocation) return latestLocation;
        return await readCurrentLocation({ timeout: 7000, maximumAge: 15000 });
    }

    async function ensureGpsReadyBeforeScan() {
        if (!navigator.geolocation) {
            const message = 'อุปกรณ์ไม่รองรับ GPS จึงไม่สามารถเข้าสู่โหมดสแกนใบหน้าได้';
            setResult(message, 'warning');
            showPopup(message, 'warning');
            setMatchingStatus('warn', 'ไม่พร้อมเริ่มสแกน', message);
            updateLocationStatusText();
            return false;
        }

        if (!gpsConsentConfirmed) {
            const accepted = window.confirm('ระบบต้องยืนยันการเก็บตำแหน่ง GPS ก่อนเปิดกล้องเพื่อเข้าสู่โหมดสแกนใบหน้า\nคุณต้องการอนุญาตหรือไม่?');
            if (!accepted) {
                const message = 'ไม่ได้รับการยืนยันเก็บตำแหน่ง GPS จึงไม่สามารถเข้าสู่โหมดสแกนใบหน้าได้';
                setResult(message, 'warning');
                showPopup(message, 'warning');
                setMatchingStatus('warn', 'ยืนยัน GPS ไม่สำเร็จ', message);
                updateLocationStatusText();
                return false;
            }
            gpsConsentConfirmed = true;
        }

        locationStatus.textContent = 'กำลังตรวจสอบตำแหน่ง GPS...';
        const location = latestLocation ?? await readCurrentLocation({ timeout: 10000, maximumAge: 0 });
        if (!location) {
            latestLocation = null;
            locationUpdatedAt = 0;
            const message = 'ไม่พบตำแหน่ง GPS หรือไม่ได้รับสิทธิ์ตำแหน่ง จึงไม่สามารถเข้าสู่โหมดสแกนใบหน้าได้';
            setResult(message, 'warning');
            showPopup(message, 'warning');
            setMatchingStatus('warn', 'ไม่พร้อมเริ่มสแกน', message);
            updateLocationStatusText();
            return false;
        }

        startLocationWatch();
        updateLocationStatusText();
        return true;
    }

    function resizeOverlayCanvas() {
        overlayCanvas.width = video.clientWidth || 640;
        overlayCanvas.height = video.clientHeight || 480;
    }

    function clearScanCountdown() { scanCountdown.textContent = ''; scanCountdown.classList.add('d-none'); }
    function updateScanCountdown() {
        if (!scanSessionDeadline || scanSessionExpired) { clearScanCountdown(); return; }
        const remainingMs = Math.max(0, scanSessionDeadline - Date.now());
        scanCountdown.textContent = `เวลาสแกนคงเหลือ ${Math.ceil(remainingMs / 1000)} วินาที`;
        scanCountdown.classList.remove('d-none');
    }
 
    function stopScanSessionCountdown() {
        if (scanSessionTimer) clearTimeout(scanSessionTimer);
        if (scanCountdownTimer) clearInterval(scanCountdownTimer);
        scanSessionTimer = null;
        scanCountdownTimer = null;
        scanSessionDeadline = 0;
        scanSessionExpired = false;
        clearScanCountdown();
    }
 
    function setRetryPromptVisibility(isVisible) {
        if (!retryScanPromptElement) return false;
        retryScanPromptElement.hidden = !isVisible;
        retryScanPromptElement.classList.toggle('is-visible', isVisible);
        document.body.classList.toggle('retry-prompt-open', isVisible);
        return true;
    }
 
    function hideRetryPrompt() {
        retryPromptVisible = false;
        setRetryPromptVisibility(false);
    }
 
    function stopActiveScanSession() {
        pauseScanSession(false);
        stopCameraTracks();
    }
 
    function pauseScanSession(preserveBadges) {
        stopScanSessionCountdown();
        stopDetectionLoop(preserveBadges);
        stopLocationWatch();
        previewing = false;
        lastPreviewAt = 0;
        readyFrameStreak = 0;
        updateStartButtonLabel(true);
    }
 
    function showRetryPrompt() {
        retryPromptVisible = true;
        if (setRetryPromptVisibility(true)) return;
        retryPromptVisible = false;
        if (window.confirm('ไม่พบใบหน้าที่ตรงกับระบบภายใน 45 วินาที ต้องการเริ่มสแกนอีกครั้งหรือไม่?')) startCamera().catch(console.error);
    }
 
    function handleScanTimeout() {
        if (scanSessionExpired) return;
        if (scanning) { scanSessionTimer = setTimeout(handleScanTimeout, 300); return; }
        scanSessionExpired = true;
        stopDetectionLoop();
        stopCameraTracks();
        stopLocationWatch();
        clearScanCountdown();
        updateStartButtonLabel(true);
        readyFrameStreak = 0;
        setResult('ไม่พบใบหน้าที่ตรงกับระบบภายใน 45 วินาที', 'warning');
        showPopup('ครบเวลา 45 วินาที ลองเริ่มสแกนใหม่ได้', 'warning');
        setMatchingStatus('warn', 'หมดเวลาการสแกน', 'ไม่พบใบหน้าที่ตรงกับระบบภายในเวลาที่กำหนด');
        showRetryPrompt();
    }
 
    function startScanSessionCountdown() {
        stopScanSessionCountdown();
        scanSessionDeadline = Date.now() + SCAN_SESSION_TIMEOUT_MS;
        updateScanCountdown();
        scanCountdownTimer = setInterval(updateScanCountdown, 250);
        scanSessionTimer = setTimeout(handleScanTimeout, SCAN_SESSION_TIMEOUT_MS + 50);
    }

    function buildGuideRect() {
        const width = overlayCanvas.width * 0.50;
        const height = overlayCanvas.height * 0.66;
        return { x: (overlayCanvas.width - width) / 2, y: (overlayCanvas.height - height) / 2, width, height };
    }

    function clampRect(rect) {
        const x = Math.max(0, Math.min(rect.x, overlayCanvas.width - 1));
        const y = Math.max(0, Math.min(rect.y, overlayCanvas.height - 1));
        return { x, y, width: Math.max(1, Math.min(rect.width, overlayCanvas.width - x)), height: Math.max(1, Math.min(rect.height, overlayCanvas.height - y)) };
    }

    function expandRect(rect, ratio) {
        const expandX = rect.width * ratio;
        const expandY = rect.height * ratio;
        return clampRect({ x: rect.x - expandX, y: rect.y - expandY, width: rect.width + (expandX * 2), height: rect.height + (expandY * 2) });
    }

    function drawGuideRect(message) {
        resizeOverlayCanvas();
        const guideRect = buildGuideRect();
        overlayCtx.clearRect(0, 0, overlayCanvas.width, overlayCanvas.height);
        overlayCtx.strokeStyle = '#6ca6ff';
        overlayCtx.lineWidth = 2;
        overlayCtx.setLineDash([8, 6]);
        overlayCtx.strokeRect(guideRect.x, guideRect.y, guideRect.width, guideRect.height);
        overlayCtx.setLineDash([]);
        scanGuideHint.textContent = message ?? 'จัดใบหน้าให้อยู่ในกรอบ ระบบจะเริ่มสแกนอัตโนมัติทันที';
        return guideRect;
    }

    function drawFaceRect(rect, isReady) {
        drawGuideRect();
        overlayCtx.strokeStyle = isReady ? '#1dd75f' : '#f5b132';
        overlayCtx.lineWidth = 3;
        overlayCtx.strokeRect(rect.x, rect.y, rect.width, rect.height);
        scanGuideHint.textContent = isReady ? 'พบใบหน้าในกรอบแล้ว ระบบกำลังเริ่มสแกนอัตโนมัติ' : 'ปรับใบหน้าให้อยู่กลางกรอบและขยับเข้าใกล้กล้องอีกเล็กน้อย';
    }

    function scaleFaceRect(faceBox) {
        const scaleX = overlayCanvas.width / video.videoWidth;
        const scaleY = overlayCanvas.height / video.videoHeight;
        return clampRect({ x: faceBox.x * scaleX, y: faceBox.y * scaleY, width: faceBox.width * scaleX, height: faceBox.height * scaleY });
    }

    function isFaceReady(faceRect) {
        const guideRect = buildGuideRect();
        const centerX = faceRect.x + (faceRect.width / 2);
        const centerY = faceRect.y + (faceRect.height / 2);
        return centerX >= guideRect.x && centerX <= guideRect.x + guideRect.width && centerY >= guideRect.y && centerY <= guideRect.y + guideRect.height && faceRect.width >= guideRect.width * 0.30 && faceRect.height >= guideRect.height * 0.30;
    }

    function mapOverlayRectToVideo(rect) {
        const scaleX = video.videoWidth / overlayCanvas.width;
        const scaleY = video.videoHeight / overlayCanvas.height;
        return { x: Math.max(0, Math.floor(rect.x * scaleX)), y: Math.max(0, Math.floor(rect.y * scaleY)), width: Math.max(1, Math.floor(rect.width * scaleX)), height: Math.max(1, Math.floor(rect.height * scaleY)) };
    }

    function scaleDimensionsToFit(width, height, maxWidth, maxHeight) {
        const widthRatio = maxWidth / width;
        const heightRatio = maxHeight / height;
        const ratio = Math.min(1, widthRatio, heightRatio);
        return {
            width: Math.max(1, Math.round(width * ratio)),
            height: Math.max(1, Math.round(height * ratio))
        };
    }

    async function captureImageBlob(rect) {
        const sourceRect = mapOverlayRectToVideo(clampRect(rect ?? buildGuideRect()));
        const outputSize = scaleDimensionsToFit(sourceRect.width, sourceRect.height, 720, 720);
        canvas.width = outputSize.width;
        canvas.height = outputSize.height;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(video, sourceRect.x, sourceRect.y, sourceRect.width, sourceRect.height, 0, 0, outputSize.width, outputSize.height);
        return new Promise((resolve) => canvas.toBlob(resolve, 'image/jpeg', 0.82));
    }

    async function parseResponseJson(response) { try { return await response.json(); } catch { return null; } }
    function hasResolvedIdentity(data) { return Boolean(data && (data.studentId || (data.studentName && data.studentName !== '-'))); }
    async function previewRecognition() {
        if (!stream || previewing || scanning || video.readyState < 2 || scanSessionExpired || retryPromptVisible || supportsLiveDetection) return;
        if (Date.now() - lastPreviewAt < PREVIEW_INTERVAL_MS) return;
        lastPreviewAt = Date.now();
        previewing = true;
        try {
            const blob = await captureImageBlob(buildGuideRect());
            if (!blob) return;
            const formData = new FormData();
            formData.append('Image', blob, 'preview.jpg');
            formData.append('StationCode', stationCode || '');
            formData.append('StationToken', stationToken || '');
            formData.append('IsPublicMode', isPublicMode ? 'true' : 'false');
            formData.append('RecognitionProfile', recognitionProfileInput.value);
            const response = await fetch('/Scan/Preview', { method: 'POST', body: formData });
            const data = await parseResponseJson(response);
            const provider = data?.provider;
            const effectiveRecognitionProfile = normalizeRecognitionProfile(data?.recognitionProfile || recognitionProfileInput.value);
            const fallbackMode = isFallbackProvider(provider, effectiveRecognitionProfile);
            if (response.ok && data?.success && data.studentName) {
                setLiveName(data.studentName, buildGuideRect());
                setMatchingStatus(fallbackMode ? 'warn' : 'ready', fallbackMode ? 'พร้อมสแกนอัตโนมัติ (โหมดสำรอง)' : 'พร้อมสแกนอัตโนมัติ', `พบชื่อ: ${data.studentName} (ความมั่นใจ ${formatConfidence(data.confidence)}) ระบบกำลังยืนยันการสแกน...`, provider, effectiveRecognitionProfile);
                await captureAndSend({ allowWithoutReadyCheck: true });
                return;
            }
            clearLiveName();
            if (!scanning) {
                setMatchingStatus(fallbackMode ? 'warn' : 'track', fallbackMode ? 'กำลังระบุตัวตน (โหมดสำรอง)' : 'กำลังระบุตัวตน', data?.message || 'ตรวจพบใบหน้าแล้ว แต่ยังไม่ตรงกับฐานข้อมูล', provider, effectiveRecognitionProfile);
            }
        } catch (error) {
            console.error(error);
        } finally {
            previewing = false;
        }
    }

    async function runDetectionFrame() {
        if (!stream || video.readyState < 2) {
            readyFrameStreak = 0;
            drawGuideRect('กำลังรอสัญญาณกล้อง...');
            setMatchingStatus('idle', 'สถานะการแมตช์: รอเริ่มต้น', 'กดเปิดกล้องเพื่อเริ่มสแกน');
            return;
        }
        if (!supportsLiveDetection || !faceDetector) {
            latestFaceRect = buildGuideRect();
            readyFrameStreak = 0;
            drawGuideRect('โหมดมาตรฐาน: จัดใบหน้าให้อยู่ในกรอบ แล้วกด "สแกนตอนนี้"');
            if (!scanning) setMatchingStatus('track', 'โหมดมาตรฐาน', 'กำลังตรวจสอบใบหน้าอัตโนมัติจากภาพในกรอบ');
            await previewRecognition();
            return;
        }
        if (detectionBusy) return;
        detectionBusy = true;
        try {
            const faces = await faceDetector.detect(video);
            if (!faces || faces.length === 0) {
                latestFaceRect = null;
                readyFrameStreak = 0;
                clearLiveName();
                drawGuideRect('กำลังค้นหาใบหน้า...');
                if (!scanning) setMatchingStatus('track', 'กำลังตรวจจับใบหน้า', 'ยังไม่พบใบหน้าในภาพ');
                return;
            }
            const scaledRect = scaleFaceRect(faces[0].boundingBox);
            latestFaceRect = scaledRect;
            const ready = isFaceReady(scaledRect);
            drawFaceRect(scaledRect, ready);
            if (!ready) {
                readyFrameStreak = 0;
                clearLiveName();
                if (!scanning) setMatchingStatus('track', 'กำลังจัดตำแหน่งใบหน้า', 'พบใบหน้าแล้ว แต่ยังไม่อยู่ในตำแหน่งที่เหมาะสม');
                return;
            }
            readyFrameStreak += 1;
            if (!scanning) setMatchingStatus('ready', 'พบใบหน้าแล้ว', 'พบใบหน้าในกรอบ ระบบจะเริ่มสแกนอัตโนมัติ');
            if (!scanSessionExpired && !retryPromptVisible && readyFrameStreak >= READY_FRAME_THRESHOLD) {
                await captureAndSend({ allowWithoutReadyCheck: true });
            }
        } catch (error) {
            console.error(error);
            supportsLiveDetection = false;
            faceDetector = null;
            latestFaceRect = buildGuideRect();
            readyFrameStreak = 0;
            drawGuideRect('เปลี่ยนเป็นโหมดมาตรฐานอัตโนมัติ');
            setMatchingStatus('warn', 'Live Detection ไม่พร้อมใช้งาน', 'ระบบเปลี่ยนเป็นโหมดกรอบมาตรฐานให้แล้ว');
        } finally {
            detectionBusy = false;
        }
    }

    function startDetectionLoop() {
        stopDetectionLoop();
        detectionTimer = setInterval(() => runDetectionFrame().catch(console.error), 380);
    }

    function stopDetectionLoop(preserveBadges = false) {
        if (detectionTimer) clearInterval(detectionTimer);
        detectionTimer = null;
        latestFaceRect = null;
        readyFrameStreak = 0;
        detectionBusy = false;
        if (!preserveBadges) {
            clearLiveName();
            clearLiveStatus();
            overlayCtx.clearRect(0, 0, overlayCanvas.width, overlayCanvas.height);
        }
    }

    function stopCameraTracks() {
        if (!stream) return;
        stream.getTracks().forEach((track) => track.stop());
        video.srcObject = null;
        stream = null;
    }

    function initFaceDetector() {
        supportsLiveDetection = false;
        faceDetector = null;
        if (!('FaceDetector' in window)) return;
        try {
            faceDetector = new FaceDetector({ fastMode: true, maxDetectedFaces: 1 });
            supportsLiveDetection = true;
        } catch {
            faceDetector = null;
            supportsLiveDetection = false;
        }
    }

    async function startCamera() {
        try {
            hideRetryPrompt();
            stopActiveScanSession();
            focusCameraPreview();
            const gpsReady = await ensureGpsReadyBeforeScan();
            if (!gpsReady) return;
            setMatchingStatus('idle', 'กำลังเปิดกล้อง', 'กรุณาอนุญาตการเข้าถึงกล้อง');
            if (!navigator.mediaDevices?.getUserMedia) {
                throw new Error(describeCameraError({ name: 'SecurityError' }));
            }
            stream = await navigator.mediaDevices.getUserMedia({
                video: { facingMode: { ideal: facingMode }, width: { ideal: 960 }, height: { ideal: 540 } },
                audio: false
            });
            video.srcObject = stream;
            video.setAttribute('playsinline', 'true');
            await video.play();
            focusCameraPreview();
            resizeOverlayCanvas();
            initFaceDetector();
            startLocationWatch();
            startScanSessionCountdown();
            startDetectionLoop();
            updateStartButtonLabel(true);
            setResult('กล้องพร้อมใช้งาน ระบบจะเริ่มสแกนอัตโนมัติเมื่อพบใบหน้าในกรอบ หรือกด "สแกนตอนนี้" ได้ทันที', 'success');
            setMatchingStatus('track', 'กล้องพร้อมใช้งาน', 'จัดใบหน้าให้อยู่ในกรอบ ระบบจะเริ่มสแกนอัตโนมัติหรือกดสแกนทันทีได้');
        } catch (error) {
            console.error(error);
            stopScanSessionCountdown();
            const message = describeCameraError(error);
            setResult(message, 'danger');
            showPopup(message, 'danger');
            setMatchingStatus('error', 'เปิดกล้องไม่สำเร็จ', message);
        }
    }

    async function switchCamera() {
        facingMode = facingMode === 'user' ? 'environment' : 'user';
        await startCamera();
    }
    async function captureAndSend(options = {}) {
        const allowWithoutReadyCheck = options.allowWithoutReadyCheck === true;
        if (!stream || scanSessionExpired || retryPromptVisible) return;
        if (!allowWithoutReadyCheck && (!supportsLiveDetection || !latestFaceRect || !isFaceReady(latestFaceRect))) {
            setResult('กรุณาจัดใบหน้าให้อยู่ในกรอบก่อนสแกน', 'warning');
            setMatchingStatus('track', 'รอพบใบหน้า', 'ระบบจะเริ่มทำงานเมื่อพบใบหน้า');
            return;
        }
        if (scanning || (Date.now() - lastScanAt) < SCAN_COOLDOWN_MS) return;

        scanning = true;
        lastScanAt = Date.now();
        setActionButtonsBusy(true);
        try {
            setMatchingStatus('capture', 'กำลังจับภาพใบหน้า', 'ระบบกำลังเตรียมภาพสำหรับแมตช์');
            const captureRect = supportsLiveDetection && latestFaceRect ? expandRect(latestFaceRect, 0.18) : buildGuideRect();
            const blob = await captureImageBlob(captureRect);
            if (!blob) {
                setResult('ไม่สามารถจับภาพได้', 'danger');
                setMatchingStatus('error', 'จับภาพไม่สำเร็จ', 'กรุณาลองใหม่อีกครั้ง');
                return;
            }

            setMatchingStatus('matching', 'กำลังแมตช์ใบหน้า', 'ระบบกำลังตรวจสอบตัวตนจากภาพที่สแกน');
            const location = await getCurrentLocation();
            const formData = new FormData();
            formData.append('Image', blob, 'capture.jpg');
            formData.append('StationCode', stationCode || '');
            formData.append('StationToken', stationToken || '');
            formData.append('RequestedType', requestedType.value);
            formData.append('IsPublicMode', isPublicMode ? 'true' : 'false');
            formData.append('RecognitionProfile', recognitionProfileInput.value);
            formData.append('ClientCapturedAtLocal', formatClientLocalTimestamp(new Date()));
            if (location) {
                formData.append('Latitude', String(location.latitude));
                formData.append('Longitude', String(location.longitude));
                formData.append('LocationAccuracyMeters', String(location.accuracy));
            }

            const response = await fetch('/Scan/Verify', { method: 'POST', body: formData });
            const data = await parseResponseJson(response);
            const provider = data?.provider;
            const timeSource = data?.timeSource;
            const clockAnomaly = Boolean(data?.clockAnomaly);
            const resolvedIdentity = hasResolvedIdentity(data);
            const effectiveRecognitionProfile = normalizeRecognitionProfile(data?.recognitionProfile || recognitionProfileInput.value);
            const fallbackMode = isFallbackProvider(provider, effectiveRecognitionProfile);

            if (!response.ok || !data || !data.success) {
                const failMessage = data?.message || 'สแกนไม่สำเร็จ';
                const failKind = data?.isDuplicate || resolvedIdentity ? 'warning' : 'danger';
                setResult(failMessage, failKind);
                showPopup(failMessage, failKind);
                setMatchingStatus(data?.isDuplicate || resolvedIdentity ? 'warn' : (fallbackMode ? 'warn' : 'error'), resolvedIdentity ? 'พบข้อมูลแล้ว' : (fallbackMode ? 'แมตช์ไม่สำเร็จ (โหมดสำรอง)' : 'แมตช์ไม่สำเร็จ'), failMessage, provider, effectiveRecognitionProfile);
                if (resolvedIdentity) {
                    const nameRect = latestFaceRect && isFaceReady(latestFaceRect) ? latestFaceRect : buildGuideRect();
                    setLiveName(data.studentName || '-', nameRect);
                    pauseScanSession(true);
                }
                return;
            }

            const successMessage = `${data.studentName || '-'} - ${data.message}`;
            setResult(successMessage, 'success');
            showPopup(successMessage, 'success');
            const nameRect = latestFaceRect && isFaceReady(latestFaceRect) ? latestFaceRect : buildGuideRect();
            setLiveName(data.studentName || '-', nameRect);
            setMatchingStatus(fallbackMode ? 'warn' : 'success', fallbackMode ? 'แมตช์สำเร็จ (โหมดสำรอง)' : 'แมตช์สำเร็จ', `พบชื่อ: ${data.studentName || '-'} (ความมั่นใจ ${formatConfidence(data.confidence)})${clockAnomaly ? ` | เวลา: ${timeSourceLabel(timeSource)}` : ''}`, provider, effectiveRecognitionProfile);
            renderLatestSuccess(data, location, effectiveRecognitionProfile);

            pauseScanSession(true);
            await refreshRecentScans();
        } catch (error) {
            console.error(error);
            setResult('เกิดข้อผิดพลาดระหว่างส่งภาพ', 'danger');
            showPopup('เกิดข้อผิดพลาดระหว่างส่งภาพ', 'danger');
            setMatchingStatus('error', 'แมตช์ไม่สำเร็จ', 'เกิดข้อผิดพลาดระหว่างติดต่อเซิร์ฟเวอร์');
        } finally {
            scanning = false;
            setActionButtonsBusy(false);
        }
    }

    if (retryScanPromptElement) {
        retryScanPromptElement.addEventListener('click', (event) => {
            const target = event.target;
            if (!(target instanceof HTMLElement)) return;
            if (target.dataset.retryClose === 'true') hideRetryPrompt();
        });
    }

    recognitionProfileButtons.forEach((button) => {
        button.addEventListener('click', () => {
            applyRecognitionProfile(button.dataset.recognitionProfile);
        });
    });
    btnStart.addEventListener('click', startCamera);
    if (btnStartInline) btnStartInline.addEventListener('click', startCamera);
    btnSwitch.addEventListener('click', switchCamera);
    btnScan.addEventListener('click', () => captureAndSend().catch(console.error));
    btnRefreshRecent.addEventListener('click', () => refreshRecentScans().catch(console.error));
    if (btnRetryScan) {
        btnRetryScan.addEventListener('click', () => {
            hideRetryPrompt();
            startCamera().catch(console.error);
        });
    }
    if (btnRetryCancel) btnRetryCancel.addEventListener('click', hideRetryPrompt);
    if (btnRetryClose) btnRetryClose.addEventListener('click', hideRetryPrompt);
    document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && retryPromptVisible) hideRetryPrompt();
    });
    window.addEventListener('resize', resizeOverlayCanvas);
    window.addEventListener('beforeunload', () => {
        stopDetectionLoop();
        stopCameraTracks();
        stopLocationWatch();
        stopScanSessionCountdown();
        document.body.classList.remove('retry-prompt-open');
    });

    setRetryPromptVisibility(false);
    applyRecognitionProfile(recognitionProfileInput.value || loadStoredRecognitionProfile(), false);
    updateStartButtonLabel(false);
    setInterval(updateClock, 1000);
    updateClock();
    updateLocationStatusText();
    refreshRecentScans();
    setResult('กด "เปิดกล้อง" เพื่อเริ่มใช้งานกล้องก่อนสแกน', 'secondary');
    setMatchingStatus('idle', 'สถานะการแมตช์: รอเริ่มต้น', 'กดปุ่มเปิดกล้องก่อนเริ่มสแกน');
})();
</script>
}

