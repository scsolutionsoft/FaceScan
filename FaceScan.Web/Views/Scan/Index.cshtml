@model ScanViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "สแกนผ่านมือถือ";
}

<div class="scan-wrapper">
    <div class="card scan-hero mb-3 border-0">
        <div class="card-body">
            <div>
                <div class="hero-kicker">สถานีสแกนผ่านมือถือ</div>
                <h2 class="mb-1">@Model.SchoolName</h2>
                <div class="text-white-50">สแกนใบหน้าเพื่อเช็คเวลาเข้า-ออกด้วยมือถือ</div>
                <div id="clock" class="scan-clock mt-2"></div>
            </div>
            <img src="~/img/facescan-mark.svg" class="scan-hero-mark" alt="สแกนใบหน้า" />
        </div>
    </div>

    <div class="card scan-card mb-3">
        <div class="card-body">
            <div class="scan-setup-grid mb-3">
                <div class="scan-setting-card">
                    <div class="scan-setting-head">
                        <label for="requestedType" class="form-label fw-semibold mb-0">ประเภทการสแกน</label>
                        <span class="scan-setting-badge">เลือกก่อนสแกน</span>
                    </div>
                    <select id="requestedType" class="form-select form-select-lg mt-2">
                        <option value="1" selected="@(Model.RequestedType == ScanType.CheckIn ? "selected" : null)">เข้าเรียน</option>
                        <option value="2" selected="@(Model.RequestedType == ScanType.CheckOut ? "selected" : null)">กลับบ้าน</option>
                    </select>
                </div>

                <div class="scan-setting-card">
                    <div class="scan-setting-head">
                        <div>
                            <div class="form-label fw-semibold mb-0">อัลกอริทึมสแกน</div>
                            <div class="scan-setting-subtitle">เลือกให้เหมาะกับความเร็วและความแม่นยำของอุปกรณ์</div>
                        </div>
                        <span class="scan-setting-badge">เร็ว/อัตโนมัติ/เสถียร/แม่นยำ</span>
                    </div>

                    <div class="scan-profile-grid mt-2" id="recognitionProfileOptions">
                        <button type="button" class="scan-profile-card" data-recognition-profile="@FaceRecognitionProfiles.Fast">
                            <span class="scan-profile-kicker">เร็ว</span>
                            <span class="scan-profile-title">รวดเร็ว</span>
                            <span class="scan-profile-note">ใช้ OpenCV Lite หรือโหมดสำรองที่เบาสุดก่อน เหมาะกับมือถือและจังหวะสแกนหนาแน่น</span>
                        </button>
                        <button type="button" class="scan-profile-card is-active" data-recognition-profile="@FaceRecognitionProfiles.Auto">
                            <span class="scan-profile-kicker">แนะนำ</span>
                            <span class="scan-profile-title">อัตโนมัติ</span>
                            <span class="scan-profile-note">ให้ระบบเลือก OpenCV Lite, Dlib, InsightFace หรือ DeepFace ตาม engine ที่พร้อมใช้งานอัตโนมัติ</span>
                        </button>
                        <button type="button" class="scan-profile-card" data-recognition-profile="@FaceRecognitionProfiles.Stable">
                            <span class="scan-profile-kicker">เสถียร</span>
                            <span class="scan-profile-title">เสถียรสูง</span>
                            <span class="scan-profile-note">ให้ความสำคัญกับ engine ที่นิ่งและตอบสนองดีบนเครื่องหน้างานก่อน ลดโอกาส fallback แบบหนัก</span>
                        </button>
                        <button type="button" class="scan-profile-card" data-recognition-profile="@FaceRecognitionProfiles.Accurate">
                            <span class="scan-profile-kicker">แม่นยำ</span>
                            <span class="scan-profile-title">แม่นยำสูง</span>
                            <span class="scan-profile-note">พยายามใช้ InsightFace, Dlib และ DeepFace ก่อน เหมาะเมื่อเน้นความมั่นใจของผลลัพธ์</span>
                        </button>
                    </div>

                    <div id="recognitionProfileHint" class="scan-profile-hint">โหมดอัตโนมัติเหมาะกับการใช้งานทั่วไปบนมือถือและแท็บเล็ต เพราะเลือก engine ให้ตามสภาพแวดล้อมจริง</div>
                </div>
            </div>

            <div class="scan-info-card mb-3">
                <div class="scan-info-label"><i class="bi bi-geo-alt me-1"></i> ตำแหน่งจีพีเอส</div>
                <div id="locationStatus" class="small text-muted">กำลังรอตำแหน่ง...</div>
            </div>

            <div id="matchingStatusCard" class="matching-status-card matching-state-idle mb-3">
                <span class="matching-dot"></span>
                <div>
                    <div id="matchingMain" class="matching-main">สถานะการแมตช์: รอเริ่มต้น</div>
                    <div id="matchingSub" class="matching-sub">กดเปิดกล้องเพื่อเริ่มสแกน</div>
                </div>
            </div>

            <div class="d-grid mb-3">
                <button id="btnStartInline" class="btn btn-lg btn-outline-primary scan-primary-action">
                    <i class="bi bi-camera-video me-1"></i> เปิดกล้องก่อนเริ่มสแกน
                </button>
            </div>

            <div class="video-shell mb-2" id="cameraPreviewShell" tabindex="-1">
                <div class="video-stage">
                    <video id="video" autoplay playsinline muted></video>
                    <canvas id="overlayCanvas"></canvas>
                    <div id="liveNameBadge" class="live-name-badge d-none"></div>
                    <div id="liveStatusBadge" class="live-status-badge live-status-idle d-none"></div>
                </div>
                <canvas id="canvas" class="d-none"></canvas>
            </div>

            <div id="scanGuideHint" class="small text-muted mb-3">จัดใบหน้าให้อยู่กลางกรอบ ระบบจะเริ่มสแกนอัตโนมัติเมื่อพร้อม</div>

            <div class="row g-2 scan-actions">
                <div class="col-12 col-sm-4 d-grid">
                    <button id="btnStart" class="btn btn-lg btn-primary">
                        <i class="bi bi-camera-video me-1"></i> เปิดกล้อง
                    </button>
                </div>
                <div class="col-12 col-sm-4 d-grid">
                    <button id="btnSwitch" class="btn btn-lg btn-outline-secondary">
                        <i class="bi bi-arrow-repeat me-1"></i> สลับกล้อง
                    </button>
                </div>
                <div class="col-12 col-sm-4 d-grid">
                    <button id="btnScan" class="btn btn-lg btn-success">
                        <i class="bi bi-person-check me-1"></i> สแกนตอนนี้
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div id="resultBox" class="alert alert-secondary fs-5 scan-result-box" role="alert">พร้อมใช้งาน</div>

    <div class="card">
        <div class="card-header fw-semibold">
            <i class="bi bi-person-check me-1"></i> ผลล่าสุดที่สแกนสำเร็จ
        </div>
        <div class="card-body" id="latestSuccess">
            <div class="scan-success-empty text-muted">ยังไม่มีข้อมูล</div>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
            <span><i class="bi bi-clock-history me-1"></i> รายงานสแกนล่าสุด</span>
            <button type="button" id="btnRefreshRecent" class="btn btn-sm btn-outline-secondary">รีเฟรช</button>
        </div>
        <div class="card-body p-0">
            <div id="recentScansCards" class="recent-scan-cards d-md-none p-3">
                <div class="text-center text-muted py-2">ยังไม่มีข้อมูล</div>
            </div>
            <div class="table-responsive d-none d-md-block">
                <table class="table table-sm table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="text-nowrap">วันเวลา</th>
                            <th class="text-nowrap">รหัส</th>
                            <th class="text-nowrap">ชื่อ</th>
                            <th class="text-nowrap">ประเภท</th>
                            <th class="text-nowrap">ความมั่นใจ</th>
                            <th class="text-nowrap">เอนจิน</th>
                        </tr>
                    </thead>
                    <tbody id="recentScansBody">
                        <tr>
                            <td colspan="6" class="text-center text-muted py-3">ยังไม่มีข้อมูล</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<input type="hidden" id="stationCode" value="@Model.StationCode" />
<input type="hidden" id="stationToken" value="@Model.StationToken" />
<input type="hidden" id="isPublicMode" value="@(Model.IsPublicMode ? "true" : "false")" />
<input type="hidden" id="recognitionProfile" value="@Model.RecognitionProfile" />

<div class="toast-container position-fixed top-0 end-0 p-3">
    <div id="scanToast" class="toast text-bg-primary border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div id="scanToastMessage" class="toast-body">-</div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>
<div id="retryScanPrompt" class="scan-retry-sheet" hidden>
    <div class="scan-retry-backdrop" data-retry-close="true"></div>
    <div class="scan-retry-dialog" role="dialog" aria-modal="true" aria-labelledby="retryScanPromptLabel">
        <div class="scan-retry-head">
            <h5 class="scan-retry-title" id="retryScanPromptLabel">สแกนไม่สำเร็จ</h5>
            <button type="button" class="btn-close" id="btnRetryClose" aria-label="Close"></button>
        </div>
        <div class="scan-retry-body">
            ไม่พบใบหน้าที่ตรงกับระบบภายใน 45 วินาที ต้องการเริ่มสแกนอีกครั้งหรือไม่?
        </div>
        <div class="scan-retry-actions">
            <button type="button" class="btn btn-outline-secondary" id="btnRetryCancel">ยังไม่สแกนต่อ</button>
            <button type="button" class="btn btn-primary" id="btnRetryScan">สแกนอีกครั้ง</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
(() => {
    const video = document.getElementById('video');
    const overlayCanvas = document.getElementById('overlayCanvas');
    const overlayCtx = overlayCanvas.getContext('2d');
    const canvas = document.getElementById('canvas');
    const requestedType = document.getElementById('requestedType');
    const recognitionProfileInput = document.getElementById('recognitionProfile');
    const recognitionProfileHint = document.getElementById('recognitionProfileHint');
    const recognitionProfileButtons = Array.from(document.querySelectorAll('[data-recognition-profile]'));
    const stationCode = document.getElementById('stationCode').value;
    const stationToken = document.getElementById('stationToken').value;
    const isPublicMode = document.getElementById('isPublicMode').value === 'true';
    const resultBox = document.getElementById('resultBox');
    const latestSuccess = document.getElementById('latestSuccess');
    const recentScansBody = document.getElementById('recentScansBody');
    const recentScansCards = document.getElementById('recentScansCards');
    const clock = document.getElementById('clock');
    const locationStatus = document.getElementById('locationStatus');
    const liveNameBadge = document.getElementById('liveNameBadge');
    const liveStatusBadge = document.getElementById('liveStatusBadge');
    const scanGuideHint = document.getElementById('scanGuideHint');
    const matchingStatusCard = document.getElementById('matchingStatusCard');
    const matchingMain = document.getElementById('matchingMain');
    const matchingSub = document.getElementById('matchingSub');
    const cameraPreviewShell = document.getElementById('cameraPreviewShell');
    const btnStart = document.getElementById('btnStart');
    const btnStartInline = document.getElementById('btnStartInline');
    const btnSwitch = document.getElementById('btnSwitch');
    const btnScan = document.getElementById('btnScan');
    const btnRefreshRecent = document.getElementById('btnRefreshRecent');
    const retryScanPromptElement = document.getElementById('retryScanPrompt');
    const btnRetryScan = document.getElementById('btnRetryScan');
    const btnRetryCancel = document.getElementById('btnRetryCancel');
    const btnRetryClose = document.getElementById('btnRetryClose');

    const toastElement = document.getElementById('scanToast');
    const toastMessage = document.getElementById('scanToastMessage');
    const toast = window.bootstrap ? new bootstrap.Toast(toastElement, { delay: 3500 }) : null;

    const PREVIEW_INTERVAL_MS = 2200;
    const SCAN_COOLDOWN_MS = 1400;
    const SCAN_SESSION_TIMEOUT_MS = 45000;
    const READY_FRAME_THRESHOLD = 2;
    const RECOGNITION_PROFILE_STORAGE_KEY = 'facescan.recognitionProfile';
    const recognitionProfilePresets = {
        fast: {
            label: 'รวดเร็ว',
            shortLabel: 'เร็ว',
            hint: 'โหมดเร็วเหมาะกับมือถือจอเล็กหรือเครื่องที่สเปกไม่สูง ระบบจะเริ่มจาก OpenCV Lite และโหมดสำรองที่เบาสุดก่อน'
        },
        auto: {
            label: 'อัตโนมัติ',
            shortLabel: 'อัตโนมัติ',
            hint: 'โหมดอัตโนมัติเหมาะกับการใช้งานทั่วไปบนมือถือและแท็บเล็ต ระบบจะเลือก engine ที่เร็วและเหมาะกับสภาพแวดล้อมให้เอง'
        },
        stable: {
            label: 'เสถียรสูง',
            shortLabel: 'เสถียร',
            hint: 'โหมดเสถียรสูงจะพยายามใช้ engine ที่นิ่งบนเครื่องหน้างานก่อน เพื่อลดอาการแกว่งเมื่อมีคนสแกนต่อเนื่อง'
        },
        accurate: {
            label: 'แม่นยำสูง',
            shortLabel: 'แม่นยำ',
            hint: 'โหมดแม่นยำสูงจะให้น้ำหนักกับ InsightFace, Dlib และ DeepFace ก่อน เมื่อ environment พร้อมใช้งาน'
        }
    };

    let stream = null;
    let facingMode = 'user';
    let scanning = false;
    let lastScanAt = 0;
    let latestLocation = null;
    let locationUpdatedAt = 0;
    let locationWatchId = null;
    let faceDetector = null;
    let supportsLiveDetection = false;
    let latestFaceRect = null;
    let detectionTimer = null;
    let detectionBusy = false;
    let previewing = false;
    let lastPreviewAt = 0;
    let activeProvider = null;
    let readyFrameStreak = 0;
    let scanSessionTimer = null;
    let scanCountdownTimer = null;
    let scanSessionDeadline = 0;
    let scanSessionExpired = false;
    let retryPromptVisible = false;
    let gpsConsentConfirmed = false;

    scanGuideHint.textContent = 'จัดใบหน้าให้อยู่ในกรอบ ระบบจะเริ่มสแกนอัตโนมัติทันที';
    scanGuideHint.classList.remove('mb-3');
    scanGuideHint.classList.add('mb-2');

    let scanCountdown = document.getElementById('scanCountdown');
    if (!scanCountdown) {
        scanCountdown = document.createElement('div');
        scanCountdown.id = 'scanCountdown';
        scanCountdown.className = 'small fw-semibold text-primary mb-3 d-none';
        scanGuideHint.insertAdjacentElement('afterend', scanCountdown);
    }

    function updateClock() { clock.textContent = new Date().toLocaleString('th-TH'); }

    function normalizeRecognitionProfile(value) {
        const normalized = typeof value === 'string' ? value.trim().toLowerCase() : '';
        if (normalized === 'fast' || normalized === 'mock') return 'fast';
        if (normalized === 'auto' || normalized === 'balanced' || normalized === 'hybrid' || normalized === 'default') return 'auto';
        if (normalized === 'stable' || normalized === 'steady' || normalized === 'reliable') return 'stable';
        if (normalized === 'accurate' || normalized === 'dlib') return 'accurate';
        return 'auto';
    }

    function getRecognitionProfileMeta(value) {
        return recognitionProfilePresets[normalizeRecognitionProfile(value)] || recognitionProfilePresets.auto;
    }

    function recognitionProfileLabel(value) {
        return getRecognitionProfileMeta(value).label;
    }

    function loadStoredRecognitionProfile() {
        try {
            return window.localStorage ? window.localStorage.getItem(RECOGNITION_PROFILE_STORAGE_KEY) : null;
        } catch {
            return null;
        }
    }

    function storeRecognitionProfile(value) {
        try {
            if (window.localStorage) {
                window.localStorage.setItem(RECOGNITION_PROFILE_STORAGE_KEY, normalizeRecognitionProfile(value));
            }
        } catch {
            // Ignore storage errors.
        }
    }

    function applyRecognitionProfile(profile, persist = true) {
        const normalized = normalizeRecognitionProfile(profile || recognitionProfileInput?.value);
        if (recognitionProfileInput) recognitionProfileInput.value = normalized;
        recognitionProfileButtons.forEach((button) => {
            button.classList.toggle('is-active', normalizeRecognitionProfile(button.dataset.recognitionProfile) === normalized);
        });
        if (recognitionProfileHint) {
            recognitionProfileHint.textContent = getRecognitionProfileMeta(normalized).hint;
        }
        activeProvider = null;
        if (persist) storeRecognitionProfile(normalized);
        return normalized;
    }

    function setResult(message, kind) {
        resultBox.textContent = message;
        resultBox.className = 'alert fs-5 scan-result-box';
        if (kind === 'success') resultBox.classList.add('alert-success');
        else if (kind === 'warning') resultBox.classList.add('alert-warning');
        else if (kind === 'danger') resultBox.classList.add('alert-danger');
        else resultBox.classList.add('alert-secondary');
    }

    function setMatchingStatus(state, mainText, subText, provider, recognitionProfile = recognitionProfileInput?.value) {
        matchingStatusCard.className = `matching-status-card matching-state-${state}`;
        matchingMain.textContent = mainText;
        matchingSub.textContent = withProviderText(subText, provider, recognitionProfile);
        const overlayRect = overlayCanvas.width > 0 && overlayCanvas.height > 0
            ? (latestFaceRect ?? buildGuideRect())
            : null;
        setLiveStatus(mainText, state, overlayRect);
    }

    function showPopup(message, kind) {
        if (!toast) return;
        toastMessage.textContent = message;
        toastElement.className = 'toast border-0';
        if (kind === 'success') toastElement.classList.add('text-bg-success');
        else if (kind === 'warning') toastElement.classList.add('text-bg-warning');
        else if (kind === 'danger') toastElement.classList.add('text-bg-danger');
        else toastElement.classList.add('text-bg-primary');
        toast.show();
    }

    function updateStartButtonLabel(canRestart) {
        btnStart.innerHTML = canRestart
            ? '<i class="bi bi-arrow-clockwise me-1"></i> เริ่มสแกนใหม่'
            : '<i class="bi bi-camera-video me-1"></i> เปิดกล้อง';
        if (btnStartInline) {
            btnStartInline.innerHTML = canRestart
                ? '<i class="bi bi-arrow-clockwise me-1"></i> เปิดกล้องอีกครั้ง'
                : '<i class="bi bi-camera-video me-1"></i> เปิดกล้องก่อนเริ่มสแกน';
        }
    }

    function setActionButtonsBusy(isBusy) {
        btnStart.disabled = isBusy;
        if (btnStartInline) btnStartInline.disabled = isBusy;
        btnSwitch.disabled = isBusy;
        btnScan.disabled = isBusy;
        requestedType.disabled = isBusy;
        recognitionProfileButtons.forEach((button) => { button.disabled = isBusy; });
        if (btnRetryScan) btnRetryScan.disabled = isBusy;
        if (btnRetryCancel) btnRetryCancel.disabled = isBusy;
        if (btnRetryClose) btnRetryClose.disabled = isBusy;
    }

    function describeCameraError(error) {
        const fallbackUrl = location.hostname === '127.0.0.1'
            ? 'http://localhost:5248/Scan/Public หรือ https://localhost:7089/Scan/Public'
            : 'https://localhost:7089/Scan/Public';

        if (!navigator.mediaDevices?.getUserMedia) {
            return `เบราว์เซอร์นี้ไม่อนุญาตให้เปิดกล้องจากหน้านี้ ลองเปิดผ่าน ${fallbackUrl}`;
        }

        if (!error || typeof error !== 'object') {
            return 'ไม่สามารถเปิดกล้องได้ (ตรวจสอบสิทธิ์หรืออุปกรณ์)';
        }

        switch (error.name) {
            case 'NotAllowedError':
            case 'PermissionDeniedError':
                return 'สิทธิ์กล้องถูกบล็อก กรุณาอนุญาต Camera ในเบราว์เซอร์แล้วกดเปิดกล้องอีกครั้ง';
            case 'NotFoundError':
            case 'DevicesNotFoundError':
                return 'ไม่พบอุปกรณ์กล้องในเครื่องนี้';
            case 'NotReadableError':
            case 'TrackStartError':
            case 'AbortError':
                return 'กล้องอาจถูกใช้งานโดยแอปอื่นอยู่ กรุณาปิดแอปกล้องหรือประชุมออนไลน์ก่อน';
            case 'OverconstrainedError':
            case 'ConstraintNotSatisfiedError':
                return 'กล้องที่ระบบพยายามเปิดไม่พร้อมใช้งาน ลองกดสลับกล้องหรือเปิดใหม่อีกครั้ง';
            case 'SecurityError':
                return `เบราว์เซอร์บล็อกการเปิดกล้องจากหน้านี้ ลองเปิดผ่าน ${fallbackUrl}`;
            default:
                return error.message || 'ไม่สามารถเปิดกล้องได้ (ตรวจสอบสิทธิ์หรืออุปกรณ์)';
        }
    }

    function clearLiveName() {
        liveNameBadge.textContent = '';
        liveNameBadge.classList.add('d-none');
    }

    function clearLiveStatus() {
        liveStatusBadge.textContent = '';
        liveStatusBadge.className = 'live-status-badge live-status-idle d-none';
    }

    function setLiveName(name, rect) {
        if (!name || !rect) { clearLiveName(); return; }
        liveNameBadge.style.left = `${Math.max(8, Math.floor(rect.x))}px`;
        liveNameBadge.style.top = `${Math.max(8, Math.floor(rect.y - 34))}px`;
        liveNameBadge.textContent = name;
        liveNameBadge.classList.remove('d-none');
    }

    function setLiveStatus(text, state, rect) {
        if (!text || !rect || !stream) { clearLiveStatus(); return; }
        const badgeWidth = Math.min(280, Math.max(170, rect.width));
        const maxX = Math.max(8, overlayCanvas.width - badgeWidth - 8);
        const left = Math.max(8, Math.min(Math.floor(rect.x), maxX));
        const desiredTop = Math.floor(rect.y + rect.height + 12);
        const fallbackTop = Math.floor(rect.y - 44);
        const top = desiredTop <= overlayCanvas.height - 36
            ? desiredTop
            : Math.max(8, fallbackTop);
        liveStatusBadge.style.left = `${left}px`;
        liveStatusBadge.style.top = `${top}px`;
        liveStatusBadge.style.width = `${badgeWidth}px`;
        liveStatusBadge.textContent = text;
        liveStatusBadge.className = `live-status-badge live-status-${state}`;
        liveStatusBadge.classList.remove('d-none');
    }

    function scanTypeLabel(scanType) {
        if (scanType === 1 || scanType === 'CheckIn') return 'เข้าเรียน';
        if (scanType === 2 || scanType === 'CheckOut') return 'กลับบ้าน';
        return scanType ?? '-';
    }

    function formatConfidence(confidence) {
        const numberValue = Number(confidence);
        return Number.isNaN(numberValue) ? '-' : numberValue.toFixed(2);
    }

    function normalizeProvider(provider) { return typeof provider === 'string' ? provider.trim() : ''; }
    function isMockProvider(provider) { return normalizeProvider(provider).toLowerCase().includes('mock'); }
    function isFallbackProvider(provider, recognitionProfile = recognitionProfileInput?.value) {
        const lower = normalizeProvider(provider).toLowerCase();
        const hasPrimaryEngine = lower.includes('opencv') || lower.includes('dlib') || lower.includes('insightface') || lower.includes('deepface');
        return isMockProvider(provider) && !hasPrimaryEngine && normalizeRecognitionProfile(recognitionProfile) !== 'fast';
    }
    function providerLabel(provider, recognitionProfile = recognitionProfileInput?.value, options = {}) {
        const normalized = normalizeProvider(provider);
        if (!normalized) return '';
        const lower = normalized.toLowerCase();
        const fallbackTag = options.showFallbackTag === false || !isFallbackProvider(provider, recognitionProfile)
            ? ''
            : ' (โหมดสำรอง)';
        if (lower.includes('hybridfaceengine')) {
            return normalized
                .replace(/HybridFaceEngine/ig, 'Hybrid')
                .replace(/opencv_lite/ig, 'OpenCV Lite')
                .replace(/mock_phash/ig, `MockFaceEngine${fallbackTag}`)
                .replace(/insightface/ig, 'InsightFace')
                .replace(/deepface/ig, 'DeepFace')
                .replace(/dlib/ig, 'Dlib');
        }
        if (lower.includes('opencv')) return 'OpenCV Lite';
        if (lower.includes('insightface')) return 'InsightFace';
        if (lower.includes('deepface')) return 'DeepFace';
        if (lower.includes('dlib')) return 'Dlib';
        if (lower.includes('mock')) {
            return options.showFallbackTag === false || !isFallbackProvider(provider, recognitionProfile)
                ? 'MockFaceEngine'
                : `MockFaceEngine${fallbackTag}`;
        }
        return normalized;
    }

    function updateProvider(provider) {
        const normalized = normalizeProvider(provider);
        if (normalized) activeProvider = normalized;
        return activeProvider;
    }

    function withProviderText(subText, provider, recognitionProfile = recognitionProfileInput?.value) {
        const currentProvider = updateProvider(provider);
        return currentProvider ? `${subText} | เอนจิน: ${providerLabel(currentProvider, recognitionProfile)}` : subText;
    }

    function formatClientLocalTimestamp(date) {
        const value = date instanceof Date ? date : new Date();
        const pad = (number) => String(number).padStart(2, '0');
        return `${value.getFullYear()}-${pad(value.getMonth() + 1)}-${pad(value.getDate())}T${pad(value.getHours())}:${pad(value.getMinutes())}:${pad(value.getSeconds())}`;
    }

    function escapeHtml(value) {
        return String(value ?? '').replaceAll('&', '&amp;').replaceAll('<', '&lt;').replaceAll('>', '&gt;').replaceAll('"', '&quot;').replaceAll("'", '&#39;');
    }

    function timeSourceLabel(timeSource) { return String(timeSource || '').toLowerCase() === 'client' ? 'เวลาเครื่องสแกน' : 'เวลาเซิร์ฟเวอร์'; }
    function renderRecentScans(items) {
        if (!Array.isArray(items) || items.length === 0) {
            recentScansBody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">ยังไม่มีข้อมูล</td></tr>';
            if (recentScansCards) {
                recentScansCards.innerHTML = '<div class="text-center text-muted py-2">ยังไม่มีข้อมูล</div>';
            }
            return;
        }
        recentScansBody.innerHTML = items.map((item) => `
            <tr>
                <td class="text-nowrap">${new Date(item.scanTime).toLocaleString('th-TH')}</td>
                <td>${escapeHtml(item.studentCode || '-')}</td>
                <td class="text-nowrap">${escapeHtml(item.studentName || '-')}</td>
                <td class="text-nowrap">${escapeHtml(scanTypeLabel(item.scanType))}</td>
                <td>${formatConfidence(item.confidence)}</td>
                <td class="text-nowrap">${escapeHtml(providerLabel(item.provider, null, { showFallbackTag: false }) || '-')}</td>
            </tr>
        `).join('');

        if (recentScansCards) {
            recentScansCards.innerHTML = items.map((item) => `
                <article class="recent-scan-card">
                    <div class="recent-scan-meta">
                        <span class="scan-pill">${escapeHtml(scanTypeLabel(item.scanType))}</span>
                        <span class="scan-pill recent-scan-provider">${escapeHtml(providerLabel(item.provider, null, { showFallbackTag: false }) || '-')}</span>
                    </div>
                    <div class="recent-scan-name">${escapeHtml(item.studentName || '-')}</div>
                    <div class="recent-scan-code">รหัส ${escapeHtml(item.studentCode || '-')}</div>
                    <div class="recent-scan-detail">เวลา ${new Date(item.scanTime).toLocaleString('th-TH')}</div>
                    <div class="recent-scan-detail">ความมั่นใจ ${formatConfidence(item.confidence)}</div>
                </article>
