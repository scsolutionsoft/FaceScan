                    ${fallback ? '<div class="text-warning">ระบบกำลังใช้งานโหมดสำรองอัตโนมัติ</div>' : ''}
                    ${mapLink ? `<div><a class="link-primary" target="_blank" href="${mapLink}">ดูตำแหน่งที่สแกนในกูเกิลแมปส์</a></div>` : '<div class="text-muted">ไม่มีตำแหน่งจีพีเอส</div>'}
