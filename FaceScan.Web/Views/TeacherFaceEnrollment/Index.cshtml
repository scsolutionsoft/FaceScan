@model TeacherFaceEnrollmentIndexViewModel
@{
    ViewData["Title"] = "ลงทะเบียนใบหน้าครู";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">ลงทะเบียนใบหน้าครู</h2>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>ชื่อผู้ใช้</th>
                <th>ชื่อ-สกุล</th>
                <th>บทบาท</th>
                <th>ห้องที่รับผิดชอบ</th>
                <th>จำนวนรูป</th>
                <th>สถานะ</th>
                <th class="text-end">จัดการ</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Teachers.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">ไม่พบข้อมูลครูที่เปิดใช้งาน</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model.Teachers)
                {
                    <tr>
                        <td>@item.Username</td>
                        <td>@item.FullName</td>
                        <td>@item.RoleName</td>
                        <td>@item.AssignedClassroomName</td>
                        <td>@item.PhotoCount</td>
                        <td>
                            <span class="badge bg-secondary">@item.EnrollmentStatus.GetDisplayName()</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Upload" asp-route-teacherId="@item.TeacherId" class="btn btn-sm btn-primary">
                                จัดการใบหน้า
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
