@model StudentGuardianFormViewModel
@{
    var isEdit = Model.Id.HasValue;
    ViewData["Title"] = isEdit ? "แก้ไขข้อมูลครอบครัว" : "เพิ่มข้อมูลครอบครัว";
    var relationships = (IEnumerable<string>)(ViewBag.Relationships ?? Array.Empty<string>());
}

<div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
    <div>
        <h2 class="mb-1">@ViewData["Title"]</h2>
        <div class="text-muted">@Model.StudentCode - @Model.StudentName | ห้อง @Model.Classroom</div>
    </div>
    <a asp-action="Index" asp-route-studentId="@Model.StudentId" class="btn btn-outline-secondary">กลับรายการครอบครัว</a>
</div>

<form asp-action="@(isEdit ? "Edit" : "Create")" method="post" enctype="multipart/form-data" class="card">
    @Html.AntiForgeryToken()
    <input asp-for="Id" type="hidden" />
    <input asp-for="StudentId" type="hidden" />
    <input asp-for="StudentCode" type="hidden" />
    <input asp-for="StudentName" type="hidden" />
    <input asp-for="Classroom" type="hidden" />
    <input asp-for="CurrentPhotoPath" type="hidden" />

    <div class="card-header">ข้อมูลบิดา มารดา หรือผู้ปกครอง</div>
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        @if (Model.CopySources.Count > 0)
        {
            <div class="alert alert-light border d-flex flex-wrap align-items-end gap-2">
                <div class="flex-grow-1">
                    <label class="form-label" for="copyGuardianSource">คัดลอกจากข้อมูลบิดา/มารดา</label>
                    <select class="form-select" id="copyGuardianSource">
                        <option value="">เลือกข้อมูลที่ต้องการคัดลอก</option>
                        @foreach (var source in Model.CopySources)
                        {
                            <option value="@source.Id"
                                    data-full-name="@source.FullName"
                                    data-national-id="@source.NationalId"
                                    data-relationship="@source.Relationship"
                                    data-phone="@source.PhoneNumber"
                                    data-occupation="@source.Occupation"
                                    data-income="@source.MonthlyIncome"
                                    data-address="@source.Address"
                                    data-photo="@source.PhotoPath">
                                @source.Label
                            </option>
                        }
                    </select>
                </div>
                <button type="button" class="btn btn-outline-primary" id="copyGuardianButton">
                    <i class="bi bi-copy me-1"></i>ใช้ข้อมูลนี้
                </button>
            </div>
        }

        <div class="row g-3">
            <div class="col-lg-8">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label asp-for="Relationship" class="form-label">ประเภทข้อมูล</label>
                        <select asp-for="Relationship" class="form-select" id="Relationship">
                            <option value="">เลือกประเภท</option>
                            @foreach (var relationship in relationships)
                            {
                                <option value="@relationship" selected="@(Model.Relationship == relationship)">@relationship</option>
                            }
                        </select>
                        <span asp-validation-for="Relationship" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FullName" class="form-label">ชื่อ-สกุล</label>
                        <input asp-for="FullName" class="form-control" id="FullName" />
                        <span asp-validation-for="FullName" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="NationalId" class="form-label">เลขบัตรประจำตัวประชาชน</label>
                        <input asp-for="NationalId" class="form-control" inputmode="numeric" maxlength="20" id="NationalId" />
                        <span asp-validation-for="NationalId" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PhoneNumber" class="form-label">เบอร์โทรติดต่อ</label>
                        <input asp-for="PhoneNumber" class="form-control" inputmode="tel" id="PhoneNumber" />
                        <span asp-validation-for="PhoneNumber" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Occupation" class="form-label">อาชีพ</label>
                        <input asp-for="Occupation" class="form-control" id="Occupation" />
                        <span asp-validation-for="Occupation" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MonthlyIncome" class="form-label">รายได้ต่อเดือน</label>
                        <input asp-for="MonthlyIncome" class="form-control" type="number" step="0.01" id="MonthlyIncome" />
                        <span asp-validation-for="MonthlyIncome" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <label asp-for="Address" class="form-label">ที่อยู่</label>
                        <textarea asp-for="Address" class="form-control" rows="3" id="Address"></textarea>
                        <span asp-validation-for="Address" class="text-danger"></span>
                    </div>
                    <div class="col-12">
                        <div class="form-check form-switch">
                            <input asp-for="IsPrimaryContact" class="form-check-input" />
                            <label asp-for="IsPrimaryContact" class="form-check-label">ตั้งเป็นผู้ปกครองหลักของนักเรียน</label>
                        </div>
                        <div class="form-text">เมื่อเลือกเป็นผู้ปกครองหลัก ระบบจะอัปเดตชื่อ เลขบัตร และเบอร์ผู้ปกครองในแฟ้มนักเรียนให้ตรงกันทันที</div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <label asp-for="Photo" class="form-label">รูปบิดา/มารดา/ผู้ปกครอง</label>
                <input asp-for="Photo" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp,image/*" />
                <span asp-validation-for="Photo" class="text-danger"></span>
                <div class="mt-3">
                    @if (!string.IsNullOrWhiteSpace(Model.CurrentPhotoPath))
                    {
                        <img src="~/@Model.CurrentPhotoPath" class="rounded border w-100" style="max-height:260px;object-fit:cover" alt="guardian" />
                    }
                    else
                    {
                        <div class="rounded border bg-light d-flex align-items-center justify-content-center text-muted" style="height:220px;">
                            <div class="text-center">
                                <i class="bi bi-person-bounding-box fs-1"></i>
                                <div>ยังไม่มีรูป</div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="card-footer d-flex justify-content-end gap-2">
        <a asp-action="Index" asp-route-studentId="@Model.StudentId" class="btn btn-outline-secondary">ยกเลิก</a>
        <button type="submit" class="btn btn-primary">บันทึกข้อมูล</button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const sourceSelect = document.getElementById('copyGuardianSource');
            const copyButton = document.getElementById('copyGuardianButton');
            const setValue = (id, value) => {
                const input = document.getElementById(id);
                if (input) {
                    input.value = value || '';
                }
            };

            copyButton?.addEventListener('click', () => {
                const selected = sourceSelect?.selectedOptions[0];
                if (!selected || !selected.value) {
                    return;
                }

                setValue('FullName', selected.dataset.fullName);
                setValue('NationalId', selected.dataset.nationalId);
                setValue('PhoneNumber', selected.dataset.phone);
                setValue('Occupation', selected.dataset.occupation);
                setValue('MonthlyIncome', selected.dataset.income);
                setValue('Address', selected.dataset.address);
                setValue('Relationship', 'ผู้ปกครอง');
            });
        })();
    </script>
}
