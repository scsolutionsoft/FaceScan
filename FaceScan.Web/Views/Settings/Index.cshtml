@model SystemSettingsViewModel
@{
    ViewData["Title"] = "ตั้งค่าระบบและแบรนด์";
    var academicYears = ViewBag.AcademicYears as IReadOnlyList<SelectOptionViewModel> ?? [];
    var periodItems = Model.Periods.Count > 0
        ? Model.Periods
        : [new PeriodVisibilityItemViewModel { SortOrder = 1, IsVisibleForCheck = true }];
    var logoPath = string.IsNullOrWhiteSpace(Model.CurrentLogoPath)
        ? Url.Content("~/img/facescan-mark.svg")
        : Url.Content($"~/{Model.CurrentLogoPath}");
}

<div class="card">
    <div class="card-header d-flex flex-column flex-lg-row justify-content-between gap-2">
        <div>
            <h2 class="mb-1">ตั้งค่าระบบ แบรนด์ และคาบเรียน</h2>
            <div class="text-muted small">แอดมินสามารถกำหนดเวลาเรียน เพิ่ม แก้ไข ลบคาบเรียน และปรับโลโก้ ชื่อโปรแกรม สีธีมได้จากหน้านี้</div>
        </div>
        <div class="text-muted small align-self-lg-center">ค่าเริ่มต้นแนะนำ: สีม่วง ขาว โทนสว่าง</div>
    </div>

    <div class="card-body row g-4">
        <div class="col-12">
            <form asp-action="SaveBranding" method="post" enctype="multipart/form-data" class="border rounded-4 p-3 p-lg-4" id="brandingSettings">
                @Html.AntiForgeryToken()
                <input asp-for="CurrentLogoPath" type="hidden" />

                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="d-flex flex-column flex-lg-row justify-content-between gap-2 mb-3">
                    <div>
                        <h4 class="mb-1">แบรนด์และธีม</h4>
                        <div class="text-muted small">เปลี่ยนโลโก้ ชื่อโปรแกรม ข้อความกำกับ และโทนสีที่ใช้ทั้งระบบ</div>
                    </div>
                </div>

                <div class="row g-3 align-items-start">
                    <div class="col-lg-3">
                        <label class="form-label fw-semibold">โลโก้ปัจจุบัน</label>
                        <div class="border rounded-4 bg-light p-3 text-center h-100">
                            <img src="@logoPath" alt="Logo Preview" class="img-fluid mb-3" style="max-height: 96px; object-fit: contain;" />
                            <div class="small text-muted">ถ้าไม่อัปโหลดใหม่ ระบบจะใช้โลโก้เดิมต่อไป</div>
                        </div>
                    </div>

                    <div class="col-lg-9">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label asp-for="ApplicationDisplayName" class="form-label">ชื่อโปรแกรม</label>
                                <input asp-for="ApplicationDisplayName" class="form-control" />
                                <span asp-validation-for="ApplicationDisplayName" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="SchoolName" class="form-label">ชื่อโรงเรียน</label>
                                <input asp-for="SchoolName" class="form-control" />
                                <span asp-validation-for="SchoolName" class="text-danger"></span>
                            </div>

                            <div class="col-12">
                                <label asp-for="ApplicationTagline" class="form-label">คำอธิบายใต้ชื่อโปรแกรม</label>
                                <input asp-for="ApplicationTagline" class="form-control" />
                                <span asp-validation-for="ApplicationTagline" class="text-danger"></span>
                            </div>

                            <div class="col-md-8">
                                <label asp-for="LogoFile" class="form-label">อัปโหลดโลโก้ใหม่</label>
                                <input asp-for="LogoFile" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                                <div class="form-text">รองรับไฟล์ JPG, PNG, WEBP</div>
                            </div>

                            <div class="col-md-4 d-flex align-items-end">
                                <div class="form-check mb-2">
                                    <input asp-for="RemoveCurrentLogo" class="form-check-input" />
                                    <label asp-for="RemoveCurrentLogo" class="form-check-label">ลบโลโก้ที่ตั้งไว้และใช้โลโก้เดิมของระบบ</label>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="row g-3">
                    <div class="col-md-4 col-xl-3">
                        <label asp-for="ThemePrimaryColor" class="form-label">สีหลัก</label>
                        <input asp-for="ThemePrimaryColor" type="color" class="form-control form-control-color w-100" />
                        <div class="small text-muted mt-1">@Model.ThemePrimaryColor</div>
                        <span asp-validation-for="ThemePrimaryColor" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label asp-for="ThemePrimarySoftColor" class="form-label">สีรอง</label>
                        <input asp-for="ThemePrimarySoftColor" type="color" class="form-control form-control-color w-100" />
                        <div class="small text-muted mt-1">@Model.ThemePrimarySoftColor</div>
                        <span asp-validation-for="ThemePrimarySoftColor" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label asp-for="ThemeAccentColor" class="form-label">สีเน้น</label>
                        <input asp-for="ThemeAccentColor" type="color" class="form-control form-control-color w-100" />
                        <div class="small text-muted mt-1">@Model.ThemeAccentColor</div>
                        <span asp-validation-for="ThemeAccentColor" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label asp-for="ThemeBackgroundColor" class="form-label">สีพื้นหลัง</label>
                        <input asp-for="ThemeBackgroundColor" type="color" class="form-control form-control-color w-100" />
                        <div class="small text-muted mt-1">@Model.ThemeBackgroundColor</div>
                        <span asp-validation-for="ThemeBackgroundColor" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label asp-for="ThemeSurfaceColor" class="form-label">สีพื้นการ์ด</label>
                        <input asp-for="ThemeSurfaceColor" type="color" class="form-control form-control-color w-100" />
                        <div class="small text-muted mt-1">@Model.ThemeSurfaceColor</div>
                        <span asp-validation-for="ThemeSurfaceColor" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label asp-for="ThemeSidebarStartColor" class="form-label">สีเมนูด้านซ้าย</label>
                        <input asp-for="ThemeSidebarStartColor" type="color" class="form-control form-control-color w-100" />
                        <div class="small text-muted mt-1">@Model.ThemeSidebarStartColor</div>
                        <span asp-validation-for="ThemeSidebarStartColor" class="text-danger"></span>
                    </div>
                    <div class="col-md-4 col-xl-3">
                        <label asp-for="ThemeSidebarEndColor" class="form-label">สีไล่เมนูด้านซ้าย</label>
                        <input asp-for="ThemeSidebarEndColor" type="color" class="form-control form-control-color w-100" />
                        <div class="small text-muted mt-1">@Model.ThemeSidebarEndColor</div>
                        <span asp-validation-for="ThemeSidebarEndColor" class="text-danger"></span>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="btn btn-primary px-4">บันทึกแบรนด์และธีม</button>
                </div>
            </form>
        </div>

        <div class="col-12">
            <form asp-action="SaveGeneral" method="post" class="border rounded-4 p-3 p-lg-4" id="generalSettings">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <h4 class="mb-1">ตั้งค่าการทำงานทั่วไป</h4>
                <div class="text-muted small mb-3">กำหนดเวลาเริ่มนับมาสาย การเช็คกลับ และค่าการสแกนของระบบ</div>

                <div class="row g-3">
                    <div class="col-md-3">
                        <label asp-for="DuplicateWindowMinutes" class="form-label">ช่วงเวลาป้องกันสแกนซ้ำ (นาที)</label>
                        <input asp-for="DuplicateWindowMinutes" class="form-control" />
                        <span asp-validation-for="DuplicateWindowMinutes" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="LateAfterTime" class="form-label">เวลาเริ่มนับมาสาย</label>
                        <input asp-for="LateAfterTime" class="form-control" placeholder="08:00" />
                        <span asp-validation-for="LateAfterTime" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="CheckOutStartTime" class="form-label">เวลาเริ่มเช็คกลับ</label>
                        <input asp-for="CheckOutStartTime" class="form-control" placeholder="15:30" />
                        <span asp-validation-for="CheckOutStartTime" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="FaceConfidenceThreshold" class="form-label">เกณฑ์ความมั่นใจใบหน้า</label>
                        <input asp-for="FaceConfidenceThreshold" class="form-control" />
                        <span asp-validation-for="FaceConfidenceThreshold" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TeacherLateAfterTime" class="form-label">ครู: เวลาเริ่มนับมาสาย</label>
                        <input asp-for="TeacherLateAfterTime" class="form-control" placeholder="08:00" />
                        <span asp-validation-for="TeacherLateAfterTime" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="TeacherCheckOutStartTime" class="form-label">ครู: เวลาเริ่มเช็คกลับ</label>
                        <input asp-for="TeacherCheckOutStartTime" class="form-control" placeholder="15:30" />
                        <span asp-validation-for="TeacherCheckOutStartTime" class="text-danger"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="AcademicYearCurrentId" class="form-label">ปีการศึกษาปัจจุบัน</label>
                        <select asp-for="AcademicYearCurrentId" class="form-select">
                            <option value="">-- เลือก --</option>
                            @foreach (var year in academicYears)
                            {
                                <option value="@year.Value">@year.Text</option>
                            }
                        </select>
                    </div>

                    <div class="col-md-3 d-flex align-items-center">
                        <div class="form-check mt-4">
                            <input asp-for="SaveSnapshots" class="form-check-input" />
                            <label asp-for="SaveSnapshots" class="form-check-label">บันทึกภาพสแนปช็อตตอนสแกน</label>
                        </div>
                    </div>

                    <div class="col-md-3 d-flex align-items-center">
                        <div class="form-check mt-2 mt-md-4">
                            <input asp-for="AllowManualOverride" class="form-check-input" />
                            <label asp-for="AllowManualOverride" class="form-check-label">อนุญาตแก้ไขข้อมูลด้วยมือ</label>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="btn btn-primary px-4">บันทึกการตั้งค่าทั่วไป</button>
                </div>
            </form>
        </div>

        <div class="col-12">
            <form asp-action="SavePeriods" method="post" class="border rounded-4 p-3 p-lg-4" id="periodSettings">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="d-flex flex-column flex-lg-row justify-content-between gap-2 mb-3">
                    <div>
                        <h4 class="mb-1">กำหนดคาบเรียน</h4>
                        <div class="text-muted small">เพิ่ม แก้ไข ลบคาบเรียน และกำหนดเวลาเริ่ม-สิ้นสุดได้จากตารางนี้</div>
                    </div>
                    <button type="button" class="btn btn-outline-primary align-self-start" id="addPeriodRow">
                        <i class="bi bi-plus-circle me-1"></i> เพิ่มคาบเรียน
                    </button>
                </div>

                <div class="alert alert-light border small mb-3">
                    ถ้าคาบเรียนเคยมีข้อมูลเช็คแล้ว ระบบจะไม่ยอมลบเพื่อป้องกันรายงานเก่าเสียหาย แต่ยังแก้ไขชื่อ เวลา และการเปิดใช้ได้
                </div>

                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th style="min-width: 140px;">ลำดับ</th>
                                <th style="min-width: 220px;">ชื่อคาบเรียน</th>
                                <th style="min-width: 150px;">เริ่ม</th>
                                <th style="min-width: 150px;">สิ้นสุด</th>
                                <th style="min-width: 160px;">เปิดให้เช็ค</th>
                                <th style="min-width: 120px;">จัดการ</th>
                            </tr>
                        </thead>
                        <tbody id="periodRows" data-period-body>
                            @for (var i = 0; i < periodItems.Count; i++)
                            {
                                var item = periodItems[i];
                                <tr data-period-row>
                                    <td>
                                        <input type="hidden" name="Periods[@i].Id" value="@item.Id" data-period-field data-name="Periods[__index__].Id" data-period-id />
                                        <input type="hidden" name="Periods[@i].MarkedForDeletion" value="false" data-period-field data-name="Periods[__index__].MarkedForDeletion" data-period-delete />
                                        <input type="number" min="1" class="form-control" name="Periods[@i].SortOrder" value="@item.SortOrder" data-period-field data-name="Periods[__index__].SortOrder" />
                                    </td>
                                    <td>
                                        <input type="text" maxlength="80" class="form-control" name="Periods[@i].Name" value="@item.Name" data-period-field data-name="Periods[__index__].Name" placeholder="เช่น คาบ 1" />
                                    </td>
                                    <td>
                                        <input type="time" class="form-control" name="Periods[@i].StartTime" value="@item.StartTime" data-period-field data-name="Periods[__index__].StartTime" />
                                    </td>
                                    <td>
                                        <input type="time" class="form-control" name="Periods[@i].EndTime" value="@item.EndTime" data-period-field data-name="Periods[__index__].EndTime" />
                                    </td>
                                    <td>
                                        <input type="hidden" name="Periods[@i].IsVisibleForCheck" value="false" data-period-field data-name="Periods[__index__].IsVisibleForCheck" />
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input" name="Periods[@i].IsVisibleForCheck" value="true" checked="@item.IsVisibleForCheck" data-period-field data-name="Periods[__index__].IsVisibleForCheck" />
                                            <label class="form-check-label">แสดงในหน้าครู</label>
                                        </div>
                                    </td>
                                    <td>
                                        <button type="button" class="btn btn-outline-danger btn-sm" data-period-remove>
                                            <i class="bi bi-trash3 me-1"></i> ลบ
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <button type="submit" class="btn btn-primary px-4">บันทึกคาบเรียน</button>
                </div>
            </form>
        </div>
    </div>
</div>

<template id="periodRowTemplate">
    <tr data-period-row>
        <td>
            <input type="hidden" name="Periods[__index__].Id" value="0" data-period-field data-name="Periods[__index__].Id" data-period-id />
            <input type="hidden" name="Periods[__index__].MarkedForDeletion" value="false" data-period-field data-name="Periods[__index__].MarkedForDeletion" data-period-delete />
            <input type="number" min="1" class="form-control" name="Periods[__index__].SortOrder" value="1" data-period-field data-name="Periods[__index__].SortOrder" />
        </td>
        <td>
            <input type="text" maxlength="80" class="form-control" name="Periods[__index__].Name" value="" data-period-field data-name="Periods[__index__].Name" placeholder="เช่น คาบ 1" />
        </td>
        <td>
            <input type="time" class="form-control" name="Periods[__index__].StartTime" value="" data-period-field data-name="Periods[__index__].StartTime" />
        </td>
        <td>
            <input type="time" class="form-control" name="Periods[__index__].EndTime" value="" data-period-field data-name="Periods[__index__].EndTime" />
        </td>
        <td>
            <input type="hidden" name="Periods[__index__].IsVisibleForCheck" value="false" data-period-field data-name="Periods[__index__].IsVisibleForCheck" />
            <div class="form-check">
                <input type="checkbox" class="form-check-input" name="Periods[__index__].IsVisibleForCheck" value="true" checked data-period-field data-name="Periods[__index__].IsVisibleForCheck" />
                <label class="form-check-label">แสดงในหน้าครู</label>
            </div>
        </td>
        <td>
            <button type="button" class="btn btn-outline-danger btn-sm" data-period-remove>
                <i class="bi bi-trash3 me-1"></i> ลบ
            </button>
        </td>
    </tr>
</template>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const body = document.querySelector('[data-period-body]');
            const template = document.getElementById('periodRowTemplate');
            const addButton = document.getElementById('addPeriodRow');

            if (!body || !template || !addButton) {
                return;
            }

            const reindexRows = () => {
                const rows = body.querySelectorAll('[data-period-row]');
                rows.forEach((row, index) => {
                    row.querySelectorAll('[data-period-field]').forEach((field) => {
                        const templateName = field.dataset.name;
                        if (!templateName) {
                            return;
                        }

                        field.name = templateName.replaceAll('__index__', index);
                    });

                    const orderInput = row.querySelector('input[data-name="Periods[__index__].SortOrder"]');
                    if (orderInput && (!orderInput.value || Number(orderInput.value) <= 0)) {
                        orderInput.value = index + 1;
                    }
                });
            };

            const removeRow = (button) => {
                const row = button.closest('[data-period-row]');
                if (!row) {
                    return;
                }

                const idInput = row.querySelector('[data-period-id]');
                const deleteInput = row.querySelector('[data-period-delete]');
                const isExisting = idInput && Number(idInput.value) > 0;

                if (isExisting && deleteInput) {
                    deleteInput.value = 'true';
                    row.hidden = true;
                } else {
                    row.remove();
                }

                reindexRows();
            };

            addButton.addEventListener('click', () => {
                const fragment = template.content.cloneNode(true);
                body.appendChild(fragment);
                reindexRows();
            });

            body.addEventListener('click', (event) => {
                const trigger = event.target.closest('[data-period-remove]');
                if (!trigger) {
                    return;
                }

                removeRow(trigger);
            });

            reindexRows();
        })();
    </script>
}
