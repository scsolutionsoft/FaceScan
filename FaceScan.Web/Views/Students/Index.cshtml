@model StudentIndexViewModel
@{
    ViewData["Title"] = "นักเรียน";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">นักเรียน</h2>
    <a asp-action="Create" class="btn btn-primary">เพิ่มนักเรียน</a>
</div>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <input class="form-control" name="SearchText" value="@Model.Filter.SearchText" placeholder="ค้นหา รหัส/ชื่อ/เลขบัตร" />
    </div>
    <div class="col-md-2">
        <select class="form-select" name="AcademicYearId">
            <option value="">ปีการศึกษา</option>
            @foreach (var item in Model.AcademicYears)
            {
                <option value="@item.Value" selected="@(Model.Filter.AcademicYearId == item.Value ? "selected" : null)">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" name="GradeLevelId">
            <option value="">ระดับชั้น</option>
            @foreach (var item in Model.GradeLevels)
            {
                <option value="@item.Value" selected="@(Model.Filter.GradeLevelId == item.Value ? "selected" : null)">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <select class="form-select" name="ClassroomId">
            <option value="">ห้อง</option>
            @foreach (var item in Model.Classrooms)
            {
                <option value="@item.Value" selected="@(Model.Filter.ClassroomId == item.Value ? "selected" : null)">@item.Text</option>
            }
        </select>
    </div>
    <div class="col-md-1">
        <input type="number" class="form-control" name="PageSize" value="@Model.Filter.PageSize" min="5" max="100" />
    </div>
    <div class="col-md-2 d-flex gap-2">
        <button type="submit" class="btn btn-outline-primary w-100">ค้นหา</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead>
            <tr>
                <th>รหัส</th>
                <th>ชื่อ-สกุล</th>
                <th>ปีการศึกษา</th>
                <th>ชั้น</th>
                <th>ห้อง</th>
                <th>สถานะใบหน้า</th>
                <th>สถานะ</th>
                <th class="text-end">จัดการ</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Students.Count == 0)
            {
                <tr><td colspan="8" class="text-center text-muted">ไม่พบข้อมูล</td></tr>
            }
            else
            {
                @foreach (var student in Model.Students)
                {
                    <tr>
                        <td>@student.StudentCode</td>
                        <td>@student.FullName</td>
                        <td>@student.AcademicYearName</td>
                        <td>@student.GradeLevelName</td>
                        <td>@student.ClassroomName</td>
                        <td><span class="badge bg-secondary">@student.EnrollmentStatus.GetDisplayName()</span></td>
                        <td>
                            @if (student.IsActive)
                            {
                                <span class="badge bg-success">ใช้งาน</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">ปิดใช้งาน</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@student.Id" class="btn btn-sm btn-outline-info">รายละเอียด</a>
                            <a asp-action="Edit" asp-route-id="@student.Id" class="btn btn-sm btn-outline-primary">แก้ไข</a>
                            <a asp-controller="StudentGuardians" asp-action="Index" asp-route-studentId="@student.Id" class="btn btn-sm btn-outline-success">ครอบครัว</a>
                            <form asp-action="Delete" asp-route-id="@student.Id" method="post" class="d-inline" onsubmit="return confirm('ยืนยันปิดการใช้งาน?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">ปิดใช้งาน</button>
                            </form>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@{
    var totalPages = (int)Math.Ceiling((double)Model.TotalCount / Math.Max(Model.Filter.PageSize, 1));
    var currentPage = Math.Max(Model.Filter.Page, 1);
}
@if (totalPages > 1)
{
    <nav>
        <ul class="pagination">
            @for (var i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-Page="@i"
                       asp-route-PageSize="@Model.Filter.PageSize"
                       asp-route-SearchText="@Model.Filter.SearchText"
                       asp-route-AcademicYearId="@Model.Filter.AcademicYearId"
                       asp-route-GradeLevelId="@Model.Filter.GradeLevelId"
                       asp-route-ClassroomId="@Model.Filter.ClassroomId">@i</a>
                </li>
            }
        </ul>
    </nav>
}
