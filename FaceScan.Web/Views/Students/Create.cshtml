@model StudentUpsertViewModel
@{
    ViewData["Title"] = "เพิ่มนักเรียน";
}

<h2 class="mb-3">เพิ่มนักเรียน</h2>

<form asp-action="Create" method="post" class="card">
    <div class="card-body">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
        <partial name="_StudentForm" model="Model" />
    </div>
    <div class="card-footer d-flex gap-2">
        <button type="submit" class="btn btn-primary">บันทึก</button>
        <a asp-action="Index" class="btn btn-outline-secondary">ยกเลิก</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
