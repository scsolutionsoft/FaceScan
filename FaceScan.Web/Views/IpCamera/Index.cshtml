    if (MINIMAL_MODE) {
        document.body.classList.add('minimal-mode');
    }

    function updateFullscreenButtonText() {
        kioskFullscreenBtn.innerHTML = document.fullscreenElement
            ? '<i class="bi bi-fullscreen-exit"></i> ออกจากเต็มจอ'
            : '<i class="bi bi-arrows-fullscreen"></i> เต็มจอ';
    }

    async function toggleFullscreen() {
        if (!document.fullscreenElement) {
            await document.documentElement.requestFullscreen();
        } else {
            await document.exitFullscreen();
        }
        updateFullscreenButtonText();
    }

    function hideKioskStartOverlay() {
        kioskStartOverlay.style.display = 'none';
    }

    function armAutoFullscreenOnFirstInteraction() {
        if (!KIOSK_MODE || !AUTO_FULLSCREEN || autoFsAttempted || document.fullscreenElement) {
            return;
        }

        const onFirstInteraction = async () => {
            if (autoFsAttempted || document.fullscreenElement) {
                return;
            }

            autoFsAttempted = true;
            try {
                await toggleFullscreen();
            } catch {
                kioskFullscreenBtn.innerHTML = '<i class="bi bi-exclamation-circle"></i> เบราว์เซอร์บล็อกเต็มจอ';
            } finally {
                hideKioskStartOverlay();
                document.removeEventListener('pointerdown', onFirstInteraction, true);
                document.removeEventListener('keydown', onFirstInteraction, true);
            }
        };

        document.addEventListener('pointerdown', onFirstInteraction, true);
        document.addEventListener('keydown', onFirstInteraction, true);
    }

    if (KIOSK_MODE) {
        document.body.classList.add('kiosk-mode');

        kioskFullscreenBtn.addEventListener('click', async () => {
            try {
                await toggleFullscreen();
            } catch {
                kioskFullscreenBtn.innerHTML = '<i class="bi bi-exclamation-circle"></i> เบราว์เซอร์บล็อกเต็มจอ';
            }
        });

        kioskStartBtn.addEventListener('click', async () => {
            try {
                await toggleFullscreen();
            } catch {
                kioskFullscreenBtn.innerHTML = '<i class="bi bi-exclamation-circle"></i> เบราว์เซอร์บล็อกเต็มจอ';
            } finally {
                hideKioskStartOverlay();
            }
        });

        kioskSkipBtn.addEventListener('click', () => {
            hideKioskStartOverlay();
        });

        document.addEventListener('fullscreenchange', updateFullscreenButtonText);
        updateFullscreenButtonText();

        if (AUTO_FULLSCREEN) {
            kioskStartOverlay.querySelector('.kiosk-start-sub').textContent = 'แตะครั้งแรกบนหน้าจอเพื่อเข้าสู่โหมดเต็มจออัตโนมัติ';
            armAutoFullscreenOnFirstInteraction();
        }
    }

    // Clock
    function updateClock() {
        const now = new Date();
        clock.textContent = now.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    }
    updateClock();
    setInterval(updateClock, 1000);

    function setStatus(state, text) {
        statusPill.className = 'status-pill ' + state;
        statusTxt.textContent = text;
    }

    function renderPipelineHealth() {
        if (pageModule && typeof pageModule.renderPipelineHealth === 'function') {
            pageModule.renderPipelineHealth({ videoHealth, detectHealth, matchHealth }, pipelineHealthState);
            return;
        }

        const renderFallback = (el, state) => {
            if (!el || !state) {
                return;
            }
            el.classList.remove('ok', 'warn', 'bad');
            el.classList.add(state.level || 'warn');
            const labelEl = el.querySelector('strong');
            if (labelEl) {
                labelEl.textContent = state.text || '-';
            }
        };

        renderFallback(videoHealth, pipelineHealthState.video);
        renderFallback(detectHealth, pipelineHealthState.detect);
        renderFallback(matchHealth, pipelineHealthState.match);
    }

    function setPipelineHealth(kind, level, text) {
        if (!pipelineHealthState[kind]) {
            return;
        }

        pipelineHealthState[kind] = { level, text };
        renderPipelineHealth();
    }

    function updateMatchPipelineHealth() {
        if (pageModule && typeof pageModule.getMatchPipelineState === 'function') {
            const state = pageModule.getMatchPipelineState(activeWorkers, verifyQueue.length, QUEUE_MAX_ITEMS);
            setPipelineHealth('match', state.level, state.text);
            return;
        }

        const serverPending = Number.isFinite(latestQueuePending) ? latestQueuePending : 0;
        if (activeWorkers > 0 || verifyQueue.length > 0 || serverPending > 0) {
            const queueText = `q:${verifyQueue.length}/${serverPending} w:${activeWorkers}`;
            const overloaded = verifyQueue.length >= Math.max(6, Math.floor(QUEUE_MAX_ITEMS * 0.6))
                || serverPending >= 8
                || queueRejectedDelta > 0
                || queueTimeoutDelta > 0;
            if (overloaded) {
                setPipelineHealth('match', 'bad', queueText);
            } else {
                setPipelineHealth('match', 'warn', queueText);
            }
            return;
        }

        setPipelineHealth('match', 'ok', 'idle');
    }

    function getScanEngineLabel() {
        return selScanEngine.value === 'buffered' ? 'คิวบัฟเฟอร์' : 'คลาสสิก';
    }

    function applyViewMode(mode, silent = false) {
        const normalized = FORCE_CONTAIN_MODE ? 'contain' : (mode === 'cover' ? 'cover' : 'contain');
        selViewMode.value = normalized;
        localStorage.setItem(viewModeStorageKey, normalized);
        camImg.style.objectFit = normalized;
        autoFitCameraImage(latestFrameWidth, latestFrameHeight);
        if (!silent) {
            setStatus('waiting', normalized === 'cover' ? 'โหมดเต็มพื้นที่ (crop เล็กน้อย)' : 'โหมดเห็นครบเฟรม');
        }
    }

    function applyPresetLockState() {
        const fullLock = !!chkFullConfigLock.checked;
        selPreset.disabled = !!chkPresetLock.checked || fullLock;
        selPreset.title = chkPresetLock.checked ? 'Locked by Lock Preset' : 'Performance Preset';

        selCctvProfile.disabled = fullLock;
        selResolution.disabled = fullLock;
        selDisplayFps.disabled = fullLock;
        selAnalysisFps.disabled = fullLock;
        selFacePolicy.disabled = fullLock;
        selScanEngine.disabled = fullLock;
        chkAdaptiveStream.disabled = fullLock;
        chkPreviewPriority.disabled = fullLock;

        if (fullLock) {
            selPreset.title = 'Locked by Lock Full Config';
        }
    }

    function appendFpsHistory(displayFps, analysisFps) {
        if (!Number.isFinite(displayFps) || !Number.isFinite(analysisFps)) {
            return;
        }

        displayFpsHistory.push(displayFps);
        analysisFpsHistory.push(analysisFps);
        if (displayFpsHistory.length > fpsHistoryMaxPoints) {
            displayFpsHistory.shift();
            analysisFpsHistory.shift();
        }
    }

    function drawFpsSparkline() {
        if (!fpsSparkCtx || !fpsSparkline || displayFpsHistory.length < 2 || analysisFpsHistory.length < 2) {
            return;
        }

        const width = fpsSparkline.width;
        const height = fpsSparkline.height;
        fpsSparkCtx.clearRect(0, 0, width, height);

        const maxFps = Math.max(10, ...displayFpsHistory, ...analysisFpsHistory);
        const minFps = 0;
        const range = Math.max(1, maxFps - minFps);
        const points = displayFpsHistory.length;
        const xStep = points > 1 ? (width - 2) / (points - 1) : width;

        const yFromFps = (fps) => {
            const normalized = (fps - minFps) / range;
            return (height - 2) - (normalized * (height - 4));
        };

        fpsSparkCtx.strokeStyle = 'rgba(148,163,184,0.28)';
        fpsSparkCtx.lineWidth = 1;
        fpsSparkCtx.beginPath();
        fpsSparkCtx.moveTo(0, yFromFps(maxFps * 0.5));
        fpsSparkCtx.lineTo(width, yFromFps(maxFps * 0.5));
        fpsSparkCtx.stroke();

        const warnFps = 1000 / LATENCY_ALERT_MS;
        const criticalFps = 1000 / LATENCY_CRITICAL_MS;
        const drawThreshold = (fps, color) => {
            const y = yFromFps(fps);
            fpsSparkCtx.save();
            fpsSparkCtx.setLineDash([4, 3]);
            fpsSparkCtx.strokeStyle = color;
            fpsSparkCtx.lineWidth = 1;
            fpsSparkCtx.beginPath();
            fpsSparkCtx.moveTo(0, y);
            fpsSparkCtx.lineTo(width, y);
            fpsSparkCtx.stroke();
            fpsSparkCtx.restore();
        };
        drawThreshold(warnFps, 'rgba(250,204,21,0.55)');
        drawThreshold(criticalFps, 'rgba(248,113,113,0.6)');

        const drawSeries = (series, color) => {
            fpsSparkCtx.strokeStyle = color;
            fpsSparkCtx.lineWidth = 1.8;
            fpsSparkCtx.beginPath();
            for (let i = 0; i < series.length; i++) {
                const x = i * xStep;
                const y = yFromFps(series[i]);
                if (i === 0) {
                    fpsSparkCtx.moveTo(x, y);
                } else {
                    fpsSparkCtx.lineTo(x, y);
                }
            }
            fpsSparkCtx.stroke();
        };

        drawSeries(displayFpsHistory, '#22c55e');
        drawSeries(analysisFpsHistory, '#38bdf8');
    }

    function updateLatencyHealthUi() {
        const analysisMs = avgAnalysisMs || 0;
        const loopMs = avgLoopMs || 0;
        const isCritical = analysisMs >= LATENCY_CRITICAL_MS || loopMs >= (LATENCY_CRITICAL_MS + 200);
        const isWarn = !isCritical && (analysisMs >= LATENCY_ALERT_MS || loopMs >= (LATENCY_ALERT_MS + 200));
        const criticalSecs = getCriticalDurationSeconds();

        if (fpsChartWrap) {
            fpsChartWrap.style.borderColor = isCritical ? '#ef4444' : (isWarn ? '#f59e0b' : '#334155');
            fpsChartWrap.style.boxShadow = isCritical
                ? '0 0 0 1px rgba(239,68,68,0.28) inset'
                : (isWarn ? '0 0 0 1px rgba(245,158,11,0.22) inset' : 'none');
        }

        if (fpsHealthText) {
            if (isCritical) {
                fpsHealthText.textContent = `สถานะกราฟ: หน่วงสูง critical ต่อเนื่อง ${criticalSecs}s (analysis ~${Math.round(analysisMs)} ms)`;
                fpsHealthText.style.color = '#fca5a5';
            } else if (isWarn) {
                fpsHealthText.textContent = `สถานะกราฟ: เริ่มหน่วง (analysis ~${Math.round(analysisMs)} ms)`;
                fpsHealthText.style.color = '#fcd34d';
            } else {
                fpsHealthText.textContent = 'สถานะกราฟ: ปกติ';
                fpsHealthText.style.color = '#86efac';
            }
        }
    }

    function updateCriticalDurationState() {
        const criticalNow = (avgAnalysisMs >= LATENCY_CRITICAL_MS) || (avgLoopMs >= (LATENCY_CRITICAL_MS + 200));
        if (criticalNow) {
            if (!criticalSinceAt) {
                criticalSinceAt = Date.now();
            }
            lastCriticalSeconds = Math.max(1, Math.floor((Date.now() - criticalSinceAt) / 1000));
        } else {
            criticalSinceAt = 0;
            lastCriticalSeconds = 0;
        }
    }

    function getCriticalDurationSeconds() {
        return lastCriticalSeconds;
    }

    function shouldRunAnalysisNow() {
        if (!LIVE_STREAM_ENABLED) {
            return true;
        }

        const now = Date.now();
        let minGapMs = getStreamAnalysisDelayMs();
        const criticalNow = (avgAnalysisMs >= LATENCY_CRITICAL_MS) || (avgLoopMs >= (LATENCY_CRITICAL_MS + 200));
        const warnNow = !criticalNow && ((avgAnalysisMs >= LATENCY_ALERT_MS) || (avgLoopMs >= (LATENCY_ALERT_MS + 200)));

        if (chkPreviewPriority.checked) {
            if (criticalNow) {
                minGapMs += PREVIEW_PRIORITY_CRITICAL_EXTRA_DELAY_MS;
            } else if (warnNow) {
                minGapMs += PREVIEW_PRIORITY_WARN_EXTRA_DELAY_MS;
            }
        }

        if ((now - lastAnalysisQueuedAt) < minGapMs) {
            return false;
        }

        lastAnalysisQueuedAt = now;
        return true;
    }

    function maybeAutoSwitchPresetForLatency() {
        if (!LIVE_STREAM_ENABLED || !chkAdaptiveStream.checked || chkPresetLock.checked || chkFullConfigLock.checked) {
            highLatencyStreak = 0;
            lowLatencyRecoveryStreak = 0;
            return false;
        }

        const now = Date.now();
        const overloaded = avgAnalysisMs >= LATENCY_CRITICAL_MS || avgLoopMs >= (LATENCY_CRITICAL_MS + 120) || verifyQueue.length >= 4;
        const recovered = avgAnalysisMs > 0 && avgAnalysisMs <= 950 && avgLoopMs > 0 && avgLoopMs <= 980 && verifyQueue.length === 0;

        if (overloaded) {
            highLatencyStreak++;
            lowLatencyRecoveryStreak = 0;
        } else if (recovered) {
            lowLatencyRecoveryStreak++;
            highLatencyStreak = 0;
        } else {
            highLatencyStreak = Math.max(0, highLatencyStreak - 1);
            lowLatencyRecoveryStreak = Math.max(0, lowLatencyRecoveryStreak - 1);
        }

        if (
            highLatencyStreak >= LATENCY_AUTO_PRESET_STREAK_REQUIRED
            && selPreset.value !== 'lowlatency'
            && (now - autoPresetLastChangedAt) >= LATENCY_AUTO_PRESET_SWITCH_COOLDOWN_MS
        ) {
            selPreset.value = 'lowlatency';
            applyPerformancePreset('lowlatency', true);
            autoPresetLastChangedAt = now;
            highLatencyStreak = 0;
            setStatus('waiting', 'หน่วงสูงต่อเนื่อง: ปรับเป็น Preset หน่วงต่ำอัตโนมัติ');
            latencyTune.textContent = 'Adaptive Recovery: สลับ Preset เป็นหน่วงต่ำเพื่อลด latency';
            return true;
        }

        if (
            lowLatencyRecoveryStreak >= LATENCY_AUTO_PRESET_RECOVERY_REQUIRED
            && selPreset.value === 'lowlatency'
            && (now - autoPresetLastChangedAt) >= LATENCY_AUTO_PRESET_SWITCH_COOLDOWN_MS
        ) {
            selPreset.value = 'balanced';
            applyPerformancePreset('balanced', true);
            autoPresetLastChangedAt = now;
            lowLatencyRecoveryStreak = 0;
            setStatus('waiting', 'ระบบกลับมานิ่ง: ปรับเป็น Preset สมดุลอัตโนมัติ');
            latencyTune.textContent = 'Adaptive Recovery: คืน Preset สมดุลหลังระบบนิ่ง';
            return true;
        }

        return false;
    }

    function updatePerformanceMetrics() {
        updateCriticalDurationState();
        let displayFps = NaN;
        if (avgPreviewFrameMs > 0) {
            displayFps = 1000 / avgPreviewFrameMs;
            previewFpsValue.textContent = displayFps.toFixed(1);
        } else {
            previewFpsValue.textContent = '-';
        }

        let analysisFps = NaN;
        if (avgAnalysisMs > 0) {
            analysisFps = 1000 / avgAnalysisMs;
            analysisFpsValue.textContent = analysisFps.toFixed(1);
        } else {
            analysisFps = getCurrentAnalysisFps();
            analysisFpsValue.textContent = `${analysisFps}`;
        }

        if (avgAnalysisMs > 0) {
            analysisLatencyValue.textContent = `${Math.round(avgAnalysisMs)} ms`;
        } else {
            analysisLatencyValue.textContent = '- ms';
        }

        appendFpsHistory(displayFps, analysisFps);
        drawFpsSparkline();
        updateLatencyHealthUi();
        updateCctvOsd();
        void maybeCaptureCriticalDebugSnapshot();
    }

    function applyPerformancePreset(presetName, silent = false) {
        const preset = (presetName || 'balanced').toLowerCase();
        let label = 'สมดุล';
        if (preset === 'smooth') {
            label = 'ลื่นสุด';
            selScanEngine.value = 'buffered';
            selFacePolicy.value = 'single';
            selProfile.value = 'fast';
            selViewMode.value = 'contain';
            selResolution.value = '640x360';
            selDisplayFps.value = '20';
            selAnalysisFps.value = '4';
            chkAdaptiveStream.checked = true;
        } else if (preset === 'quality') {
            label = 'ภาพคม';
            selScanEngine.value = 'buffered';
            selFacePolicy.value = 'single';
            selProfile.value = 'stable';
            selViewMode.value = 'contain';
            selResolution.value = '1280x720';
            selDisplayFps.value = '12';
            selAnalysisFps.value = '6';
            chkAdaptiveStream.checked = false;
        } else if (preset === 'lowlatency') {
            label = 'หน่วงต่ำ';
            selScanEngine.value = 'buffered';
            selFacePolicy.value = 'single';
            selProfile.value = 'fast';
            selViewMode.value = 'contain';
            selResolution.value = '640x360';
            selDisplayFps.value = '24';
            selAnalysisFps.value = '6';
            chkAdaptiveStream.checked = true;
        } else {
            label = 'สมดุล';
            selScanEngine.value = 'buffered';
            selFacePolicy.value = 'single';
            selProfile.value = 'stable';
            selViewMode.value = 'contain';
            selResolution.value = '960x540';
            selDisplayFps.value = '12';
            selAnalysisFps.value = '6';
            chkAdaptiveStream.checked = true;
        }

        localStorage.setItem(presetStorageKey, preset);
        localStorage.setItem(resolutionStorageKey, selResolution.value);
        localStorage.setItem(displayFpsStorageKey, selDisplayFps.value);
        localStorage.setItem(analysisFpsStorageKey, selAnalysisFps.value);
        localStorage.setItem(adaptiveStreamStorageKey, chkAdaptiveStream.checked ? '1' : '0');
        localStorage.setItem(scanEngineStorageKey, selScanEngine.value);
        localStorage.setItem(viewModeStorageKey, selViewMode.value);
        localStorage.setItem(`ipcam-profile:${STATION_CODE || 'default'}`, selProfile.value);
        refreshPixelBadge();
        applyViewMode(selViewMode.value, true);
        refreshLiveStreamSource(true);

        if (!silent) {
            setStatus('waiting', `เปลี่ยน preset: ${label} (ล็อกพิกเซล ${getResolutionLabel(selResolution.value)})`);
            latencyTune.textContent = `Preset: ${label}, engine=${selScanEngine.value}, res=${selResolution.value}, display=${getCurrentDisplayFps()} FPS, analysis=${getCurrentAnalysisFps()} FPS, adaptive=${chkAdaptiveStream.checked ? 'on' : 'off'}`;
        }
    }

    function getResolutionLabel(value) {
        return value === 'native' ? 'Native' : value;
    }

    function refreshPixelBadge() {
        pixelBadge.textContent = getResolutionLabel(selResolution.value);
    }

    function getCurrentDisplayFps() {
        return Number.parseInt(selDisplayFps.value || '20', 10) || 20;
    }

    function getCurrentAnalysisFps() {
        const selected = Number.parseInt(selAnalysisFps.value || '8', 10) || 8;
        return Math.max(2, Math.min(STREAM_ANALYSIS_MAX_FPS, selected));
    }

    function getPreviewTickDelayMs() {
        const displayFps = Math.max(1, getCurrentDisplayFps());
        return clamp(Math.floor(1000 / displayFps), 33, 600);
    }

    function getStreamAnalysisDelayMs() {
        const streamAnalysisFps = getCurrentAnalysisFps();
        return Math.max(STREAM_ANALYSIS_MIN_DELAY_MS, Math.floor(1000 / streamAnalysisFps));
    }

