@{
    Layout = null;
    var stationCode  = ViewBag.StationCode  as string ?? "";
    var stationToken = ViewBag.StationToken as string ?? "";
    var stationName  = ViewBag.StationName  as string ?? stationCode;
    var cameraType   = ViewBag.CameraType   as string ?? "generic";
    var recognitionProfile = ViewBag.RecognitionProfile as string ?? "auto";
    var intervalMs   = (int)(ViewBag.IntervalMs ?? 1000);
    var minConfidence = (decimal)(ViewBag.CameraMinConfidence ?? 0.60m);
    var skipFrames = (int)(ViewBag.CameraSkipFrames ?? 1);
    var overlayEnabled = (bool)(ViewBag.CameraOverlayEnabled ?? true);
    var appName      = ViewBag.AppName      as string ?? "FaceScan";
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@appName – สถานีสแกน IP Camera: @stationName</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@400;500;600;700&family=Sarabun:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        * { box-sizing: border-box; }
        body {
            margin: 0; padding: 0;
            background: #0f172a;
            color: #f1f5f9;
            font-family: 'Kanit', 'Sarabun', sans-serif;
            height: 100vh;
            overflow: hidden;
        }
        body.kiosk-mode .station-header {
            display: none;
        }
        body.kiosk-mode .main-layout {
            height: 100vh;
        }
        body.minimal-mode .feed-panel {
            display: none;
        }
        body.minimal-mode .cam-panel {
            flex: 1 1 auto;
        }
        body.minimal-mode .cam-overlay .corner {
            opacity: 0.65;
        }

        #kioskStartOverlay {
            position: fixed;
            inset: 0;
            z-index: 1300;
            display: none;
            align-items: center;
            justify-content: center;
            background: rgba(2, 6, 23, 0.84);
            backdrop-filter: blur(3px);
        }
        body.kiosk-mode #kioskStartOverlay {
            display: flex;
        }
        .kiosk-start-card {
            width: min(92vw, 480px);
            border: 1px solid #334155;
            border-radius: 16px;
            background: linear-gradient(165deg, #0f172a, #111827);
            padding: 22px 20px;
            text-align: center;
            box-shadow: 0 20px 38px rgba(2, 6, 23, 0.45);
        }
        .kiosk-start-title {
            font-size: 1.25rem;
            font-weight: 700;
            margin-bottom: 8px;
        }
        .kiosk-start-sub {
            color: #94a3b8;
            font-size: 0.95rem;
            margin-bottom: 16px;
        }

        #kioskFullscreenBtn {
            position: fixed;
            top: 10px;
            right: 10px;
            z-index: 1200;
            border: 1px solid #3f3f46;
            background: rgba(15, 23, 42, 0.9);
            color: #e2e8f0;
            padding: 6px 12px;
            border-radius: 999px;
            font-size: 0.8rem;
            display: none;
        }
        body.kiosk-mode #kioskFullscreenBtn {
            display: inline-flex;
            gap: 6px;
            align-items: center;
        }
        .station-header {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            border-bottom: 1px solid #334155;
            padding: 8px 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 48px;
            flex-shrink: 0;
        }
        .station-header .station-name {
            font-size: 1.05rem;
            font-weight: 600;
            color: #e2e8f0;
        }
        .station-header .status-pill {
            font-size: 0.75rem;
            padding: 3px 10px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        .status-pill.scanning  { background: #16a34a22; color: #4ade80; border: 1px solid #16a34a55; }
        .status-pill.error     { background: #dc262622; color: #f87171; border: 1px solid #dc262655; }
        .status-pill.waiting   { background: #d9770622; color: #fb923c; border: 1px solid #d9770655; }
        .station-header .clock { font-size: 0.85rem; color: #94a3b8; min-width: 80px; text-align: right; }

        .main-layout {
            display: flex;
            height: calc(100vh - 48px - 52px);
        }

        /* ── LEFT: Camera feed ── */
        .cam-panel {
            flex: 1 1 0;
            position: relative;
            background: #111;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: auto;
            padding: 16px;
        }
        .cam-stage {
            position: relative;
            width: 1280px;
            height: 720px;
            background: #000;
            border-radius: 8px;
            overflow: hidden;
            box-shadow: 0 4px 18px rgba(0,0,0,0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            flex: 0 0 auto;
        }
        #camImg {
            width: 100%;
            height: 100%;
            object-fit: contain;
            display: block;
        }
        .cam-overlay {
            position: absolute;
            inset: 0;
            display: flex;
            align-items: center;
            justify-content: center;
            pointer-events: none;
        }
        #overlayCanvas {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
        }
        .result-splash {
            background: rgba(0,0,0,0.82);
            border-radius: 16px;
            padding: 24px 32px;
            text-align: center;
            min-width: 280px;
            max-width: 360px;
            backdrop-filter: blur(8px);
            animation: fadeIn .25s ease;
            border: 1px solid rgba(255,255,255,0.08);
        }
        @@keyframes fadeIn { from { opacity: 0; transform: scale(.93); } to { opacity: 1; transform: scale(1); } }
        .result-splash.success { border-color: #4ade8055; }
        .result-splash.dup     { border-color: #facc1555; }
        .result-splash.failed  { border-color: #f8717155; }
        .result-icon { font-size: 3rem; line-height: 1; margin-bottom: 8px; }
        .result-name { font-size: 1.4rem; font-weight: 700; margin-bottom: 4px; }
        .result-sub  { font-size: 0.88rem; color: #94a3b8; }

        /* Corner scanline indicator */
        .corner { position: absolute; width: 28px; height: 28px; }
        .corner.tl { top: 14px; left: 14px; border-top: 3px solid #4ade80; border-left: 3px solid #4ade80; }
        .corner.tr { top: 14px; right: 14px; border-top: 3px solid #4ade80; border-right: 3px solid #4ade80; }
        .corner.bl { bottom: 14px; left: 14px; border-bottom: 3px solid #4ade80; border-left: 3px solid #4ade80; }
        .corner.br { bottom: 14px; right: 14px; border-bottom: 3px solid #4ade80; border-right: 3px solid #4ade80; }
        .cam-offline { color: #64748b; font-size: 1rem; }
        .camera-retry-banner {
            position: absolute;
            top: 12px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 20;
            border: 1px solid #f59e0b88;
            background: rgba(15, 23, 42, 0.84);
            color: #fde68a;
            border-radius: 999px;
            padding: 6px 12px;
            font-size: 0.82rem;
            display: none;
            align-items: center;
            gap: 6px;
            backdrop-filter: blur(2px);
        }
        .pixel-controls {
            position: absolute;
            right: 12px;
            top: 12px;
            z-index: 30;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 5px 7px;
            border: 1px solid #334155;
            border-radius: 10px;
            background: rgba(15, 23, 42, 0.82);
            backdrop-filter: blur(2px);
        }
        .pixel-controls button {
            border: 1px solid #334155;
            background: #0f172a;
            color: #e2e8f0;
            border-radius: 6px;
            font-size: 0.72rem;
            padding: 2px 7px;
            line-height: 1.2;
        }
        .pixel-controls button:hover {
            background: #172033;
            border-color: #475569;
        }
        .pixel-controls .pixel-badge {
            min-width: 98px;
            text-align: center;
            color: #cbd5e1;
            font-size: 0.72rem;
            font-weight: 600;
        }
        .cctv-osd {
            position: absolute;
            left: 12px;
            top: 12px;
            z-index: 35;
            display: none;
            align-items: center;
            gap: 7px;
            padding: 4px 9px;
            border: 1px solid #334155;
            border-radius: 999px;
            background: rgba(15, 23, 42, 0.84);
            color: #cbd5e1;
            font-size: 0.68rem;
            font-weight: 600;
            letter-spacing: 0.01em;
            backdrop-filter: blur(2px);
        }
        .cctv-osd .dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #f59e0b;
        }
        .cctv-osd.critical {
            border-color: #ef444488;
            color: #fecaca;
            background: rgba(127, 29, 29, 0.58);
            box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.28) inset;
        }
        .cctv-osd.critical .dot {
            background: #ef4444;
            animation: osdBlink 0.9s steps(1) infinite;
        }
        @@keyframes osdBlink { 50% { opacity: 0.25; } }

        /* ── RIGHT: Result feed ── */
        .feed-panel {
            width: 300px;
            flex-shrink: 0;
            background: #1e293b;
            border-left: 1px solid #334155;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .feed-panel .feed-header {
            padding: 10px 14px;
            border-bottom: 1px solid #334155;
            font-size: 0.8rem;
            font-weight: 600;
            color: #94a3b8;
            text-transform: uppercase;
            letter-spacing: .05em;
            flex-shrink: 0;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 8px;
        }
        .feed-clear-btn {
            border: 1px solid #334155;
            background: #0f172a;
            color: #cbd5e1;
            border-radius: 999px;
            font-size: 0.68rem;
            padding: 4px 10px;
            line-height: 1;
            transition: background .15s ease, border-color .15s ease, color .15s ease;
        }
        .feed-clear-btn:hover {
            background: #172033;
            border-color: #475569;
            color: #f8fafc;
        }
        .counters {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 0;
            border-bottom: 1px solid #334155;
            flex-shrink: 0;
        }
        .cnt-box {
            padding: 10px 8px;
            text-align: center;
            border-right: 1px solid #334155;
        }
        .cnt-box:last-child { border-right: none; }
        .cnt-box .cnt-val { font-size: 1.5rem; font-weight: 700; }
        .cnt-box .cnt-label { font-size: 0.68rem; color: #64748b; }
        .cnt-box.success .cnt-val { color: #4ade80; }
        .cnt-box.dup .cnt-val     { color: #facc15; }
        .cnt-box.failed .cnt-val  { color: #f87171; }

        .latency-panel {
            border-bottom: 1px solid #334155;
            padding: 8px 10px;
            background: #172033;
            flex-shrink: 0;
        }
        .latency-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.7rem;
            color: #94a3b8;
            margin-bottom: 6px;
        }
        .latency-mini {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-top: 6px;
            margin-bottom: 6px;
        }
        .latency-mini-item {
            border: 1px solid #334155;
            border-radius: 7px;
            padding: 5px 7px;
            background: #0f172a;
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            font-size: 0.66rem;
            color: #94a3b8;
        }
        .latency-mini-item strong {
            font-size: 0.78rem;
            color: #e2e8f0;
            font-weight: 700;
        }
        .latency-value {
            font-size: 0.86rem;
            color: #e2e8f0;
            font-weight: 700;
        }
        .latency-track {
            width: 100%;
            height: 7px;
            border-radius: 999px;
            background: #0f172a;
            border: 1px solid #334155;
            overflow: hidden;
            margin-bottom: 6px;
        }
        .latency-fill {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, #22c55e 0%, #facc15 55%, #ef4444 100%);
            transition: width .2s ease;
        }
        .latency-tune {
            font-size: 0.66rem;
            color: #94a3b8;
        }
        .pipeline-health {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 6px;
            margin: 4px 0 6px;
        }
        .pipeline-item {
            border: 1px solid #334155;
            border-radius: 7px;
            background: #0f172a;
            padding: 5px 6px;
            font-size: 0.62rem;
            color: #94a3b8;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 4px;
        }
        .pipeline-item strong {
            color: #e2e8f0;
            font-size: 0.68rem;
        }
        .pipeline-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: #94a3b8;
            flex: 0 0 auto;
        }
        .pipeline-item.ok .pipeline-dot {
            background: #22c55e;
        }
        .pipeline-item.warn .pipeline-dot {
            background: #f59e0b;
        }
        .pipeline-item.bad .pipeline-dot {
            background: #ef4444;
        }
        .fps-chart-wrap {
            margin: 6px 0 5px;
            border: 1px solid #334155;
            border-radius: 7px;
            background: #0f172a;
            padding: 5px 6px 4px;
        }
        .fps-chart-head {
            display: flex;
            justify-content: space-between;
            font-size: 0.62rem;
            color: #94a3b8;
            margin-bottom: 3px;
        }
        .fps-legend {
            display: inline-flex;
            gap: 8px;
            align-items: center;
        }
        .fps-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            display: inline-block;
        }
        .fps-dot.display {
            background: #22c55e;
        }
        .fps-dot.analysis {
            background: #38bdf8;
        }
        #fpsSparkline {
            width: 100%;
            height: 46px;
            display: block;
        }
        .debug-list-wrap {
            border-bottom: 1px solid #334155;
            padding: 6px 8px;
            background: #162238;
            flex-shrink: 0;
        }
        .debug-list-head {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.64rem;
            color: #94a3b8;
            margin-bottom: 4px;
        }
        .debug-list {
            display: flex;
            flex-direction: column;
            gap: 4px;
            max-height: 90px;
            overflow-y: auto;
        }
        .debug-item {
            border: 1px solid #334155;
            border-radius: 6px;
            background: #0f172a;
            color: #cbd5e1;
            font-size: 0.62rem;
            padding: 4px 6px;
            line-height: 1.35;
            text-decoration: none;
            display: block;
        }
        .debug-item:hover {
            border-color: #64748b;
            background: #111c31;
            color: #f8fafc;
        }
        .debug-empty {
            color: #64748b;
            font-size: 0.62rem;
        }

        .feed-list {
            flex: 1 1 0;
            overflow-y: auto;
            padding: 4px 0;
        }
        .feed-list::-webkit-scrollbar { width: 4px; }
        .feed-list::-webkit-scrollbar-thumb { background: #334155; border-radius: 2px; }
        .feed-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 7px 12px;
            border-bottom: 1px solid #1e293b;
            font-size: 0.8rem;
            animation: slideIn .2s ease;
            border-left: 4px solid transparent;
        }
        @@keyframes slideIn { from { opacity: 0; transform: translateX(6px); } to { opacity: 1; transform: translateX(0); } }
        .feed-item .feed-icon { font-size: 1rem; flex-shrink: 0; }
        .feed-item .feed-body { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 2px; }
        .feed-item .feed-name { font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .feed-item .feed-sub { font-size: 0.68rem; color: #94a3b8; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .feed-item .feed-time { font-size: 0.7rem; color: #64748b; white-space: nowrap; }
        .feed-item.success { border-left-color: #22c55e; background: linear-gradient(90deg, rgba(34,197,94,0.12), rgba(34,197,94,0.02)); }
        .feed-item.dup { border-left-color: #facc15; background: linear-gradient(90deg, rgba(250,204,21,0.12), rgba(250,204,21,0.02)); }
        .feed-item.failed { border-left-color: #f87171; background: linear-gradient(90deg, rgba(248,113,113,0.12), rgba(248,113,113,0.02)); }
        .feed-item.success .feed-icon { color: #4ade80; }
        .feed-item.success .feed-sub { color: #86efac; }
        .feed-item.dup .feed-icon { color: #facc15; }
        .feed-item.dup .feed-sub { color: #fde68a; }
        .feed-item.failed .feed-icon { color: #f87171; }
        .feed-item.failed .feed-sub { color: #fca5a5; }
        .feed-empty {
            padding: 16px 14px;
            font-size: 0.78rem;
            color: #64748b;
            text-align: center;
        }

        .config-bar {
            position: fixed;
            left: 0;
            right: 0;
            bottom: 0;
            height: 52px;
            padding: 8px 14px;
            background: #0b1220;
            border-top: 1px solid #334155;
            display: flex;
            gap: 8px;
            align-items: center;
            justify-content: flex-start;
            flex-wrap: nowrap;
            overflow-x: auto;
            overflow-y: hidden;
            z-index: 1050;
            box-shadow: 0 -2px 12px rgba(0,0,0,0.45);
        }
        .config-bar select, .config-bar label {
            font-size: 0.78rem;
            background: #0f172a;
            color: #cbd5e1;
            border: 1px solid #334155;
            border-radius: 6px;
            padding: 4px 8px;
            height: 34px;
            white-space: nowrap;
        }
        .config-bar select {
            flex: 0 0 auto;
            min-width: 150px;
        }
        .config-bar label {
            flex: 0 0 auto;
            min-width: 90px;
            display: flex;
            align-items: center;
            gap: 6px;
        }
        body.minimal-mode .config-bar { display: none; }
    </style>
</head>
<body>

<button type="button" id="kioskFullscreenBtn">
    <i class="bi bi-arrows-fullscreen"></i>
    เต็มจอ
</button>

<div id="kioskStartOverlay" role="dialog" aria-live="polite" aria-label="Kiosk fullscreen launcher">
    <div class="kiosk-start-card">
        <div class="kiosk-start-title">โหมด Kiosk พร้อมใช้งาน</div>
        <div class="kiosk-start-sub">แตะปุ่มด้านล่างเพื่อเข้าสู่โหมดเต็มจอสำหรับจุดสแกน</div>
        <div class="d-grid gap-2">
            <button type="button" class="btn btn-success btn-lg" id="kioskStartBtn">
                <i class="bi bi-arrows-fullscreen me-1"></i>เริ่มโหมดเต็มจอ
            </button>
            <button type="button" class="btn btn-outline-light btn-sm" id="kioskSkipBtn">
                ใช้งานต่อโดยไม่เต็มจอ
            </button>
        </div>
    </div>
</div>

<div class="station-header">
    <div class="d-flex align-items-center gap-3">
        <span class="text-primary fw-bold" style="font-size:1.2rem">
            <i class="bi bi-camera-video-fill me-1" style="color:#4ade80"></i>@appName
        </span>
        <span class="station-name">@stationName</span>
    </div>
    <span id="statusPill" class="status-pill waiting">
        <span id="statusDot">●</span> <span id="statusText">กำลังเชื่อมต่อ...</span>
    </span>
    <span class="clock" id="liveClock"></span>
</div>

<div class="main-layout">

    <!-- Camera feed -->
    <div class="cam-panel" id="camPanel">
        <div class="camera-retry-banner" id="cameraRetryBanner">
            <i class="bi bi-arrow-repeat"></i>
            <span id="cameraRetryText">กำลังเชื่อมต่อกล้องใหม่...</span>
        </div>
        <div class="pixel-controls" title="ปรับขนาดพิกเซลกล้อง">
            <button type="button" id="btnPixelDown">Pixel -</button>
            <span class="pixel-badge" id="pixelBadge">640x360</span>
            <button type="button" id="btnPixelUp">Pixel +</button>
        </div>
        <div class="cam-stage" id="camStage">
            <img id="camImg" src="" alt="Camera feed" style="display:none" />
            <div class="cctv-osd" id="cctvOsd"><span class="dot"></span><span id="cctvOsdText">CCTV LIVE</span></div>
            <div class="cam-offline" id="camOffline" style="display:none">
                <i class="bi bi-camera-video-off fs-1 d-block text-center mb-2"></i>
                <div id="camOfflineText">ไม่สามารถรับภาพจากกล้องได้</div>
            </div>
            <div class="cam-overlay">
                <canvas id="overlayCanvas"></canvas>
                <div class="corner tl"></div>
                <div class="corner tr"></div>
                <div class="corner bl"></div>
                <div class="corner br"></div>
                <div id="resultSplash" style="display:none"></div>
            </div>
        </div>
    </div>

    <!-- Result feed -->
    <div class="feed-panel">
        <div class="feed-header">
            <span><i class="bi bi-broadcast me-1"></i>ผลสแกนสด</span>
            <button type="button" id="feedClearBtn" class="feed-clear-btn"><i class="bi bi-trash3 me-1"></i>ล้างรายการ</button>
        </div>
        <div class="counters">
            <div class="cnt-box success">
