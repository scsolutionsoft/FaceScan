        if (naturalW === 0 || naturalH === 0) {
            return;
        }

        if (naturalW !== lastNaturalImageWidth || naturalH !== lastNaturalImageHeight) {
            lastNaturalImageWidth = naturalW;
            lastNaturalImageHeight = naturalH;
            autoFitCameraImage(latestFrameWidth || naturalW, latestFrameHeight || naturalH);
        }
    });

    applyPerformancePreset(selPreset.value, true);
    applyCameraProfile(selCctvProfile.value, true);
    applyViewMode(selViewMode.value, true);
    applyPresetLockState();
    refreshPixelBadge();
