<script src="~/js/ipcamera-page-module.js" asp-append-version="true"></script>
<script>
(function () {
    'use strict';

    const STATION_CODE  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stationCode));
    const STATION_TOKEN = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(stationToken));
    const urlParams = new URLSearchParams(window.location.search);
    const KIOSK_MODE = urlParams.get('kiosk') === '1';
    const MINIMAL_MODE = urlParams.get('minimal') === '1';
    const AUTO_FULLSCREEN = urlParams.get('autofs') === '1';
    const INTERVAL_MS   = 1000;
    const MIN_CONFIDENCE = @Html.Raw(minConfidence.ToString(System.Globalization.CultureInfo.InvariantCulture));
    const SKIP_FRAMES = @skipFrames;
    const OVERLAY_ENABLED = @overlayEnabled.ToString().ToLowerInvariant();
    const CAMERA_FACE_MODE = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((string)(ViewBag.ScanFaceMode ?? "single")));
    const CAMERA_SCAN_ENGINE = @Html.Raw(System.Text.Json.JsonSerializer.Serialize((string)(ViewBag.ScanEngine ?? "classic")));
    const CAMERA_AUTO_TUNE = @(((bool?)ViewBag.ScanAutoTuneEnabled ?? true).ToString().ToLowerInvariant());
    const CAMERA_MULTI_FACE_MAX = @((int?)(ViewBag.ScanMultiFaceMax) ?? 3);
    const SNAP_URL      = `/IpCamera/ProxySnapshot?stationCode=${encodeURIComponent(STATION_CODE)}&stationToken=${encodeURIComponent(STATION_TOKEN)}&t=`;
    const MJPEG_STREAM_URL = `/IpCamera/MjpegStream?stationCode=${encodeURIComponent(STATION_CODE)}&stationToken=${encodeURIComponent(STATION_TOKEN)}`;
    const TEST_CONNECTION_URL = `/IpCamera/TestConnection?stationCode=${encodeURIComponent(STATION_CODE)}&stationToken=${encodeURIComponent(STATION_TOKEN)}`;
    const DEBUG_SNAPSHOT_UPLOAD_URL = `/IpCamera/UploadDebugSnapshot?stationCode=${encodeURIComponent(STATION_CODE)}&stationToken=${encodeURIComponent(STATION_TOKEN)}`;
    const DEBUG_SNAPSHOT_LIST_URL = `/IpCamera/DebugSnapshots?stationCode=${encodeURIComponent(STATION_CODE)}&stationToken=${encodeURIComponent(STATION_TOKEN)}&take=8`;
    const PREVIEW_URL   = '/Scan/Preview';
    const VERIFY_URL    = '/Scan/Verify';
    const VERIFY_QUEUE_URL = '/Scan/VerifyQueued';
    const VERIFY_QUEUE_RESULT_URL = '/Scan/VerifyQueuedResult';
    const VERIFY_QUEUE_METRICS_URL = '/Scan/VerifyQueuedMetrics';
    const SPLASH_HOLD_MS = 3200;
    const COOLDOWN_MS   = 60_000;   // per studentCode
    const QUEUE_BACKPRESSURE_COOLDOWN_MS = 1500;
    const FEED_MAX      = 80;
    const FACE_STABLE_HITS = 2;     // Require 2 consecutive face frames before Verify
    const VERIFY_MIN_GAP_MS = 900;  // Throttle verify calls for responsiveness
    const FAST_INTERVAL_MS = Math.max(260, Math.floor(INTERVAL_MS * 0.55));
    const NORMAL_INTERVAL_MS = INTERVAL_MS;
    const IDLE_INTERVAL_MS = Math.min(2400, Math.max(INTERVAL_MS, Math.floor(INTERVAL_MS * 1.65)));
    const PREVIEW_INTERVAL_MS = Math.max(220, Math.min(360, Math.floor(INTERVAL_MS * 0.24)));
    const PREVIEW_IDLE_INTERVAL_MS = Math.max(PREVIEW_INTERVAL_MS, Math.min(900, Math.floor(INTERVAL_MS * 0.55)));
    const QUEUE_MAX_ITEMS = 24;
    const SERVER_PENDING_WARN_LIMIT = 24;
    const SERVER_PENDING_HARD_LIMIT = 48;
    const MULTI_FRAME_FACE_LIMIT = Math.max(3, Math.min(6, CAMERA_MULTI_FACE_MAX));
    const RESOLUTION_STEPS = ['native', '960x540', '640x360', '480x270', '320x180'];
    const AUTO_RESOLUTION_COOLDOWN_MS = 9000;
    const AUTO_RESOLUTION_ENABLED = false;
    const CAMERA_CONNECTION_CHECK_INTERVAL_MS = 45_000;
    const FORCE_CONTAIN_MODE = true;
    const LIVE_STREAM_ENABLED = (urlParams.get('stream') ?? '1') !== '0';
    const DISPLAY_FPS_STEPS = [6, 8, 10, 12, 15, 20, 24];
    const ANALYSIS_FPS_STEPS = [2, 4, 6, 8, 10];
    const STREAM_ANALYSIS_MAX_FPS = 10;
    const STREAM_ANALYSIS_MIN_DELAY_MS = 120;
    const STREAM_ADAPTIVE_COOLDOWN_MS = 6000;
    const STREAM_ANALYSIS_ADAPTIVE_COOLDOWN_MS = 7000;
    const LATENCY_ALERT_MS = 1200;
    const LATENCY_CRITICAL_MS = 1700;
    const LATENCY_AUTO_PRESET_SWITCH_COOLDOWN_MS = 25_000;
    const LATENCY_AUTO_PRESET_STREAK_REQUIRED = 5;
    const LATENCY_AUTO_PRESET_RECOVERY_REQUIRED = 8;
    const PREVIEW_API_MIN_GAP_MS = 450;
    const PREVIEW_PRIORITY_WARN_EXTRA_DELAY_MS = 220;
    const PREVIEW_PRIORITY_CRITICAL_EXTRA_DELAY_MS = 520;
    const DEBUG_SNAPSHOT_CRITICAL_SECONDS = 8;
    const DEBUG_SNAPSHOT_COOLDOWN_MS = 45_000;
    const ANALYSIS_FRAME_SKIP_BASE = Math.max(1, SKIP_FRAMES);

    let cntSuccess = 0, cntDup = 0, cntFail = 0;
    let feedHistory = [];
    let noFaceStreak = 0;
    let frameCounter = 0;
    let isBusy = false;
    let consecutiveSnapError = 0;
    let faceStableCount = 0;
    let lastVerifyAt = 0;
    let dynamicFaceStableHits = FACE_STABLE_HITS;
    let dynamicVerifyGapMs = VERIFY_MIN_GAP_MS;
    let dynamicFastIntervalMs = FAST_INTERVAL_MS;
    let dynamicNormalIntervalMs = NORMAL_INTERVAL_MS;
    let dynamicIdleIntervalMs = IDLE_INTERVAL_MS;
    let avgLoopMs = 0;
    let avgSnapMs = 0;
    let avgVerifyMs = 0;
    let avgAnalysisMs = 0;
    let avgPreviewFrameMs = 0;
    let lastPreviewPaintAt = 0;
    let tuningSampleCount = 0;
    let dynamicWorkers = 1;
    let dynamicFrameSkip = ANALYSIS_FRAME_SKIP_BASE;
    let activeWorkers = 0;
    let autoResolutionLastChangedAt = 0;
    let autoAnalysisLastChangedAt = 0;
    let autoPresetLastChangedAt = 0;
    let highLatencyStreak = 0;
    let lowLatencyRecoveryStreak = 0;
    let criticalSinceAt = 0;
    let lastCriticalSeconds = 0;
    let lastAnalysisQueuedAt = 0;
    let lastPreviewApiAt = 0;
    let lastDebugSnapshotAt = 0;
    let debugSnapshotInFlight = false;
    let latestAnalysisJob = null;
    let analysisScheduled = false;
    let analysisInFlight = false;
    let previewNoFaceCooldownUntil = 0;
    let previewLoopTimer = null;
    let analysisLoopTimer = null;
    let splitPipelinesRunning = false;
    let queueBackpressureUntil = 0;
    let queueBackpressureLevel = 0;
    let queueMetricsRefreshInFlight = false;
    let latestQueuePending = 0;
    let latestQueueRejectedTotal = 0;
    let latestQueueTimeoutTotal = 0;
    let latestQueueAvgMs = 0;
    let latestQueueCompleted = 0;
    let queueRejectedDelta = 0;
    let queueTimeoutDelta = 0;
    let lastQueueMetricsAt = 0;
    const pipelineHealthState = {
        video: { level: 'warn', text: 'init' },
        detect: { level: 'warn', text: 'init' },
        match: { level: 'warn', text: 'init' }
    };
    const verifyQueue = [];
    const cooldownMap = new Map(); // studentCode → timestamp
    let debugSnapshotRefreshInFlight = false;

    const camImg      = document.getElementById('camImg');
    const camPanel    = document.getElementById('camPanel');
    const camOffline  = document.getElementById('camOffline');
    const cameraRetryBanner = document.getElementById('cameraRetryBanner');
    const cameraRetryText = document.getElementById('cameraRetryText');
    const btnPixelDown = document.getElementById('btnPixelDown');
    const btnPixelUp = document.getElementById('btnPixelUp');
    const pixelBadge = document.getElementById('pixelBadge');
    const overlayCanvas = document.getElementById('overlayCanvas');
    const overlayCtx = overlayCanvas.getContext('2d');
    const statusPill  = document.getElementById('statusPill');
    const statusDot   = document.getElementById('statusDot');
    const statusTxt   = document.getElementById('statusText');
    const camOfflineText = document.getElementById('camOfflineText');
    const resultSplash = document.getElementById('resultSplash');
    const feedList    = document.getElementById('feedList');
    const feedClearBtn = document.getElementById('feedClearBtn');
    const debugSnapshotList = document.getElementById('debugSnapshotList');
    const debugSnapshotHint = document.getElementById('debugSnapshotHint');
    const selPreset = document.getElementById('selPreset');
    const selCctvProfile = document.getElementById('selCctvProfile');
    const selViewMode = document.getElementById('selViewMode');
    const selProfile  = document.getElementById('selProfile');
    const selResolution = document.getElementById('selResolution');
    const selDisplayFps = document.getElementById('selDisplayFps');
    const selAnalysisFps = document.getElementById('selAnalysisFps');
    const selFacePolicy = document.getElementById('selFacePolicy');
    const selScanEngine = document.getElementById('selScanEngine');
    const chkAdaptiveStream = document.getElementById('chkAdaptiveStream');
    const chkPreviewPriority = document.getElementById('chkPreviewPriority');
    const chkPresetLock = document.getElementById('chkPresetLock');
    const chkFullConfigLock = document.getElementById('chkFullConfigLock');
    const chkAutoDebugSnapshot = document.getElementById('chkAutoDebugSnapshot');
    const chkSound    = document.getElementById('chkSound');
    const latencyValue = document.getElementById('latencyValue');
    const previewFpsValue = document.getElementById('previewFpsValue');
    const analysisFpsValue = document.getElementById('analysisFpsValue');
    const analysisLatencyValue = document.getElementById('analysisLatencyValue');
    const latencyFill = document.getElementById('latencyFill');
    const latencyTune = document.getElementById('latencyTune');
    const queueMetricsText = document.getElementById('queueMetricsText');
    const fpsChartWrap = document.getElementById('fpsChartWrap');
    const fpsHealthText = document.getElementById('fpsHealthText');
    const fpsSparkline = document.getElementById('fpsSparkline');
    const fpsSparkCtx = fpsSparkline ? fpsSparkline.getContext('2d') : null;
    const videoHealth = document.getElementById('videoHealth');
    const detectHealth = document.getElementById('detectHealth');
    const matchHealth = document.getElementById('matchHealth');
    const cctvOsd = document.getElementById('cctvOsd');
    const cctvOsdText = document.getElementById('cctvOsdText');
    const pageModule = window.IpCameraPageModule || null;
    const clock       = document.getElementById('liveClock');
    const kioskFullscreenBtn = document.getElementById('kioskFullscreenBtn');
    const kioskStartOverlay = document.getElementById('kioskStartOverlay');
    const kioskStartBtn = document.getElementById('kioskStartBtn');
    const kioskSkipBtn = document.getElementById('kioskSkipBtn');
    const FEED_STORAGE_KEY = `ipcam-feed-history:${STATION_CODE || 'public'}`;
    let autoFsAttempted = false;
    let faceDetector  = null;
    let supportsLiveDetection = false;
    let latestFaceRect = null;
    let latestOverlayConfidence = null;
    let latestFrameWidth = 0;
    let latestFrameHeight = 0;
    let lastRenderedImageWidth = 0;
    let lastRenderedImageHeight = 0;
    let lastNaturalImageWidth = 0;
    let lastNaturalImageHeight = 0;
    let nextTickTimer = null;
    let activeLiveStreamUrl = '';
    const fpsHistoryMaxPoints = 48;
    const displayFpsHistory = [];
    const analysisFpsHistory = [];

    // Restore preferences
    selProfile.value = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(recognitionProfile));
    const resolutionStorageKey = `ipcam-realtime-resolution:${STATION_CODE || 'default'}`;
    const displayFpsStorageKey = `ipcam-display-fps:${STATION_CODE || 'default'}`;
    const analysisFpsStorageKey = `ipcam-analysis-fps:${STATION_CODE || 'default'}`;
    const adaptiveStreamStorageKey = `ipcam-adaptive-stream:${STATION_CODE || 'default'}`;
    const cctvProfileStorageKey = `ipcam-cctv-profile:${STATION_CODE || 'default'}`;
    const previewPriorityStorageKey = `ipcam-preview-priority:${STATION_CODE || 'default'}`;
    const presetLockStorageKey = `ipcam-preset-lock:${STATION_CODE || 'default'}`;
    const fullConfigLockStorageKey = `ipcam-full-config-lock:${STATION_CODE || 'default'}`;
    const autoDebugSnapshotStorageKey = `ipcam-auto-debug-snapshot:${STATION_CODE || 'default'}`;
    const presetStorageKey = `ipcam-performance-preset:${STATION_CODE || 'default'}`;
    const viewModeStorageKey = `ipcam-view-mode:${STATION_CODE || 'default'}`;
    const persistedResolution = localStorage.getItem(resolutionStorageKey);
    const displayFpsFromQuery = Number.parseInt(urlParams.get('displayFps') || '', 10);
    const analysisFpsFromQuery = Number.parseInt(urlParams.get('analysisFps') || '', 10);
    const persistedDisplayFps = Number.parseInt(localStorage.getItem(displayFpsStorageKey) || '20', 10);
    const persistedAnalysisFps = Number.parseInt(localStorage.getItem(analysisFpsStorageKey) || '6', 10);
    const persistedAdaptiveStream = localStorage.getItem(adaptiveStreamStorageKey);
    const persistedCctvProfile = localStorage.getItem(cctvProfileStorageKey);
    const persistedPreviewPriority = localStorage.getItem(previewPriorityStorageKey);
    const persistedPresetLock = localStorage.getItem(presetLockStorageKey);
    const persistedFullConfigLock = localStorage.getItem(fullConfigLockStorageKey);
    const persistedAutoDebugSnapshot = localStorage.getItem(autoDebugSnapshotStorageKey);
    const effectiveDisplayFps = Number.isFinite(displayFpsFromQuery) ? displayFpsFromQuery : persistedDisplayFps;
    const effectiveAnalysisFps = Number.isFinite(analysisFpsFromQuery) ? analysisFpsFromQuery : persistedAnalysisFps;
    selResolution.value = persistedResolution || '1280x720';
    selDisplayFps.value = String(DISPLAY_FPS_STEPS.includes(effectiveDisplayFps) ? effectiveDisplayFps : 20);
    selAnalysisFps.value = String(ANALYSIS_FPS_STEPS.includes(effectiveAnalysisFps) ? effectiveAnalysisFps : 6);
    chkAdaptiveStream.checked = persistedAdaptiveStream !== '0';
    selCctvProfile.value = persistedCctvProfile || 'generic';
    chkPreviewPriority.checked = persistedPreviewPriority !== '0';
    chkPresetLock.checked = persistedPresetLock === '1';
    chkFullConfigLock.checked = persistedFullConfigLock === '1';
    chkAutoDebugSnapshot.checked = persistedAutoDebugSnapshot === '1';
    selFacePolicy.value = (CAMERA_FACE_MODE === 'multi' ? 'multi' : 'single');
    const scanEngineStorageKey = `ipcam-scan-engine:${STATION_CODE || 'default'}`;
    const persistedEngine = localStorage.getItem(scanEngineStorageKey);
    const cameraDefaultEngine = 'buffered';
    selScanEngine.value = persistedEngine || cameraDefaultEngine;
    selPreset.value = localStorage.getItem(presetStorageKey) || 'balanced';
    const persistedViewMode = localStorage.getItem(viewModeStorageKey);
    selViewMode.value = (FORCE_CONTAIN_MODE ? 'contain' : (persistedViewMode || 'contain'));
    if (FORCE_CONTAIN_MODE) {
        selViewMode.disabled = true;
    }
    if (selResolution.value !== 'native' && selViewMode.value === 'cover') {
        selViewMode.value = 'contain';
        localStorage.setItem(viewModeStorageKey, 'contain');
    }
    chkSound.checked = localStorage.getItem('ipcam-sound') === '1';
    selProfile.addEventListener('change', () => localStorage.setItem(`ipcam-profile:${STATION_CODE || 'default'}`, selProfile.value));
    selResolution.addEventListener('change', () => {
        localStorage.setItem(resolutionStorageKey, selResolution.value);
        autoResolutionLastChangedAt = Date.now();
        if (selResolution.value !== 'native' && selViewMode.value === 'cover') {
            applyViewMode('contain', true);
        }
        refreshPixelBadge();
        autoFitCameraImage(latestFrameWidth, latestFrameHeight);
        drawFaceOverlay(latestFaceRect, latestOverlayConfidence);
        refreshLiveStreamSource(true);
        setStatus('waiting', `ปรับภาพเรียลไทม์: ${getResolutionLabel(selResolution.value)}`);
    });
    selDisplayFps.addEventListener('change', () => {
        localStorage.setItem(displayFpsStorageKey, selDisplayFps.value);
        refreshLiveStreamSource(true);
        setStatus('waiting', `ปรับความลื่นภาพ: ${selDisplayFps.value} FPS`);
    });
    selAnalysisFps.addEventListener('change', () => {
        localStorage.setItem(analysisFpsStorageKey, selAnalysisFps.value);
        setStatus('waiting', `ปรับความถี่วิเคราะห์: ${selAnalysisFps.value} FPS`);
    });
    chkAdaptiveStream.addEventListener('change', () => {
        localStorage.setItem(adaptiveStreamStorageKey, chkAdaptiveStream.checked ? '1' : '0');
        setStatus('waiting', chkAdaptiveStream.checked ? 'เปิด Adaptive Auto' : 'ปิด Adaptive Auto');
    });
    chkPreviewPriority.addEventListener('change', () => {
        localStorage.setItem(previewPriorityStorageKey, chkPreviewPriority.checked ? '1' : '0');
        setStatus('waiting', chkPreviewPriority.checked ? 'เปิด CCTV Preview Priority' : 'ปิด CCTV Preview Priority');
    });
    chkPresetLock.addEventListener('change', () => {
        localStorage.setItem(presetLockStorageKey, chkPresetLock.checked ? '1' : '0');
        applyPresetLockState();
        setStatus('waiting', chkPresetLock.checked ? 'เปิด Lock Preset (ปิด auto-switch)' : 'ปิด Lock Preset');
    });
    chkFullConfigLock.addEventListener('change', () => {
        localStorage.setItem(fullConfigLockStorageKey, chkFullConfigLock.checked ? '1' : '0');
        applyPresetLockState();
        setStatus('waiting', chkFullConfigLock.checked ? 'เปิด Lock Full Config (ค่าถูกล็อกคงที่)' : 'ปิด Lock Full Config');
    });
    chkAutoDebugSnapshot.addEventListener('change', () => {
        localStorage.setItem(autoDebugSnapshotStorageKey, chkAutoDebugSnapshot.checked ? '1' : '0');
        setStatus('waiting', chkAutoDebugSnapshot.checked ? 'เปิด Auto Debug Snapshot' : 'ปิด Auto Debug Snapshot');
    });
    selFacePolicy.addEventListener('change', () => {
        if (!localStorage.getItem(scanEngineStorageKey)) {
            selScanEngine.value = cameraDefaultEngine;
        }
    });
    selScanEngine.addEventListener('change', () => {
        localStorage.setItem(scanEngineStorageKey, selScanEngine.value);
        if (selScanEngine.value !== 'buffered') {
            verifyQueue.length = 0;
        }
        setStatus('waiting', selScanEngine.value === 'buffered' ? 'ใช้โหมดคิวบัฟเฟอร์' : 'ใช้โหมดคลาสสิก');
    });
    selCctvProfile.addEventListener('change', () => {
        applyCameraProfile(selCctvProfile.value);
