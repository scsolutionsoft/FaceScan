    function updateCctvOsd() {
        if (!cctvOsd || !cctvOsdText) {
            return;
        }

        if (!LIVE_STREAM_ENABLED) {
            cctvOsd.style.display = 'none';
            return;
        }

        cctvOsd.style.display = 'inline-flex';
        const criticalSecs = getCriticalDurationSeconds();
        if (criticalSecs > 0) {
            cctvOsd.classList.add('critical');
            cctvOsdText.textContent = `CRITICAL ${criticalSecs}s • LIVE`; 
        } else {
            cctvOsd.classList.remove('critical');
            cctvOsdText.textContent = `LIVE ${getCurrentDisplayFps()} FPS • analysis ${getCurrentAnalysisFps()} FPS`;
        }
    }

    async function maybeCaptureCriticalDebugSnapshot() {
        if (!chkAutoDebugSnapshot.checked) {
            return;
        }

        const criticalSecs = getCriticalDurationSeconds();
        if (criticalSecs < DEBUG_SNAPSHOT_CRITICAL_SECONDS) {
            return;
        }

        const now = Date.now();
        if ((now - lastDebugSnapshotAt) < DEBUG_SNAPSHOT_COOLDOWN_MS || debugSnapshotInFlight) {
            return;
        }

        const naturalW = camImg.naturalWidth || 0;
        const naturalH = camImg.naturalHeight || 0;
        if (naturalW <= 0 || naturalH <= 0) {
            return;
        }

        debugSnapshotInFlight = true;
        try {
            const canvas = document.createElement('canvas');
            canvas.width = naturalW;
            canvas.height = naturalH;
            const ctx = canvas.getContext('2d', { willReadFrequently: false });
            if (!ctx) {
                return;
            }

            ctx.drawImage(camImg, 0, 0, naturalW, naturalH);
            const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.78));
            if (!blob) {
                return;
            }

            const form = new FormData();
            form.append('Image', blob, `critical-${criticalSecs}s.jpg`);
            form.append('Reason', 'critical-latency');
            form.append('CriticalSeconds', String(criticalSecs));
            form.append('AnalysisMs', String(Math.round(avgAnalysisMs || 0)));
            form.append('LoopMs', String(Math.round(avgLoopMs || 0)));
            form.append('DisplayFps', String(Math.round((1000 / Math.max(1, avgPreviewFrameMs || 1)) * 10) / 10));
            form.append('AnalysisFps', String(Math.round((1000 / Math.max(1, avgAnalysisMs || 1)) * 10) / 10));

            const response = await fetch(DEBUG_SNAPSHOT_UPLOAD_URL, {
                method: 'POST',
                body: form
            });

            if (!response.ok) {
                return;
            }

            lastDebugSnapshotAt = now;
            setStatus('waiting', `Auto Debug Snapshot: บันทึกภาพวิกฤต (${criticalSecs}s)`);
        } finally {
            debugSnapshotInFlight = false;
        }
    }

    function maybeAdaptiveAdjustDisplayFps() {
        if (!LIVE_STREAM_ENABLED || !chkAdaptiveStream.checked || chkFullConfigLock.checked) {
            return;
        }

        const now = Date.now();
        if ((now - autoResolutionLastChangedAt) < STREAM_ADAPTIVE_COOLDOWN_MS) {
            return;
        }

        const current = getCurrentDisplayFps();
        const currentIndex = DISPLAY_FPS_STEPS.indexOf(current);
        if (currentIndex < 0) {
            return;
        }

        const overload = consecutiveSnapError >= 2 || avgLoopMs > 1450 || avgAnalysisMs > 1300;
        const underload = consecutiveSnapError === 0 && avgLoopMs > 0 && avgLoopMs < 700 && avgAnalysisMs > 0 && avgAnalysisMs < 560;

        let targetIndex = currentIndex;
        if (overload && currentIndex > 0) {
            targetIndex = currentIndex - 1;
        } else if (underload && currentIndex < (DISPLAY_FPS_STEPS.length - 1)) {
            targetIndex = currentIndex + 1;
        }

        if (targetIndex === currentIndex) {
            return;
        }

        const nextFps = DISPLAY_FPS_STEPS[targetIndex];
        selDisplayFps.value = String(nextFps);
        localStorage.setItem(displayFpsStorageKey, String(nextFps));
        autoResolutionLastChangedAt = now;
        refreshLiveStreamSource(true);
        latencyTune.textContent = `Adaptive Auto: ปรับ Display FPS -> ${nextFps}, analysis=${getCurrentAnalysisFps()} FPS`;
    }

    function maybeAdaptiveAdjustAnalysisFps() {
        if (!LIVE_STREAM_ENABLED || !chkAdaptiveStream.checked || chkFullConfigLock.checked) {
            return;
        }

        const now = Date.now();
        if ((now - autoAnalysisLastChangedAt) < STREAM_ANALYSIS_ADAPTIVE_COOLDOWN_MS) {
            return;
        }

        const current = getCurrentAnalysisFps();
        const currentIndex = ANALYSIS_FPS_STEPS.indexOf(current);
        if (currentIndex < 0) {
            return;
        }

        const overloaded = avgAnalysisMs > 1400 || avgLoopMs > 1500 || verifyQueue.length >= 2;
        const relaxed = avgAnalysisMs > 0 && avgAnalysisMs < 700 && avgLoopMs > 0 && avgLoopMs < 850 && verifyQueue.length === 0 && consecutiveSnapError === 0;

        let targetIndex = currentIndex;
        if (overloaded && currentIndex > 0) {
            targetIndex = currentIndex - 1;
        } else if (relaxed && currentIndex < (ANALYSIS_FPS_STEPS.length - 1)) {
            targetIndex = currentIndex + 1;
        }

        if (targetIndex === currentIndex) {
            return;
        }

        const nextFps = ANALYSIS_FPS_STEPS[targetIndex];
        selAnalysisFps.value = String(nextFps);
        localStorage.setItem(analysisFpsStorageKey, String(nextFps));
        autoAnalysisLastChangedAt = now;
        latencyTune.textContent = `Adaptive Auto: ปรับ Analysis FPS -> ${nextFps}, display=${getCurrentDisplayFps()} FPS`;
    }

    function buildLiveStreamUrl() {
        const resolution = selResolution.value || 'native';
        const fps = getCurrentDisplayFps();
        return `${MJPEG_STREAM_URL}&resolution=${encodeURIComponent(resolution)}&fps=${fps}`;
    }

    function refreshLiveStreamSource(force = false) {
        if (!LIVE_STREAM_ENABLED) {
            return;
        }

        const baseUrl = buildLiveStreamUrl();
        const nextUrl = force ? `${baseUrl}&nonce=${Date.now()}` : baseUrl;
        if (!force && activeLiveStreamUrl === nextUrl) {
            return;
        }

        activeLiveStreamUrl = nextUrl;
        camImg.src = nextUrl;
        camImg.style.display = '';
    }

    function parseResolution(value) {
        if (value === 'native') {
            return null;
        }

        const parts = String(value || '').split('x');
        if (parts.length !== 2) {
            return null;
        }

        const width = Number.parseInt(parts[0], 10);
        const height = Number.parseInt(parts[1], 10);
        if (!Number.isFinite(width) || !Number.isFinite(height) || width < 160 || height < 120) {
            return null;
        }

        return { width, height };
    }

    function getResolutionIndex(value) {
        const idx = RESOLUTION_STEPS.indexOf(value);
        return idx >= 0 ? idx : RESOLUTION_STEPS.indexOf('640x360');
    }

    function setRealtimeResolution(value, reason) {
        if (selResolution.value === value) {
            return false;
        }

        selResolution.value = value;
        localStorage.setItem(resolutionStorageKey, value);
        autoResolutionLastChangedAt = Date.now();
        refreshPixelBadge();
        autoFitCameraImage(latestFrameWidth, latestFrameHeight);
        drawFaceOverlay(latestFaceRect, latestOverlayConfidence);
        latencyTune.textContent = `Pixel setting: ${reason} -> ${getResolutionLabel(value)}`;
        setStatus('waiting', `ปรับภาพเรียลไทม์: ${getResolutionLabel(value)}`);
        return true;
    }

    function stepCameraResolution(delta) {
        const currentIndex = getResolutionIndex(selResolution.value);
        const targetIndex = clamp(currentIndex + delta, 0, RESOLUTION_STEPS.length - 1);
        const targetValue = RESOLUTION_STEPS[targetIndex];

        if (targetValue === selResolution.value) {
            return;
        }

        setRealtimeResolution(targetValue, 'ผู้ใช้กดปุ่ม Pixel');
    }

    function maybeAutoAdjustResolution(factor) {
        if (!CAMERA_AUTO_TUNE || !AUTO_RESOLUTION_ENABLED || chkFullConfigLock.checked) {
            return;
        }

        const now = Date.now();
        if ((now - autoResolutionLastChangedAt) < AUTO_RESOLUTION_COOLDOWN_MS) {
            return;
        }

        const currentIndex = getResolutionIndex(selResolution.value);
        const overload = factor >= 1.5 || avgLoopMs > 1300 || (verifyQueue.length >= (QUEUE_MAX_ITEMS - 2));
        const underload = factor <= 0.8 && avgLoopMs > 0 && avgLoopMs < 520 && avgSnapMs < 320 && verifyQueue.length === 0 && consecutiveSnapError === 0;

        if (overload && currentIndex < (RESOLUTION_STEPS.length - 1)) {
            setRealtimeResolution(RESOLUTION_STEPS[currentIndex + 1], 'ลดความละเอียดเพื่อความลื่น');
            return;
        }

        if (underload && currentIndex > 0) {
            setRealtimeResolution(RESOLUTION_STEPS[currentIndex - 1], 'เพิ่มความละเอียดเมื่อระบบนิ่ง');
        }
    }

    async function resizeBlobForProcessing(sourceBlob, targetWidth, targetHeight) {
        // Fast path: let browser decode+resize in one step when supported.
        if (typeof createImageBitmap === 'function') {
            let resizedBitmap = null;
            try {
                resizedBitmap = await createImageBitmap(sourceBlob, {
                    resizeWidth: targetWidth,
                    resizeHeight: targetHeight,
                    resizeQuality: 'high'
                });

                const canvas = document.createElement('canvas');
                canvas.width = Math.max(1, resizedBitmap.width);
                canvas.height = Math.max(1, resizedBitmap.height);
                const ctx = canvas.getContext('2d', { willReadFrequently: false });
                if (!ctx) {
                    return { blob: sourceBlob, width: resizedBitmap.width, height: resizedBitmap.height };
                }

                ctx.drawImage(resizedBitmap, 0, 0);
                const resizedBlob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.78));
                return {
                    blob: resizedBlob || sourceBlob,
                    width: canvas.width,
                    height: canvas.height
                };
            } catch {
                // Fall through to generic canvas path below.
            } finally {
                if (resizedBitmap && resizedBitmap.close) {
                    resizedBitmap.close();
                }
            }
        }

        let bitmap = null;
        try {
            bitmap = await createImageBitmap(sourceBlob);
            const srcW = bitmap.width;
            const srcH = bitmap.height;

            if (srcW <= 0 || srcH <= 0) {
                return { blob: sourceBlob, width: 0, height: 0 };
            }

            const scale = Math.min(targetWidth / srcW, targetHeight / srcH);
            const drawW = Math.max(1, Math.floor(srcW * scale));
            const drawH = Math.max(1, Math.floor(srcH * scale));

            const canvas = document.createElement('canvas');
            canvas.width = drawW;
            canvas.height = drawH;
            const ctx = canvas.getContext('2d', { willReadFrequently: false });
            if (!ctx) {
                return { blob: sourceBlob, width: srcW, height: srcH };
            }

            ctx.drawImage(bitmap, 0, 0, srcW, srcH, 0, 0, drawW, drawH);
            const resizedBlob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.78));
            return {
                blob: resizedBlob || sourceBlob,
                width: drawW,
                height: drawH
            };
        } catch {
            return { blob: sourceBlob, width: 0, height: 0 };
        } finally {
            if (bitmap && bitmap.close) {
                bitmap.close();
            }
        }
    }

    async function prepareFrameBlob(sourceBlob) {
        const resolution = parseResolution(selResolution.value);
        if (!resolution) {
            return {
                blob: sourceBlob,
                width: camImg.naturalWidth || 0,
                height: camImg.naturalHeight || 0
            };
        }

        return await resizeBlobForProcessing(sourceBlob, resolution.width, resolution.height);
    }

    async function captureFrameFromLiveStream() {
        const naturalW = camImg.naturalWidth || 0;
        const naturalH = camImg.naturalHeight || 0;
        if (naturalW <= 0 || naturalH <= 0) {
            return null;
        }

        const requested = parseResolution(selResolution.value);
        const targetW = requested ? requested.width : naturalW;
        const targetH = requested ? requested.height : naturalH;

        const canvas = document.createElement('canvas');
        canvas.width = Math.max(1, targetW);
        canvas.height = Math.max(1, targetH);
        const ctx = canvas.getContext('2d', { willReadFrequently: false });
        if (!ctx) {
            return null;
        }

        ctx.drawImage(camImg, 0, 0, naturalW, naturalH, 0, 0, canvas.width, canvas.height);
        const blob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.72));
        if (!blob) {
            return null;
        }

        return {
            blob,
            width: canvas.width,
            height: canvas.height
        };
    }

    function showRetryBanner(retryCount) {
        if (retryCount < 3) {
            cameraRetryBanner.style.display = 'none';
            return;
        }

        cameraRetryText.textContent = `กำลังเชื่อมต่อกล้องใหม่... (ครั้งที่ ${retryCount})`;
        cameraRetryBanner.style.display = 'inline-flex';
    }

    function hideRetryBanner() {
        cameraRetryBanner.style.display = 'none';
    }

    function resizeOverlayCanvas() {
        const stage = document.getElementById('camStage') || camPanel;
        overlayCanvas.width = stage.clientWidth;
        overlayCanvas.height = stage.clientHeight;
    }

    function applyStageSize() {
        const stage = document.getElementById('camStage');
        if (!stage) return;
        const requested = parseResolution(selResolution.value);
        let w, h;
        if (requested) {
            w = requested.width;
            h = requested.height;
        } else {
            w = camImg.naturalWidth || 1280;
            h = camImg.naturalHeight || 720;
        }
        // Lock the stage to the EXACT pixel size of the selected resolution.
        stage.style.width = w + 'px';
        stage.style.height = h + 'px';
        stage.style.maxWidth = 'none';
        stage.style.maxHeight = 'none';
        stage.style.aspectRatio = '';
    }

    function autoFitCameraImage(frameWidth, frameHeight) {
        applyStageSize();
        resizeOverlayCanvas();
        const requested = parseResolution(selResolution.value);
        const fw = Number(frameWidth) || (requested ? requested.width : 0) || camImg.naturalWidth || 0;
        const fh = Number(frameHeight) || (requested ? requested.height : 0) || camImg.naturalHeight || 0;
        if (fw <= 0 || fh <= 0) {
            return;
        }

        const stage = document.getElementById('camStage') || camPanel;
        const panelW = stage.clientWidth;
        const panelH = stage.clientHeight;
        if (panelW <= 0 || panelH <= 0) {
            return;
        }

        if (selViewMode.value === 'cover' && !requested) {
            const coverW = Math.max(1, Math.round(panelW));
            const coverH = Math.max(1, Math.round(panelH));
            if (coverW === lastRenderedImageWidth && coverH === lastRenderedImageHeight) {
                return;
            }

            camImg.style.width = `${coverW}px`;
            camImg.style.height = `${coverH}px`;
            lastRenderedImageWidth = coverW;
            lastRenderedImageHeight = coverH;
            return;
        }

        let targetW = panelW;
        let targetH = panelH;
        if (requested) {
            // Respect selected pixel size first, then clamp to available panel space.
            targetW = requested.width;
            targetH = requested.height;
            const downScale = Math.min(1, panelW / targetW, panelH / targetH);
            targetW *= downScale;
            targetH *= downScale;
        } else {
            const aspect = fw / fh;
            targetW = panelW;
            targetH = targetW / aspect;
            if (targetH > panelH) {
                targetH = panelH;
                targetW = targetH * aspect;
            }
        }

        const roundedW = Math.max(1, Math.round(targetW));
        const roundedH = Math.max(1, Math.round(targetH));
        if (roundedW === lastRenderedImageWidth && roundedH === lastRenderedImageHeight) {
            return;
        }

        camImg.style.width = `${roundedW}px`;
        camImg.style.height = `${roundedH}px`;
        lastRenderedImageWidth = roundedW;
        lastRenderedImageHeight = roundedH;
    }

    function getDisplayGeometry(naturalWidth, naturalHeight) {
        const stage = document.getElementById('camStage') || camPanel;
        const panelW = stage.clientWidth;
        const panelH = stage.clientHeight;
        const mode = FORCE_CONTAIN_MODE ? 'contain' : (selViewMode.value === 'cover' ? 'cover' : 'contain');
        const requested = parseResolution(selResolution.value);
        if (requested) {
            const displayW = Math.min(panelW, requested.width);
            const displayH = Math.min(panelH, requested.height);
            const scale = Math.min(displayW / naturalWidth, displayH / naturalHeight);
            const drawnW = naturalWidth * scale;
            const drawnH = naturalHeight * scale;
            const offsetX = (panelW - drawnW) / 2;
            const offsetY = (panelH - drawnH) / 2;
            return { scale, offsetX, offsetY };
        }

        const refW = requested ? Math.min(panelW, requested.width) : panelW;
        const refH = requested ? Math.min(panelH, requested.height) : panelH;
        const scale = mode === 'cover'
            ? Math.max(panelW / naturalWidth, panelH / naturalHeight)
            : Math.min(refW / naturalWidth, refH / naturalHeight);

        const drawnW = naturalWidth * scale;
        const drawnH = naturalHeight * scale;
        const offsetX = (panelW - drawnW) / 2;
        const offsetY = (panelH - drawnH) / 2;
        return { scale, offsetX, offsetY };
    }

    function clearOverlay() {
        overlayCtx.clearRect(0, 0, overlayCanvas.width, overlayCanvas.height);
    }

    function getOverlayColor(confidence) {
        if (!Number.isFinite(confidence)) return '#60a5fa';
        if (confidence >= 0.80) return '#22c55e';
        if (confidence >= 0.65) return '#facc15';
        return '#f97316';
    }

    function drawFaceOverlay(rect, confidence) {
        if (!OVERLAY_ENABLED) {
            clearOverlay();
            return;
        }

        clearOverlay();
        if (!rect) return;

        overlayCtx.strokeStyle = getOverlayColor(confidence);
        overlayCtx.lineWidth = 3;
        overlayCtx.setLineDash([8, 5]);
        overlayCtx.strokeRect(rect.x, rect.y, rect.width, rect.height);
        overlayCtx.setLineDash([]);
    }

    function mapImageRectToPanel(faceRect, naturalWidth, naturalHeight) {
        const { scale, offsetX, offsetY } = getDisplayGeometry(naturalWidth, naturalHeight);

        return {
            x: offsetX + (faceRect.x * scale),
            y: offsetY + (faceRect.y * scale),
            width: Math.max(1, faceRect.width * scale),
            height: Math.max(1, faceRect.height * scale)
        };
    }

    async function detectFacesInfo(blob, naturalWidth, naturalHeight) {
        if (!OVERLAY_ENABLED || !supportsLiveDetection || !faceDetector) {
            return { rect: null, count: 0, boxes: [] };
        }

        let bitmap = null;
        try {
            bitmap = await createImageBitmap(blob);
            const detections = await faceDetector.detect(bitmap);
            if (!detections || detections.length === 0) {
                return { rect: null, count: 0, boxes: [] };
            }

            const boxes = detections
                .map(d => d.boundingBox)
                .map(b => ({
                    x: Math.max(0, b.x),
                    y: Math.max(0, b.y),
                    width: Math.max(1, b.width),
                    height: Math.max(1, b.height)
                }))
                .sort((a, b) => (b.width * b.height) - (a.width * a.height));

            const largest = boxes[0];

            if (!largest) {
                return { rect: null, count: detections.length, boxes: [] };
            }

            return {
                rect: mapImageRectToPanel(
                    { x: largest.x, y: largest.y, width: largest.width, height: largest.height },
                    naturalWidth,
                    naturalHeight),
                count: detections.length,
                boxes
            };
        } catch {
            return { rect: null, count: 0, boxes: [] };
        } finally {
            if (bitmap && bitmap.close) {
                bitmap.close();
            }
        }
    }

    async function initFaceDetector() {
        try {
            if (!('FaceDetector' in window)) {
                supportsLiveDetection = false;
                return;
            }

            faceDetector = new FaceDetector({ fastMode: true, maxDetectedFaces: Math.max(2, Math.min(6, CAMERA_MULTI_FACE_MAX)) });
            supportsLiveDetection = true;
        } catch {
            supportsLiveDetection = false;
            faceDetector = null;
        }
    }

    // ── Sound (Web Audio) ──
    let audioCtx = null;
    function playBeep(type) {
        if (!chkSound.checked) return;
        try {
            audioCtx = audioCtx || new (window.AudioContext || window.webkitAudioContext)();
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain); gain.connect(audioCtx.destination);
            osc.type = 'triangle';
            if (type === 'success') {
                osc.frequency.setValueAtTime(880, audioCtx.currentTime);
                osc.frequency.exponentialRampToValueAtTime(1100, audioCtx.currentTime + 0.1);
                gain.gain.setValueAtTime(0.35, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.3);
                osc.start(); osc.stop(audioCtx.currentTime + 0.3);
            } else if (type === 'dup') {
                osc.frequency.value = 660;
                gain.gain.setValueAtTime(0.2, audioCtx.currentTime);
                gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.2);
                osc.start(); osc.stop(audioCtx.currentTime + 0.2);
            }
        } catch (_) {}
    }

    // ── Splash overlay on camera feed ──
    let splashTimer = null;
    function showSplash(type, name, sub) {
        clearTimeout(splashTimer);
        const iconMap = { success: '✅', dup: '⚠️', failed: '' };
        const icon = iconMap[type] || '';
        resultSplash.className = 'result-splash ' + type;
        resultSplash.innerHTML = `
            <div class="result-icon">${icon}</div>
            <div class="result-name">${escHtml(name)}</div>
            <div class="result-sub">${escHtml(sub)}</div>`;
        resultSplash.style.display = '';
        splashTimer = setTimeout(() => { resultSplash.style.display = 'none'; }, SPLASH_HOLD_MS);
    }

    function escHtml(s) {
        return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
    }

    function buildLocationLabel(gradeLevel, classroom) {
        const parts = [];
        if (gradeLevel) {
            parts.push(`ชั้น ${gradeLevel}`);
        }
        if (classroom) {
            parts.push(`ห้อง ${classroom}`);
        }
        return parts.join(' / ');
    }

    function persistFeedHistory() {
        try {
            localStorage.setItem(FEED_STORAGE_KEY, JSON.stringify(feedHistory.slice(0, FEED_MAX)));
        } catch {
            // Ignore storage issues; the feed remains visible for this session.
        }
    }

    function loadFeedHistory() {
        try {
            const raw = localStorage.getItem(FEED_STORAGE_KEY);
            const parsed = raw ? JSON.parse(raw) : [];
            feedHistory = Array.isArray(parsed) ? parsed.slice(0, FEED_MAX) : [];
        } catch {
            feedHistory = [];
        }

        renderFeedHistory();
    }

    function buildFeedSubText(item) {
        const parts = [];
        const location = buildLocationLabel(item.gradeLevel, item.classroom);
        if (location) {
            parts.push(location);
        }
        if (item.scanType) {
            parts.push(item.scanType);
        }
        if (item.message) {
            parts.push(item.message);
        }

        return parts.length > 0 ? parts.join(' • ') : 'บันทึกรายการ';
    }

    function createFeedItemEl(item) {
        const iconMap = { success: 'bi-person-check-fill', dup: 'bi-exclamation-circle-fill', failed: 'bi-person-x-fill' };
        const icon = iconMap[item.type] || 'bi-question-circle';
        const el = document.createElement('div');
        el.className = `feed-item ${item.type}`;
        el.innerHTML = `
            <span class="feed-icon"><i class="bi ${icon}"></i></span>
            <div class="feed-body">
                <span class="feed-name" title="${escHtml(item.name)}">${escHtml(item.name)}</span>
                <span class="feed-sub">${escHtml(buildFeedSubText(item))}</span>
            </div>
            <span class="feed-time">${escHtml(item.time)}</span>`;
        return el;
    }

    // ── Feed ──
    function renderFeedHistory() {
        feedList.innerHTML = '';

        if (feedHistory.length === 0) {
            const empty = document.createElement('div');
            empty.className = 'feed-empty';
            empty.textContent = 'ยังไม่มีรายการสแกนที่แสดง';
            feedList.appendChild(empty);
            return;
        }

        for (const item of feedHistory) {
            feedList.appendChild(createFeedItemEl(item));
        }
    }

    function addFeedItem(type, name, sub, time, extra = {}) {
        feedHistory.unshift({
            type,
            name,
            sub,
            time,
            gradeLevel: extra.gradeLevel || '',
            classroom: extra.classroom || '',
            message: extra.message || '',
            scanType: extra.scanType || ''
        });
        feedHistory = feedHistory.slice(0, FEED_MAX);
        persistFeedHistory();
        renderFeedHistory();
    }

    loadFeedHistory();

    function formatTime(d) {
        return d.toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
    }

    async function postScan(url, blob) {
        const form = new FormData();
        form.append('Image', blob, 'frame.jpg');
        form.append('StationCode', STATION_CODE);
        form.append('StationToken', STATION_TOKEN);
        form.append('RecognitionProfile', selProfile.value);
        form.append('ClientCapturedAtLocal', new Date().toISOString());

        const response = await fetch(url, { method: 'POST', body: form });
        if (!response.ok) {
            return null;
        }

        return await response.json();
    }

    function sleep(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    async function postScanQueued(blob) {
        const form = new FormData();
        form.append('Image', blob, 'frame.jpg');
        form.append('StationCode', STATION_CODE);
        form.append('StationToken', STATION_TOKEN);
        form.append('RecognitionProfile', selProfile.value);
        form.append('ClientCapturedAtLocal', new Date().toISOString());

        const enqueueResp = await fetch(VERIFY_QUEUE_URL, { method: 'POST', body: form });
        if (enqueueResp.status === 429) {
            let retryAfterMs = QUEUE_BACKPRESSURE_COOLDOWN_MS;
            try {
                const overloadBody = await enqueueResp.json();
                const serverRetry = Number(overloadBody && overloadBody.retryAfterMs);
                if (Number.isFinite(serverRetry) && serverRetry > 0) {
                    retryAfterMs = Math.round(serverRetry);
                }
            } catch {
                // Ignore parse errors and use local fallback.
            }

            queueBackpressureLevel = Math.min(6, queueBackpressureLevel + 1);
            const localBackoffMs = Math.min(8000, retryAfterMs + (queueBackpressureLevel * 500));
            queueBackpressureUntil = Date.now() + Math.max(QUEUE_BACKPRESSURE_COOLDOWN_MS, localBackoffMs);
            return { __queueRejected: true };
        }

        if (enqueueResp.status === 409) {
            let retryAfterMs = Math.max(180, Math.floor(dynamicVerifyGapMs * 0.75));
            try {
                const duplicateBody = await enqueueResp.json();
                const serverRetry = Number(duplicateBody && duplicateBody.retryAfterMs);
                if (Number.isFinite(serverRetry) && serverRetry > 0) {
                    retryAfterMs = Math.round(serverRetry);
                }
            } catch {
                // Ignore parse errors and use local fallback.
            }

            queueBackpressureUntil = Math.max(queueBackpressureUntil, Date.now() + Math.min(2500, retryAfterMs));
            return { __queueRejected: true, __queueRejectedKind: 'duplicate' };
        }

        if (enqueueResp.status === 400) {
            queueBackpressureUntil = Math.max(queueBackpressureUntil, Date.now() + Math.min(1600, Math.max(300, dynamicVerifyGapMs)));
            return { __queueRejected: true, __queueRejectedKind: 'low-quality' };
        }

        if (!enqueueResp.ok) {
            return null;
        }

        const enqueueJson = await enqueueResp.json();
        queueBackpressureLevel = Math.max(0, queueBackpressureLevel - 1);
        const jobId = enqueueJson && enqueueJson.jobId ? String(enqueueJson.jobId) : '';
        if (!jobId) {
            return null;
        }

        for (let i = 0; i < 24; i++) {
            const resultResp = await fetch(`${VERIFY_QUEUE_RESULT_URL}?jobId=${encodeURIComponent(jobId)}`, { cache: 'no-store' });
            if (resultResp.ok) {
                const resultJson = await resultResp.json();
                if (resultJson && resultJson.status === 'completed' && resultJson.result) {
                    return resultJson.result;
                }

                if (resultJson && resultJson.status === 'failed') {
                    return null;
                }
            }

            await sleep(200);
        }

        return null;
    }

    function renderDebugSnapshotItems(items) {
        if (!debugSnapshotList) {
            return;
        }

        debugSnapshotList.innerHTML = '';
        if (!Array.isArray(items) || items.length === 0) {
            const empty = document.createElement('div');
            empty.className = 'debug-empty';
            empty.textContent = 'ยังไม่มีภาพ debug ล่าสุด';
            debugSnapshotList.appendChild(empty);
            if (debugSnapshotHint) {
                debugSnapshotHint.textContent = 'ไม่มีข้อมูล';
            }
            return;
        }

        for (const item of items) {
            const a = document.createElement('a');
            a.className = 'debug-item';
            a.href = item.url;
            a.target = '_blank';
            a.rel = 'noopener noreferrer';
            const captured = item.capturedAtUtc ? new Date(item.capturedAtUtc).toLocaleTimeString('th-TH', { hour: '2-digit', minute: '2-digit', second: '2-digit' }) : '-';
            a.textContent = `${captured} • critical=${item.criticalSeconds || '-'}s • a=${item.analysisMs || '-'}ms`;
            debugSnapshotList.appendChild(a);
        }

        if (debugSnapshotHint) {
            debugSnapshotHint.textContent = `ล่าสุด ${items.length} รายการ`;
        }
    }

    async function refreshDebugSnapshots() {
        if (debugSnapshotRefreshInFlight) {
            return;
        }

        debugSnapshotRefreshInFlight = true;
        try {
            const resp = await fetch(DEBUG_SNAPSHOT_LIST_URL, { cache: 'no-store' });
            if (!resp.ok) {
                return;
            }

            const data = await resp.json();
            renderDebugSnapshotItems((data && data.items) || []);
        } catch {
            // Ignore one-off fetch errors for debug list.
        } finally {
            debugSnapshotRefreshInFlight = false;
        }
    }

    async function refreshQueueMetrics() {
        if (!queueMetricsText || queueMetricsRefreshInFlight) {
            return;
        }

        queueMetricsRefreshInFlight = true;
        try {
            const resp = await fetch(VERIFY_QUEUE_METRICS_URL, { cache: 'no-store' });
            if (!resp.ok) {
                queueMetricsText.textContent = 'Queue metrics: unavailable';
                queueMetricsText.style.color = '#fca5a5';
                return;
            }

            const data = await resp.json();
            const metrics = data && data.metrics ? data.metrics : null;
            if (!metrics) {
                queueMetricsText.textContent = 'Queue metrics: unavailable';
                queueMetricsText.style.color = '#fca5a5';
                return;
            }

            const pending = Number(metrics.pendingCount || 0);
            const rejected = Number(metrics.totalRejected || 0);
            const rejectedDuplicate = Number(metrics.totalRejectedDuplicate || 0);
            const rejectedLowQuality = Number(metrics.totalRejectedLowQuality || 0);
            const timeout = Number(metrics.totalTimeout || 0);
            const avgMs = Number(metrics.averageProcessMs || 0);
            const avgQueueWaitMs = Number(metrics.averageQueueWaitMs || 0);
            const effectiveThreshold = Number(metrics.effectiveRejectThreshold || 0);
            const effectiveDuplicateWindowMs = Number(metrics.effectiveDuplicateWindowMs || 0);
            const completed = Number(metrics.totalCompleted || 0);

            queueRejectedDelta = Math.max(0, rejected - latestQueueRejectedTotal);
            queueTimeoutDelta = Math.max(0, timeout - latestQueueTimeoutTotal);
            latestQueuePending = pending;
            latestQueueRejectedTotal = rejected;
            latestQueueTimeoutTotal = timeout;
            latestQueueAvgMs = Number.isFinite(avgMs) ? avgMs : 0;
            latestQueueCompleted = completed;
            lastQueueMetricsAt = Date.now();

            updateMatchPipelineHealth();

            queueMetricsText.textContent = `Queue metrics: pending=${pending}/${effectiveThreshold}, completed=${completed}, rejected=${rejected} (dup=${rejectedDuplicate}, low=${rejectedLowQuality}), timeout=${timeout}, avg=${avgMs.toFixed(1)}ms, wait=${avgQueueWaitMs.toFixed(1)}ms, dupWin=${effectiveDuplicateWindowMs}ms`;
            if (pending >= 8 || timeout > 0) {
                queueMetricsText.style.color = '#fca5a5';
            } else if (pending >= 3 || rejected > 0) {
                queueMetricsText.style.color = '#fcd34d';
            } else {
                queueMetricsText.style.color = '#93c5fd';
            }
        } catch {
            queueMetricsText.textContent = 'Queue metrics: unavailable';
            queueMetricsText.style.color = '#fca5a5';
        } finally {
            queueMetricsRefreshInFlight = false;
        }
    }

    async function cropFaceBlob(frameBlob, faceBox, paddingRatio = 0.16) {
        let bitmap = null;
        try {
            bitmap = await createImageBitmap(frameBlob);
            const srcW = bitmap.width;
            const srcH = bitmap.height;

            const padX = faceBox.width * paddingRatio;
            const padY = faceBox.height * paddingRatio;
            const sx = Math.max(0, Math.floor(faceBox.x - padX));
            const sy = Math.max(0, Math.floor(faceBox.y - padY));
            const ex = Math.min(srcW, Math.ceil(faceBox.x + faceBox.width + padX));
            const ey = Math.min(srcH, Math.ceil(faceBox.y + faceBox.height + padY));
            const sw = Math.max(1, ex - sx);
            const sh = Math.max(1, ey - sy);

            const canvas = document.createElement('canvas');
            canvas.width = sw;
            canvas.height = sh;
            const ctx = canvas.getContext('2d', { willReadFrequently: false });
            if (!ctx) {
                return frameBlob;
            }

            ctx.drawImage(bitmap, sx, sy, sw, sh, 0, 0, sw, sh);
            const faceBlob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.82));
            return faceBlob || frameBlob;
        } catch {
            return frameBlob;
        } finally {
            if (bitmap && bitmap.close) {
                bitmap.close();
            }
        }
    }

    async function cropFacesBlobs(frameBlob, faceBoxes, paddingRatio = 0.16) {
        if (!Array.isArray(faceBoxes) || faceBoxes.length === 0) {
            return [];
        }

        let bitmap = null;
        try {
            bitmap = await createImageBitmap(frameBlob);
            const srcW = bitmap.width;
            const srcH = bitmap.height;
            const blobs = [];

            for (const faceBox of faceBoxes) {
                const padX = faceBox.width * paddingRatio;
                const padY = faceBox.height * paddingRatio;
                const sx = Math.max(0, Math.floor(faceBox.x - padX));
                const sy = Math.max(0, Math.floor(faceBox.y - padY));
                const ex = Math.min(srcW, Math.ceil(faceBox.x + faceBox.width + padX));
                const ey = Math.min(srcH, Math.ceil(faceBox.y + faceBox.height + padY));
                const sw = Math.max(1, ex - sx);
                const sh = Math.max(1, ey - sy);

                const canvas = document.createElement('canvas');
                canvas.width = sw;
                canvas.height = sh;
                const ctx = canvas.getContext('2d', { willReadFrequently: false });
                if (!ctx) {
                    blobs.push(frameBlob);
                    continue;
                }

                ctx.drawImage(bitmap, sx, sy, sw, sh, 0, 0, sw, sh);
                const faceBlob = await new Promise(resolve => canvas.toBlob(resolve, 'image/jpeg', 0.82));
                blobs.push(faceBlob || frameBlob);
            }

            return blobs;
        } catch {
            return faceBoxes.map(() => frameBlob);
        } finally {
            if (bitmap && bitmap.close) {
                bitmap.close();
            }
        }
    }

    function enqueueVerifyTask(task) {
        if (Date.now() < queueBackpressureUntil) {
            return;
        }

        if (latestQueuePending >= SERVER_PENDING_HARD_LIMIT) {
            queueBackpressureUntil = Math.max(queueBackpressureUntil, Date.now() + 1200);
            return;
        }

        if (latestQueuePending >= SERVER_PENDING_WARN_LIMIT) {
            const pressureBackoffMs = 450 + Math.min(900, (latestQueuePending - SERVER_PENDING_WARN_LIMIT) * 20);
            queueBackpressureUntil = Math.max(queueBackpressureUntil, Date.now() + pressureBackoffMs);
        }

        if (verifyQueue.length >= QUEUE_MAX_ITEMS) {
            verifyQueue.shift();
        }

        verifyQueue.push(task);
        updateMatchPipelineHealth();
        processVerifyQueue();
    }

    function processVerifyQueue() {
        updateMatchPipelineHealth();
        while (activeWorkers < dynamicWorkers && verifyQueue.length > 0) {
            const task = verifyQueue.shift();
            activeWorkers++;
            updateMatchPipelineHealth();
            runVerifyTask(task)
                .catch(() => {})
                .finally(() => {
                    activeWorkers = Math.max(0, activeWorkers - 1);
                    updateMatchPipelineHealth();
                    processVerifyQueue();
                });
        }
    }

    function queueFrameAnalysis(job) {
        latestAnalysisJob = job;

        if (analysisScheduled || analysisInFlight) {
            return;
        }

        analysisScheduled = true;
        setTimeout(() => {
            analysisScheduled = false;
            void processLatestFrameAnalysis();
        }, 0);
    }

    async function processLatestFrameAnalysis() {
        if (analysisInFlight) {
            return;
        }

        analysisInFlight = true;
        try {
            while (latestAnalysisJob) {
                const job = latestAnalysisJob;
                latestAnalysisJob = null;
                try {
                    await analyzeFrame(job);
                } catch {
                    // Ignore one-off analysis errors and keep the preview loop flowing.
                }
            }
        } finally {
            analysisInFlight = false;
        }
    }

    async function analyzeFrame(job) {
        const { frameBlob, preparedFrame, now } = job;
        const analysisStartedAt = performance.now();
        try {
            const faceInfo = await detectFacesInfo(frameBlob, preparedFrame.width || camImg.naturalWidth || 1280, preparedFrame.height || camImg.naturalHeight || 720);
            latestFaceRect = faceInfo.rect;
            drawFaceOverlay(latestFaceRect, latestOverlayConfidence);

            if (dynamicFrameSkip > 1 && (job.frameCounter % dynamicFrameSkip) !== 0) {
                return;
            }

            setStatus('scanning', 'กำลังตรวจจับใบหน้า...');

            if (supportsLiveDetection) {
                if (faceInfo.count === 0) {
                    faceStableCount = 0;
                    noFaceStreak++;
                    setStatus('scanning', 'ยังไม่พบใบหน้า – รอสแกน...');
                    return;
                }

                if (faceInfo.count > 1) {
                    if (selFacePolicy.value === 'single') {
                        faceStableCount = 0;
                        setStatus('waiting', `พบหลายใบหน้า (${faceInfo.count}) กรุณาให้เข้าเฟรมทีละคน`);
                        return;
                    }

                    setStatus('scanning', `พบหลายใบหน้า (${faceInfo.count}) เลือกหน้าเด่นสุด`);
                }

                noFaceStreak = 0;
                faceStableCount++;
                if (faceStableCount < dynamicFaceStableHits) {
                    setStatus('scanning', 'พบใบหน้า กำลังยืนยันตำแหน่ง...');
                    return;
                }
            } else {
                if (Date.now() < previewNoFaceCooldownUntil) {
                    setStatus('scanning', 'ยังไม่พบใบหน้า – รอสแกน...');
                    return;
                }

                const previewGapMs = Math.max(
                    PREVIEW_API_MIN_GAP_MS,
                    Math.min(1400, Math.round((avgAnalysisMs || 0) * 0.6)),
                    verifyQueue.length > 0 ? 950 : 0
                );
                const previewNowMs = Date.now();
                if ((previewNowMs - lastPreviewApiAt) < previewGapMs) {
                    setStatus('scanning', 'โหมดประหยัด: หน่วงงาน preview ชั่วคราว');
                    return;
                }

                lastPreviewApiAt = previewNowMs;

                const preview = await postScan(PREVIEW_URL, frameBlob);
                if (!preview) {
                    setStatus('waiting', 'ตรวจจับไม่ได้ ชั่วคราว');
                    return;
                }

                const previewConfidence = Number(preview.confidence ?? 0);
                latestOverlayConfidence = Number.isFinite(previewConfidence) ? previewConfidence : null;
                drawFaceOverlay(latestFaceRect, latestOverlayConfidence);

                if (!preview.success) {
                    const message = String(preview.message || '');
                    const noFace = message.includes('ไม่พบใบหน้า') || message.includes('ไม่สามารถประมวลผลข้อมูลใบหน้า') || message.includes('ไม่พบข้อมูล');
                    noFaceStreak++;

                    if (noFace) {
                        previewNoFaceCooldownUntil = Date.now() + 1200;
                        setStatus('scanning', 'ยังไม่พบใบหน้า – รอสแกน...');
                        return;
                    }

                    cntFail++;
                    document.getElementById('cntFail').textContent = cntFail;
                    addFeedItem('failed', 'ตรวจไม่ผ่านเกณฑ์', message || 'ความมั่นใจไม่พอ', formatTime(now), {
                        message: message || 'ความมั่นใจไม่พอ',
                        scanType: 'preview'
                    });
                    setStatus('scanning', 'ตรวจพบไม่ผ่านเกณฑ์ – รอสแกน...');
                    return;
                }

                noFaceStreak = 0;
                previewNoFaceCooldownUntil = 0;
                if (Number.isFinite(previewConfidence) && previewConfidence < MIN_CONFIDENCE) {
                    cntFail++;
                    document.getElementById('cntFail').textContent = cntFail;
                    addFeedItem('failed', 'ความมั่นใจต่ำ', `ต่ำกว่าเกณฑ์ (${previewConfidence.toFixed(2)})`, formatTime(now), {
                        message: `ต่ำกว่าเกณฑ์ ${previewConfidence.toFixed(2)}`,
                        scanType: 'preview'
                    });
                    setStatus('scanning', `พบใบหน้าแต่ความมั่นใจต่ำ (${previewConfidence.toFixed(2)})`);
                    return;
                }
            }

            const modeMulti = selFacePolicy.value === 'multi';
            const candidateBoxes = supportsLiveDetection
                ? (faceInfo.boxes || []).slice(0, modeMulti ? MULTI_FRAME_FACE_LIMIT : 1)
                : [null];

            if (candidateBoxes.length === 0) {
                setStatus('waiting', 'ไม่พบใบหน้าที่พร้อมสแกน');
                return;
            }

            if (selScanEngine.value === 'buffered') {
                if (latestQueuePending >= SERVER_PENDING_HARD_LIMIT) {
                    setStatus('waiting', 'คิวเซิร์ฟเวอร์แน่น: หน่วงการส่งงานชั่วคราว');
                    return;
                }

                const queueSlack = Math.max(0, QUEUE_MAX_ITEMS - verifyQueue.length);
                const serverQueueBudget = latestQueuePending >= SERVER_PENDING_WARN_LIMIT
                    ? 1
                    : 2;
                const maxToQueue = Math.max(1, Math.min(candidateBoxes.length, Math.min(queueSlack, Math.min(MULTI_FRAME_FACE_LIMIT, serverQueueBudget))));
                const selectedBoxes = candidateBoxes.slice(0, maxToQueue);
                const croppedBlobs = selectedBoxes.some(Boolean)
                    ? await cropFacesBlobs(frameBlob, selectedBoxes.filter(Boolean))
                    : [frameBlob];

                let blobCursor = 0;
                for (const box of selectedBoxes) {
                    const cropped = box ? (croppedBlobs[blobCursor++] || frameBlob) : frameBlob;
                    enqueueVerifyTask({ blob: cropped, createdAt: Date.now() });
                }

                faceStableCount = 0;
                setStatus('scanning', `โหมด${getScanEngineLabel()}: เข้าคิว ${selectedBoxes.length} ใบหน้า (คิว ${verifyQueue.length})`);
                return;
            }

            const firstFace = candidateBoxes[0] || null;
            const classicBlob = firstFace ? await cropFaceBlob(frameBlob, firstFace) : frameBlob;
            await runVerifyTask({ blob: classicBlob, createdAt: Date.now() });
            faceStableCount = 0;
            setStatus('scanning', `โหมด${getScanEngineLabel()}: ตรวจสอบหน้าเด่นสุด`);
        } finally {
            const analysisDurationMs = performance.now() - analysisStartedAt;
            if (analysisDurationMs > 0) {
                avgAnalysisMs = ema(avgAnalysisMs, analysisDurationMs, 0.2);
                updatePerformanceMetrics();
            }
        }
    }

    async function runVerifyTask(task) {
        const now = new Date();
        if (Date.now() < queueBackpressureUntil) {
            return;
        }

        if ((now.getTime() - lastVerifyAt) < dynamicVerifyGapMs) {
            return;
        }

        lastVerifyAt = now.getTime();
        const verifyStartAt = performance.now();
        let result = await postScanQueued(task.blob);
        if (result && result.__queueRejected) {
            if (result.__queueRejectedKind === 'duplicate') {
                setStatus('waiting', 'ภาพซ้ำต่อเนื่อง ลดความถี่ส่งเฟรมอัตโนมัติ');
            } else if (result.__queueRejectedKind === 'low-quality') {
                setStatus('waiting', 'ภาพไม่ชัดหรือเล็กเกินไป ข้ามเฟรมนี้อัตโนมัติ');
            } else {
                setStatus('waiting', 'คิวสแกนแน่นชั่วคราว ลดความถี่ตรวจจับอัตโนมัติ');
            }
            return;
        }

        if (!result) {
            result = await postScan(VERIFY_URL, task.blob);
        }
        const verifyDurationMs = performance.now() - verifyStartAt;
        if (verifyDurationMs > 0) {
            avgVerifyMs = ema(avgVerifyMs, verifyDurationMs, 0.2);
        }

        if (!result) {
            return;
        }

        if (!result.success && !result.isDuplicate) {
            return;
        }

        const key = result.studentCode || result.studentId || '__unknown';
        const lastScan = cooldownMap.get(key);
        if (lastScan && (now.getTime() - lastScan) < COOLDOWN_MS) {
            return;
        }

        cooldownMap.set(key, now.getTime());
        const name = result.studentName || 'ไม่ทราบชื่อ';
        const location = buildLocationLabel(result.gradeLevel, result.classroom);
        const timeStr = formatTime(now);

        if (result.isDuplicate) {
            cntDup++;
            document.getElementById('cntDup').textContent = cntDup;
            const sub = location ? `${location} • ข้อมูลซ้ำ – บันทึกแล้ว` : 'ข้อมูลซ้ำ – บันทึกแล้ว';
            showSplash('dup', name, sub);
            addFeedItem('dup', name, sub, timeStr, {
                gradeLevel: result.gradeLevel,
                classroom: result.classroom,
                message: result.message || 'ข้อมูลซ้ำ',
                scanType: result.scanType || ''
            });
            playBeep('dup');
            setStatus('scanning', 'บันทึกซ้ำ – รอสแกน...');
        } else {
            cntSuccess++;
            document.getElementById('cntSuccess').textContent = cntSuccess;
            const sub = location ? `${location} • ${result.message || 'บันทึกเรียบร้อย'}` : (result.message || 'บันทึกเรียบร้อย');
            showSplash('success', name, sub);
            addFeedItem('success', name, sub, timeStr, {
                gradeLevel: result.gradeLevel,
                classroom: result.classroom,
                message: result.message || 'บันทึกเรียบร้อย',
                scanType: result.scanType || ''
            });
            playBeep('success');
            setStatus('scanning', 'สแกนสำเร็จ – รอคนถัดไป...');
        }
    }

    function ema(prev, value, alpha) {
        if (!Number.isFinite(prev) || prev <= 0) {
            return value;
        }

        return (prev * (1 - alpha)) + (value * alpha);
    }

    function clamp(value, min, max) {
        return Math.max(min, Math.min(max, value));
    }

    function runAutoTuning() {
        if (LIVE_STREAM_ENABLED) {
            const streamDelay = getStreamAnalysisDelayMs();
            dynamicFaceStableHits = FACE_STABLE_HITS;
            dynamicVerifyGapMs = VERIFY_MIN_GAP_MS;
            dynamicFastIntervalMs = streamDelay;
            dynamicNormalIntervalMs = streamDelay;
            dynamicIdleIntervalMs = Math.max(streamDelay, PREVIEW_IDLE_INTERVAL_MS);
            const freshServerMetrics = (Date.now() - lastQueueMetricsAt) <= 3500;
            const serverOverloaded = freshServerMetrics
                && (latestQueuePending >= 8 || queueRejectedDelta > 0 || queueTimeoutDelta > 0 || latestQueueAvgMs >= 1300);
            const overloaded = avgAnalysisMs >= LATENCY_CRITICAL_MS
                || avgLoopMs >= (LATENCY_CRITICAL_MS + 120)
                || verifyQueue.length >= 4
                || Date.now() < queueBackpressureUntil
                || serverOverloaded;

            if (serverOverloaded) {
                queueBackpressureUntil = Math.max(queueBackpressureUntil, Date.now() + 1200);
            }

            dynamicFrameSkip = overloaded ? Math.max(2, ANALYSIS_FRAME_SKIP_BASE + 1) : ANALYSIS_FRAME_SKIP_BASE;
            dynamicWorkers = (selScanEngine.value === 'buffered' && selFacePolicy.value === 'multi' && !overloaded) ? 2 : 1;

            const barPct = clamp((avgLoopMs / 1800) * 100, 5, 100);
            latencyFill.style.width = `${barPct.toFixed(1)}%`;
            latencyValue.textContent = `${Math.round(avgLoopMs || 0)} ms`;
            maybeAdaptiveAdjustAnalysisFps();
            maybeAdaptiveAdjustDisplayFps();
            if (maybeAutoSwitchPresetForLatency()) {
                return;
            }
            latencyTune.textContent = `Stream buffer: display=${getCurrentDisplayFps()} FPS, analysis=${getCurrentAnalysisFps()} FPS, frameSkip=${dynamicFrameSkip}, adaptive=${chkAdaptiveStream.checked ? 'on' : 'off'}, lockPreset=${chkPresetLock.checked ? 'on' : 'off'}, critical=${getCriticalDurationSeconds()}s, queue=${latestQueuePending}/${latestQueueCompleted}, engine=${selScanEngine.value}, res=${selResolution.value}`;
            return;
        }

        if (!CAMERA_AUTO_TUNE) {
            dynamicFaceStableHits = FACE_STABLE_HITS;
            dynamicVerifyGapMs = VERIFY_MIN_GAP_MS;
            dynamicFastIntervalMs = FAST_INTERVAL_MS;
            dynamicNormalIntervalMs = NORMAL_INTERVAL_MS;
            dynamicIdleIntervalMs = IDLE_INTERVAL_MS;
            dynamicWorkers = (selScanEngine.value === 'buffered' && selFacePolicy.value === 'multi') ? 2 : 1;
            const barPct = clamp((avgLoopMs / 1800) * 100, 5, 100);
            latencyFill.style.width = `${barPct.toFixed(1)}%`;
            latencyValue.textContent = `${Math.round(avgLoopMs || 0)} ms`;
            latencyTune.textContent = `Auto tuning: ปิด (ใช้ stream buffer) engine=${selScanEngine.value}, res=${selResolution.value}, stable=${dynamicFaceStableHits}, workers=${dynamicWorkers}, q=${verifyQueue.length}`;
            return;
        }

        let factor = 1;
        if (avgSnapMs > 850 || avgVerifyMs > 1050 || consecutiveSnapError >= 2) {
            factor = 1.6;
        } else if (avgSnapMs > 520 || avgVerifyMs > 760 || consecutiveSnapError === 1) {
            factor = 1.25;
        } else if (avgSnapMs > 0 && avgVerifyMs > 0 && avgSnapMs < 280 && avgVerifyMs < 420) {
            factor = 0.75;
        }

        dynamicNormalIntervalMs = clamp(Math.round(INTERVAL_MS * factor), 220, 2600);
        dynamicFastIntervalMs = clamp(Math.round(dynamicNormalIntervalMs * 0.55), 140, dynamicNormalIntervalMs);
        dynamicIdleIntervalMs = clamp(Math.round(dynamicNormalIntervalMs * 1.7), dynamicNormalIntervalMs, 3200);

        dynamicFaceStableHits = factor >= 1.5 ? 3 : (factor >= 1.15 ? 2 : 1);
        dynamicVerifyGapMs = factor >= 1.5 ? 1200 : (factor >= 1.15 ? 950 : 700);
        dynamicFrameSkip = factor >= 1.5 ? Math.max(3, ANALYSIS_FRAME_SKIP_BASE + 1) : (factor >= 1.15 ? Math.max(2, ANALYSIS_FRAME_SKIP_BASE) : ANALYSIS_FRAME_SKIP_BASE);
        if (selScanEngine.value !== 'buffered') {
            dynamicWorkers = 1;
        } else if (selFacePolicy.value === 'multi') {
            dynamicWorkers = factor >= 1.5 ? 1 : (factor >= 1.15 ? 2 : 3);
        } else {
            dynamicWorkers = 1;
        }

        maybeAutoAdjustResolution(factor);

        const barPct = clamp((avgLoopMs / 1800) * 100, 5, 100);
        latencyFill.style.width = `${barPct.toFixed(1)}%`;
        latencyValue.textContent = `${Math.round(avgLoopMs || 0)} ms`;
        latencyTune.textContent = `Auto tuning: engine=${selScanEngine.value}, res=${selResolution.value}, stable=${dynamicFaceStableHits}, workers=${dynamicWorkers}, frameSkip=${dynamicFrameSkip}, q=${verifyQueue.length}, interval=${dynamicNormalIntervalMs}ms`;
    }

    // Legacy single-loop runtime removed. Split preview/detect pipelines are now the primary runtime.

    function stopSplitPipelines() {
        if (previewLoopTimer) {
            clearTimeout(previewLoopTimer);
            previewLoopTimer = null;
        }
        if (analysisLoopTimer) {
            clearTimeout(analysisLoopTimer);
            analysisLoopTimer = null;
        }
        splitPipelinesRunning = false;
    }

    async function runPreviewLoop() {
        if (!splitPipelinesRunning) {
            return;
        }

        const loopStartedAt = performance.now();
        try {
            if (LIVE_STREAM_ENABLED) {
                refreshLiveStreamSource();
                const naturalW = camImg.naturalWidth || latestFrameWidth || 0;
                const naturalH = camImg.naturalHeight || latestFrameHeight || 0;
                if (naturalW > 0 && naturalH > 0) {
                    latestFrameWidth = naturalW;
                    latestFrameHeight = naturalH;
                    autoFitCameraImage(latestFrameWidth, latestFrameHeight);
                    camOffline.style.display = 'none';
                    hideRetryBanner();
                } else {
                    setPipelineHealth('video', 'warn', 'buffering');
                }
            } else {
                const resp = await fetch(SNAP_URL + Date.now(), { cache: 'no-store' });
                if (!resp.ok) {
                    consecutiveSnapError++;
                    showRetryBanner(consecutiveSnapError);
                    setPipelineHealth('video', consecutiveSnapError >= 3 ? 'bad' : 'warn', `HTTP ${resp.status}`);
                    if (consecutiveSnapError >= 3) {
                        camImg.style.display = 'none';
                        camOffline.style.display = '';
                    }
                } else {
                    consecutiveSnapError = 0;
                    hideRetryBanner();
                    camOffline.style.display = 'none';
                    const blob = await resp.blob();
                    const objUrl = URL.createObjectURL(blob);
                    const prevUrl = camImg.src;
                    camImg.src = objUrl;
                    camImg.style.display = '';
                    if (prevUrl && prevUrl.startsWith('blob:')) {
                        URL.revokeObjectURL(prevUrl);
                    }

                    const prepared = await prepareFrameBlob(blob);
                    latestFrameWidth = prepared.width || camImg.naturalWidth || latestFrameWidth;
                    latestFrameHeight = prepared.height || camImg.naturalHeight || latestFrameHeight;
                    autoFitCameraImage(latestFrameWidth, latestFrameHeight);
                }
            }

            const previewNow = performance.now();
            if (lastPreviewPaintAt > 0) {
                const previewDelta = previewNow - lastPreviewPaintAt;
                if (previewDelta > 0) {
                    avgPreviewFrameMs = ema(avgPreviewFrameMs, previewDelta, 0.22);
                }
            }
            lastPreviewPaintAt = previewNow;
            setPipelineHealth('video', 'ok', `${(1000 / Math.max(1, avgPreviewFrameMs || 1)).toFixed(1)}fps`);
            updatePerformanceMetrics();
        } catch {
            setPipelineHealth('video', 'bad', 'error');
        } finally {
            const loopMs = performance.now() - loopStartedAt;
            if (loopMs > 0) {
                avgLoopMs = ema(avgLoopMs, loopMs, 0.1);
            }

            const nextDelay = getPreviewTickDelayMs();
            previewLoopTimer = setTimeout(() => {
                void runPreviewLoop();
            }, nextDelay);
        }
    }

    async function runAnalysisLoop() {
        if (!splitPipelinesRunning) {
            return;
        }

        const startedAt = performance.now();
        let snapMs = 0;
        try {
            let preparedFrame = null;
            const snapStart = performance.now();
            if (LIVE_STREAM_ENABLED) {
                preparedFrame = await captureFrameFromLiveStream();
            } else {
                const snapResp = await fetch(SNAP_URL + Date.now(), { cache: 'no-store' });
                if (snapResp.ok) {
                    const sourceBlob = await snapResp.blob();
                    preparedFrame = await prepareFrameBlob(sourceBlob);
                }
            }
            snapMs = performance.now() - snapStart;

            if (!preparedFrame || !preparedFrame.blob) {
                consecutiveSnapError++;
                setPipelineHealth('detect', consecutiveSnapError >= 3 ? 'bad' : 'warn', 'no-frame');
                if (consecutiveSnapError >= 3) {
                    setStatus('waiting', 'กำลังรอบัฟเฟอร์สตรีมภาพ...');
                }
                return;
            }

            consecutiveSnapError = 0;
            frameCounter++;
            latestOverlayConfidence = null;

            if (!shouldRunAnalysisNow()) {
                setPipelineHealth('detect', 'warn', 'throttled');
                return;
            }

            setPipelineHealth('detect', 'ok', `${getCurrentAnalysisFps()}fps`);
            queueFrameAnalysis({
                frameBlob: preparedFrame.blob,
                preparedFrame,
                now: new Date(),
                frameCounter
            });

            if (analysisInFlight) {
                setPipelineHealth('detect', 'warn', 'busy');
            }
            setStatus('scanning', 'กำลังประมวลผลภาพ...');
        } catch {
            setPipelineHealth('detect', 'bad', 'error');
        } finally {
            const loopMs = performance.now() - startedAt;
            if (loopMs > 0) {
                avgLoopMs = ema(avgLoopMs, loopMs, 0.16);
            }
            if (snapMs > 0) {
                avgSnapMs = ema(avgSnapMs, snapMs, 0.2);
            }

            tuningSampleCount++;
            if (tuningSampleCount % 3 === 0) {
                runAutoTuning();
            }

            updateMatchPipelineHealth();
            const nextDelay = getStreamAnalysisDelayMs();
            analysisLoopTimer = setTimeout(() => {
                void runAnalysisLoop();
            }, nextDelay);
        }
    }

    function startRealtimeRuntime() {
        stopSplitPipelines();
        splitPipelinesRunning = true;
        setPipelineHealth('video', 'warn', 'starting');
        setPipelineHealth('detect', 'warn', 'starting');
        setPipelineHealth('match', 'warn', 'starting');
        void runPreviewLoop();
        void runAnalysisLoop();
    }

    async function checkCameraConnection(quiet = false) {
        try {
            const response = await fetch(TEST_CONNECTION_URL, { cache: 'no-store' });
            if (!response.ok) {
                throw new Error(`HTTP ${response.status}`);
            }

            const data = await response.json();
            if (data && data.success) {
                camOffline.style.display = 'none';
                hideRetryBanner();
                setPipelineHealth('video', 'ok', 'connected');
                if (!quiet) {
                    const source = data.source ? ` (${String(data.source).toUpperCase()})` : '';
                    setStatus('waiting', `เชื่อมต่อกล้องสำเร็จ${source}`);
                }
                return true;
            }

            const message = (data && data.message) ? String(data.message) : 'ทดสอบการเชื่อมต่อกล้องไม่ผ่าน';
            if (camOfflineText) {
                camOfflineText.textContent = message;
            }
            camImg.style.display = 'none';
            camOffline.style.display = '';
            setPipelineHealth('video', 'bad', 'offline');
            setStatus('error', message);
            return false;
        } catch {
            if (!quiet) {
                setStatus('error', 'ตรวจสอบการเชื่อมต่อกล้องไม่สำเร็จ');
            }
            setPipelineHealth('video', 'bad', 'check-failed');
            return false;
        }
    }

    resizeOverlayCanvas();
    window.addEventListener('resize', () => {
        resizeOverlayCanvas();
        autoFitCameraImage(latestFrameWidth, latestFrameHeight);
        drawFaceOverlay(latestFaceRect, latestOverlayConfidence);
    });
    initFaceDetector();
    runAutoTuning();

    // Low-latency startup defaults for first-time users while preserving saved preferences.
    if (!persistedEngine) {
        selScanEngine.value = cameraDefaultEngine;
        localStorage.setItem(scanEngineStorageKey, selScanEngine.value);
    }

    if (!persistedResolution) {
        selResolution.value = '640x360';
        localStorage.setItem(resolutionStorageKey, selResolution.value);
    }

    selViewMode.value = 'contain';
    localStorage.setItem(viewModeStorageKey, 'contain');
    applyViewMode('contain', true);
    refreshPixelBadge();
    void refreshQueueMetrics();

    setStatus('waiting', 'กำลังตรวจสอบการเชื่อมต่อกล้อง...');
    checkCameraConnection(false).finally(() => {
        startRealtimeRuntime();
    });

    window.addEventListener('beforeunload', () => {
        stopSplitPipelines();
    });

    setInterval(() => {
        checkCameraConnection(true);
    }, CAMERA_CONNECTION_CHECK_INTERVAL_MS);

    setInterval(() => {
        void refreshDebugSnapshots();
    }, 10000);

    setInterval(() => {
        void refreshQueueMetrics();
    }, 1000);
})();
</script>
</body>
</html>
