@using FaceScan.Web.Models.Entities
@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item text-light small me-lg-2 user-chip">
        <i class="bi bi-person-circle me-1"></i>
        @(UserManager.GetUserName(User) ?? "-")
    </li>
    <li class="nav-item">
        <form asp-area="" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-sm btn-outline-light rounded-pill px-3">
                <i class="bi bi-box-arrow-right me-1"></i> ออกจากระบบ
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-sm btn-light rounded-pill px-3" asp-area="" asp-controller="Account" asp-action="Login">
            <i class="bi bi-box-arrow-in-right me-1"></i> เข้าสู่ระบบ
        </a>
    </li>
}
</ul>
