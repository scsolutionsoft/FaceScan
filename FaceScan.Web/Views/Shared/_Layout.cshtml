@using FaceScan.Web.Services.Interfaces
@inject ISystemSettingService SystemSettingService
@{
    string NormalizeColor(string? value, string fallback)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return fallback;
        }

        var trimmed = value.Trim();
        return trimmed.Length == 7 && trimmed.StartsWith('#') ? trimmed.ToUpperInvariant() : fallback;
    }

    string ToRgb(string hex)
    {
        var color = NormalizeColor(hex, "#000000");
        var red = Convert.ToInt32(color.Substring(1, 2), 16);
        var green = Convert.ToInt32(color.Substring(3, 2), 16);
        var blue = Convert.ToInt32(color.Substring(5, 2), 16);
        return $"{red}, {green}, {blue}";
    }

    var appSettings = await SystemSettingService.GetSettingsAsync();
    var displayName = string.IsNullOrWhiteSpace(appSettings.ApplicationDisplayName) ? "FaceScan" : appSettings.ApplicationDisplayName;
    var tagline = string.IsNullOrWhiteSpace(appSettings.ApplicationTagline) ? "ระบบเช็กเวลาเข้า-ออกด้วยการสแกนใบหน้า" : appSettings.ApplicationTagline;
    var logoRelativePath = string.IsNullOrWhiteSpace(appSettings.BrandLogoPath) ? "img/facescan-mark.svg" : appSettings.BrandLogoPath.TrimStart('/');
    var logoUrl = Url.Content($"~/{logoRelativePath}");
    var pageTitle = string.IsNullOrWhiteSpace(ViewData["Title"]?.ToString())
        ? displayName
        : $"{ViewData["Title"]} - {displayName}";
    var primaryColor = NormalizeColor(appSettings.ThemePrimaryColor, "#7C3AED");
    var primarySoftColor = NormalizeColor(appSettings.ThemePrimarySoftColor, "#A855F7");
    var accentColor = NormalizeColor(appSettings.ThemeAccentColor, "#E9D5FF");
    var backgroundColor = NormalizeColor(appSettings.ThemeBackgroundColor, "#F7F3FF");
    var surfaceColor = NormalizeColor(appSettings.ThemeSurfaceColor, "#FFFFFF");
    var sidebarStartColor = NormalizeColor(appSettings.ThemeSidebarStartColor, "#7C3AED");
    var sidebarEndColor = NormalizeColor(appSettings.ThemeSidebarEndColor, "#4C1D95");
    var homeArea = string.Empty;
    var homeController = "Dashboard";

    if (User.IsInRole("Student"))
    {
        homeController = "StudentPortal";
    }
    else if (User.IsInRole("Executive"))
    {
        homeArea = "Executive";
        homeController = "Reports";
    }
    else if (User.IsInRole("Teacher") || User.IsInRole("HomeroomHead"))
    {
        homeArea = "Teacher";
        homeController = "Home";
    }
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@400;500;600;700&family=Sarabun:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        :root {
            --bg: @backgroundColor;
            --panel: @surfaceColor;
            --primary: @primaryColor;
            --primary-soft: @primarySoftColor;
            --accent: @accentColor;
            --primary-rgb: @ToRgb(primaryColor);
            --primary-soft-rgb: @ToRgb(primarySoftColor);
            --accent-rgb: @ToRgb(accentColor);
            --sidebar-start: @sidebarStartColor;
            --sidebar-end: @sidebarEndColor;
            --sidebar-start-rgb: @ToRgb(sidebarStartColor);
            --sidebar-end-rgb: @ToRgb(sidebarEndColor);
            --page-gradient-start: @surfaceColor;
            --page-gradient-end: @backgroundColor;
        }
    </style>
</head>
<body>
    <div class="page-bg-art" aria-hidden="true">
        <span class="bg-orb orb-one"></span>
        <span class="bg-orb orb-two"></span>
        <span class="bg-orb orb-three"></span>
    </div>

    <div class="app-shell">
        <aside class="sidebar d-none d-lg-flex">
            <div class="sidebar-brand">
                <a asp-area="@homeArea" asp-controller="@homeController" asp-action="Index" class="brand-link">
                    <img src="@logoUrl" alt="@displayName" class="brand-logo" />
                    <span>@displayName</span>
                </a>
                <div class="brand-subtitle">@tagline</div>
            </div>

            <div class="sidebar-scroll">
                <partial name="_SidebarMenu" />
            </div>

            <div class="sidebar-footer">
                <partial name="_LoginPartial" />
            </div>
        </aside>

        <div class="main-panel">
            <header class="mobile-header d-lg-none">
                <button class="btn btn-mobile-menu" type="button" data-bs-toggle="offcanvas" data-bs-target="#mobileSidebar" aria-controls="mobileSidebar">
                    <i class="bi bi-list me-1"></i> เมนู
                </button>
                <div class="mobile-title">@displayName</div>
                <a asp-area="@homeArea" asp-controller="@homeController" asp-action="Index" class="btn btn-light btn-sm rounded-pill px-3">หน้าแรก</a>
            </header>

            <main class="content-wrapper">
                <div class="container-fluid px-0">
                    @if (TempData["Success"] is string success)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @success
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                    @if (TempData["Error"] is string error)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @RenderBody()
                </div>
            </main>

            <footer class="footer text-muted">
                <div class="px-3 py-2">&copy; @DateTime.Now.Year @displayName</div>
            </footer>
        </div>
    </div>

    <div class="offcanvas offcanvas-start mobile-sidebar" tabindex="-1" id="mobileSidebar" aria-labelledby="mobileSidebarLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title d-flex align-items-center gap-2" id="mobileSidebarLabel">
                <img src="@logoUrl" alt="@displayName" width="24" height="24" style="object-fit: contain;" />
                @displayName
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <div class="small text-muted mb-3">@tagline</div>
            <partial name="_SidebarMenu" />
            <hr />
            <partial name="_LoginPartial" />
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
