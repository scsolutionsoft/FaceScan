@model FaceEnrollmentIndexViewModel
@{
    ViewData["Title"] = "ลงทะเบียนใบหน้า";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">ลงทะเบียนใบหน้า</h2>
</div>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>รหัสนักเรียน</th>
                <th>ชื่อ-สกุล</th>
                <th>ห้อง</th>
                <th>จำนวนรูป</th>
                <th>สถานะ</th>
                <th class="text-end">จัดการ</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Students)
            {
                <tr>
                    <td>@item.StudentCode</td>
                    <td>@item.FullName</td>
                    <td>@item.ClassroomName</td>
                    <td>@item.PhotoCount</td>
                    <td>
                        <span class="badge bg-secondary">@item.EnrollmentStatus.GetDisplayName()</span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Upload" asp-route-studentId="@item.StudentId" class="btn btn-sm btn-primary">
                            จัดการใบหน้า
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

