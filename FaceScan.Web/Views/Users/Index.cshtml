@model UsersIndexViewModel
@{
    ViewData["Title"] = "ผู้ใช้และสิทธิ์";
    var roles = ViewBag.Roles as List<string> ?? new List<string>();
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? string.Empty;
    var currentUserIsSuperAdmin = User.IsInRole("SuperAdmin");

    static string RoleLabel(string role) => role switch
    {
        "SuperAdmin" => "ผู้ดูแลสูงสุด",
        "Admin" => "ผู้ดูแลระบบ",
        "Executive" => "ผู้บริหาร",
        "Teacher" => "ครูผู้สอน",
        "HomeroomHead" => "หัวหน้าชั้น",
        "Student" => "นักเรียน",
        "Staff" => "เจ้าหน้าที่",
        "Viewer" => "ผู้ชม",
        _ => role
    };
}

<div class="row g-3">
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header">เพิ่มผู้ใช้</div>
            <div class="card-body">
                <form asp-action="Create" method="post" class="row g-2">
                    @Html.AntiForgeryToken()
                    <div class="col-12">
                        <label class="form-label">ชื่อผู้ใช้</label>
                        <input name="Username" class="form-control" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">อีเมล</label>
                        <input name="Email" type="email" class="form-control" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">รหัสผ่าน</label>
                        <input name="Password" type="password" class="form-control" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label">ชื่อ-นามสกุล</label>
                        <input name="FullName" class="form-control" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">บทบาท</label>
                        <select name="Role" class="form-select" required>
                            @foreach (var role in roles)
                            {
                                <option value="@role">@RoleLabel(role)</option>
                            }
                        </select>
                    </div>
                    <div class="col-12">
                        <label class="form-label">ห้องที่รับผิดชอบ (ถ้ามี)</label>
                        <select name="AssignedClassroomId" class="form-select">
                            <option value="">-- ไม่ระบุ --</option>
                            @foreach (var classroom in Model.Classrooms)
                            {
                                <option value="@classroom.Value">@classroom.Text</option>
                            }
                        </select>
                    </div>
                    <div class="col-12 d-grid">
                        <button type="submit" class="btn btn-primary">บันทึกผู้ใช้</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">รายการผู้ใช้</div>
            <div class="table-responsive">
                <table class="table table-striped mb-0 align-middle">
                    <thead>
                        <tr>
                            <th>ชื่อผู้ใช้</th>
                            <th>ชื่อ-นามสกุล</th>
                            <th>อีเมล</th>
                            <th>บทบาท</th>
                            <th>ห้องที่รับผิดชอบ</th>
                            <th>สถานะ</th>
                            <th class="text-end">จัดการ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model.Users)
                        {
                            var canDelete = !string.Equals(user.Id, currentUserId, StringComparison.Ordinal)
                                && (currentUserIsSuperAdmin || !string.Equals(user.Role, "SuperAdmin", StringComparison.OrdinalIgnoreCase));

                            <tr>
                                <td>@user.Username</td>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td>@RoleLabel(user.Role)</td>
                                <td>@(string.IsNullOrWhiteSpace(user.AssignedClassroom) ? "-" : user.AssignedClassroom)</td>
                                <td>
                                    @if (user.IsActive)
                                    {
                                        <span class="badge bg-success">ใช้งาน</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">ปิดใช้งาน</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="d-flex flex-wrap justify-content-end gap-1">
                                        <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@user.Id">แก้ไข</a>
                                        <form asp-action="ResetPassword" asp-route-id="@user.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Users")" />
                                            <button class="btn btn-sm btn-outline-info"
                                                    type="submit"
                                                    onclick="return confirm('รีเซ็ตรหัสผ่านของผู้ใช้ @user.Username และสร้างรหัสชั่วคราวใหม่ใช่หรือไม่?');">
                                                รีเซ็ตรหัสผ่าน
                                            </button>
                                        </form>
                                        <form asp-action="ToggleActive" asp-route-id="@user.Id" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button class="btn btn-sm btn-outline-warning">สลับสถานะ</button>
                                        </form>
                                        @if (canDelete)
                                        {
                                            <form asp-action="Delete" asp-route-id="@user.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="returnUrl" value="@Url.Action("Index", "Users")" />
                                                <button class="btn btn-sm btn-outline-danger"
                                                        type="submit"
                                                        onclick="return confirm('ยืนยันการลบข้อมูลผู้ใช้ @user.Username ใช่หรือไม่? การดำเนินการนี้ไม่สามารถย้อนกลับได้');">
                                                    ลบผู้ใช้
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn btn-sm btn-outline-danger" type="button" disabled>ลบผู้ใช้</button>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
