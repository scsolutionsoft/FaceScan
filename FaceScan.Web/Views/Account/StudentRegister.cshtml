@model StudentRegisterViewModel
@{
    ViewData["Title"] = "สมัครสมาชิกนักเรียน";
}

<div class="auth-shell">
    <div class="card auth-card shadow-sm mt-3 mt-lg-4">
        <div class="auth-head">
            <div class="d-flex align-items-center justify-content-between gap-3">
                <div>
                    <h3 class="mb-1">สมัครสมาชิกนักเรียน</h3>
                    <p class="mb-0 text-white-50">ยืนยันตัวตนด้วยรหัสนักเรียนและวันเกิดก่อนสร้างบัญชีสำหรับเมนูนักเรียน</p>
                </div>
                <i class="bi bi-mortarboard fs-1"></i>
            </div>
        </div>

        <div class="auth-body">
            <form asp-action="StudentRegister" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                <div class="mb-3">
                    <label asp-for="StudentCode" class="form-label"></label>
                    <input asp-for="StudentCode" class="form-control form-control-lg" placeholder="เช่น S0001" />
                    <span asp-validation-for="StudentCode" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="BirthDate" class="form-label"></label>
                    <input asp-for="BirthDate" class="form-control form-control-lg" type="date" />
                    <span asp-validation-for="BirthDate" class="text-danger"></span>
                </div>

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control form-control-lg" />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                    <div class="col-12 col-md-6">
                        <label asp-for="ConfirmPassword" class="form-label"></label>
                        <input asp-for="ConfirmPassword" class="form-control form-control-lg" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100 btn-lg rounded-pill mt-3">สมัครสมาชิกนักเรียน</button>
            </form>

            <div class="d-flex flex-column flex-sm-row gap-2 justify-content-between align-items-sm-center mt-3">
                <a asp-action="Login">กลับไปหน้าเข้าสู่ระบบ</a>
                <a asp-action="TeacherRegister" class="btn btn-outline-primary btn-sm rounded-pill px-3">ต้องการสมัครครู</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
